    rdfs:label "Open Source (GPLv3) / Commercial" .

ns1:hasIngredient a rdf:Property ;
    rdfs:label "has ingredient" ;
    rdfs:comment "Links a Dish to the FoodItems it contains." ;
    rdfs:domain ns1:Dish ;
    rdfs:range ns1:FoodItem .

<http://example.org/semantic-web/instance/bread> a ns1:FoodItem ;
    ns1:prefLabel "Bread" .

<http://example.org/semantic-web/instance/cheese> a ns1:FoodItem ;
    ns1:prefLabel "Cheese" .

<http://example.org/semantic-web/instance/chicken> a ns1:Meat ;
    ns1:prefLabel "Chicken (meat)" .

