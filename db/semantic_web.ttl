@prefix ns1: <http://example.org/semantic-web#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:APIInterface a rdfs:Class ;
    rdfs:label "API or interface" ;
    rdfs:comment "An application programming interface, endpoint style, workbench, driver, or native interface used to access a system." ;
    rdfs:subClassOf ns1:TechnologyArtifact .

ns1:Agent a rdfs:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "An actor such as a person, organization, or community that creates, maintains, publishes, or uses semantic technologies and artifacts." ;
    rdfs:subClassOf ns1:Entity .

ns1:ArchitectureLayer a rdfs:Class ;
    rdfs:label "Architecture layer" ;
    rdfs:comment "A layer in the Semantic Web architectural stack." ;
    rdfs:subClassOf ns1:ConceptualTopic .

ns1:Assumption a rdfs:Class ;
    rdfs:label "Assumption" ;
    rdfs:comment "A logical or modeling assumption adopted within semantic technologies." ;
    rdfs:subClassOf ns1:Principle .

ns1:AttributeProperty a rdfs:Class ;
    rdfs:label "Attribute property" ;
    rdfs:comment "A property that links a resource to a literal data value." ;
    rdfs:subClassOf ns1:PropertyConcept ;
    owl:disjointWith ns1:RelationshipProperty .

ns1:Axiom a rdfs:Class ;
    rdfs:label "Axiom" ;
    rdfs:comment "An explicit logical assertion or rule that constrains or defines the ontology." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:Capability a rdfs:Class ;
    rdfs:label "Capability" ;
    rdfs:comment "A functional ability that a software system or technology can provide." ;
    rdfs:subClassOf ns1:ConceptualTopic .

ns1:ClassConcept a rdfs:Class ;
    rdfs:label "Class concept" ;
    rdfs:comment "A concept representing a class or category in an ontology." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:ClassificationTask a rdfs:Class ;
    rdfs:label "Classification task" ;
    rdfs:comment "An inference task that computes implied class membership or taxonomy structure." ;
    rdfs:subClassOf ns1:InferenceTask .

ns1:Community a rdfs:Class ;
    rdfs:label "Community" ;
    rdfs:comment "A group or community that shares and develops a common conceptualization, vocabulary, or technology practice." ;
    rdfs:subClassOf ns1:Organization .

ns1:ConceptualTopic a rdfs:Class ;
    rdfs:label "Conceptual topic" ;
    rdfs:comment "A non-material conceptual subject, principle, feature, or topic relevant to the domain." ;
    rdfs:subClassOf ns1:Entity .

ns1:ConsistencyCheckingTask a rdfs:Class ;
    rdfs:label "Consistency checking task" ;
    rdfs:comment "An inference task that detects logical contradictions or incompatible assertions." ;
    rdfs:subClassOf ns1:InferenceTask .

ns1:Constraint a rdfs:Class ;
    rdfs:label "Constraint" ;
    rdfs:comment "A logical or structural restriction used to limit or validate modeling choices and data assertions." ;
    rdfs:subClassOf ns1:Axiom .

ns1:DataModel a rdfs:Class ;
    rdfs:label "Data model" ;
    rdfs:comment "A formal model for structuring and interpreting data, such as RDF or RDF Schema." ;
    rdfs:subClassOf ns1:TechnologyArtifact .

ns1:DataModelLayer a rdfs:Class ;
    rdfs:label "Data model layer" ;
    rdfs:comment "The layer covering RDF and RDF Schema as graph-oriented data models." ;
    rdfs:subClassOf ns1:ArchitectureLayer .

ns1:DatabaseManagementSystem a rdfs:Class ;
    rdfs:label "Database management system" ;
    rdfs:comment "A software system that manages persistent data storage and retrieval." ;
    rdfs:subClassOf ns1:SoftwareSystem .

ns1:Dataset a rdfs:Class ;
    rdfs:label "Dataset" ;
    rdfs:comment "A structured collection of data that may be expressed or published using semantic web technologies." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:Entity a rdfs:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "A broad top-level class for any conceptual, organizational, technological, or informational thing in this schema." .

ns1:Feature a rdfs:Class ;
    rdfs:label "Feature" ;
    rdfs:comment "A characteristic, specialization, or notable functional aspect of a software system or semantic artifact." ;
    rdfs:subClassOf ns1:ConceptualTopic .

ns1:FoundationalOntology a rdfs:Class ;
    rdfs:label "Foundational ontology" ;
    rdfs:comment "A domain-neutral or upper-level ontology used as a structural foundation for other ontologies." ;
    rdfs:subClassOf ns1:Ontology .

ns1:GraphDatabase a rdfs:Class ;
    rdfs:label "Graph database" ;
    rdfs:comment "A database management system centered on graph-structured data and graph-oriented access patterns." ;
    rdfs:subClassOf ns1:DatabaseManagementSystem .

ns1:IdentifierLayer a rdfs:Class ;
    rdfs:label "Identifier layer" ;
    rdfs:comment "The layer covering resource identification and character sets such as URI, IRI, and Unicode." ;
    rdfs:subClassOf ns1:ArchitectureLayer .

ns1:IdentifierScheme a rdfs:Class ;
    rdfs:label "Identifier scheme" ;
    rdfs:comment "A scheme for identifying resources, such as URI or IRI." ;
    rdfs:subClassOf ns1:TechnologyArtifact .

ns1:Individual a rdfs:Class ;
    rdfs:label "Individual" ;
    rdfs:comment "A concrete instance belonging to one or more classes in an ontology or knowledge graph." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:InferenceTask a rdfs:Class ;
    rdfs:label "Inference task" ;
    rdfs:comment "A specific reasoning task performed by a reasoner or inference engine." ;
    rdfs:subClassOf ns1:ConceptualTopic .

ns1:KnowledgeArtifact a rdfs:Class ;
    rdfs:label "Knowledge artifact" ;
    rdfs:comment "A formal or semi-formal artifact used to represent, organize, describe, or exchange knowledge." ;
    rdfs:subClassOf ns1:Entity .

ns1:KnowledgeGraph a rdfs:Class ;
    rdfs:label "Knowledge graph" ;
    rdfs:comment "A graph of entities connected by typed relationships, typically containing instance-level data." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:Language a rdfs:Class ;
    rdfs:label "Language" ;
    rdfs:comment "A formal language used for modeling, querying, reasoning, or serialization in the Semantic Web domain." ;
    rdfs:subClassOf ns1:TechnologyArtifact .

ns1:LicenseModel a rdfs:Class ;
    rdfs:label "License model" ;
    rdfs:comment "A licensing arrangement or distribution model associated with a software system." ;
    rdfs:subClassOf ns1:ConceptualTopic .

ns1:LogicalProfile a rdfs:Class ;
    rdfs:label "Logical profile" ;
    rdfs:comment "A constrained sublanguage or profile of an ontology language optimized for particular reasoning or query behavior." ;
    rdfs:subClassOf ns1:ConceptualTopic .

ns1:ManagedService a rdfs:Class ;
    rdfs:label "Managed service" ;
    rdfs:comment "A software offering operated as a managed service rather than solely as self-hosted software." ;
    rdfs:subClassOf ns1:SoftwareSystem .

ns1:NonUniqueNameAssumption a rdfs:Class ;
    rdfs:label "Non-Unique Name Assumption" ;
    rdfs:comment "An assumption that distinct identifiers may refer to the same real-world entity unless asserted otherwise." ;
    rdfs:subClassOf ns1:Assumption .

ns1:OWL2ELProfile a rdfs:Class ;
    rdfs:label "OWL 2 EL profile" ;
    rdfs:comment "A logical profile of OWL 2 oriented toward large vocabularies and polynomial-time reasoning." ;
    rdfs:subClassOf ns1:LogicalProfile .

ns1:OWL2QLProfile a rdfs:Class ;
    rdfs:label "OWL 2 QL profile" ;
    rdfs:comment "A logical profile of OWL 2 oriented toward query answering and relational database integration." ;
    rdfs:subClassOf ns1:LogicalProfile .

ns1:OWL2RLProfile a rdfs:Class ;
    rdfs:label "OWL 2 RL profile" ;
    rdfs:comment "A logical profile of OWL 2 oriented toward scalable rule-based reasoning." ;
    rdfs:subClassOf ns1:LogicalProfile .

ns1:Ontology a rdfs:Class ;
    rdfs:label "Ontology" ;
    rdfs:comment "A formal, explicit specification of a shared conceptualization." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:OntologyComponent a rdfs:Class ;
    rdfs:label "Ontology component" ;
    rdfs:comment "A structural primitive or component used within an ontology." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:OntologyLanguage a rdfs:Class ;
    rdfs:label "Ontology language" ;
    rdfs:comment "A formal language used to define ontologies and semantic constraints." ;
    rdfs:subClassOf ns1:Language .

ns1:OntologyLayer a rdfs:Class ;
    rdfs:label "Ontology layer" ;
    rdfs:comment "The layer covering richer semantic vocabularies and ontology languages such as OWL and SKOS." ;
    rdfs:subClassOf ns1:ArchitectureLayer .

ns1:OpenWorldAssumption a rdfs:Class ;
    rdfs:label "Open World Assumption" ;
    rdfs:comment "An assumption that missing information should be treated as unknown rather than false." ;
    rdfs:subClassOf ns1:Assumption .

ns1:Organization a rdfs:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "An organization such as a company, foundation, standards body, or project maintainer." ;
    rdfs:subClassOf ns1:Agent .

ns1:Person a rdfs:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human individual relevant to semantic web or ontology work." ;
    rdfs:subClassOf ns1:Agent .

ns1:Principle a rdfs:Class ;
    rdfs:label "Principle" ;
    rdfs:comment "A general conceptual principle or guiding semantic assumption." ;
    rdfs:subClassOf ns1:ConceptualTopic .

ns1:ProofTrustLayer a rdfs:Class ;
    rdfs:label "Proof and trust layer" ;
    rdfs:comment "The upper semantic web layer concerned with proof, provenance, trust, and reliability assessment." ;
    rdfs:subClassOf ns1:ArchitectureLayer .

ns1:PropertyConcept a rdfs:Class ;
    rdfs:label "Property concept" ;
    rdfs:comment "A conceptual representation of a property used in an ontology." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:Protocol a rdfs:Class ;
    rdfs:label "Protocol" ;
    rdfs:comment "A communication protocol used to access, query, or integrate semantic systems." ;
    rdfs:subClassOf ns1:TechnologyArtifact .

ns1:QueryLanguage a rdfs:Class ;
    rdfs:label "Query language" ;
    rdfs:comment "A language used to query semantic graphs or related structured data." ;
    rdfs:subClassOf ns1:Language .

ns1:QueryLayer a rdfs:Class ;
    rdfs:label "Query layer" ;
    rdfs:comment "The layer covering graph query technologies such as SPARQL." ;
    rdfs:subClassOf ns1:ArchitectureLayer .

ns1:Reasoner a rdfs:Class ;
    rdfs:label "Reasoner" ;
    rdfs:comment "A software system that performs logical inference, classification, or consistency checking over an ontology or graph." ;
    rdfs:subClassOf ns1:SoftwareSystem .

ns1:ReasoningCapability a rdfs:Class ;
    rdfs:label "Reasoning capability" ;
    rdfs:comment "A kind of semantic reasoning or inferential support provided by a system or ontology environment." ;
    rdfs:subClassOf ns1:ConceptualTopic .

ns1:RelationshipProperty a rdfs:Class ;
    rdfs:label "Relationship property" ;
    rdfs:comment "A property that links one resource to another resource." ;
    rdfs:subClassOf ns1:PropertyConcept .

ns1:RuleLanguage a rdfs:Class ;
    rdfs:label "Rule language" ;
    rdfs:comment "A language used to express rules or inference logic over semantic data." ;
    rdfs:subClassOf ns1:Language .

ns1:RulesLayer a rdfs:Class ;
    rdfs:label "Rules layer" ;
    rdfs:comment "The layer covering rules, logic, and related inferential mechanisms above the ontology and query layers." ;
    rdfs:subClassOf ns1:ArchitectureLayer .

ns1:SerializationFormat a rdfs:Class ;
    rdfs:label "Serialization format" ;
    rdfs:comment "A concrete syntax for expressing and exchanging RDF or related semantic data." ;
    rdfs:subClassOf ns1:TechnologyArtifact .

ns1:SoftwareSystem a rdfs:Class ;
    rdfs:label "Software system" ;
    rdfs:comment "A software product, platform, framework component, or service relevant to semantic technologies." ;
    rdfs:subClassOf ns1:TechnologyArtifact .

ns1:Standard a rdfs:Class ;
    rdfs:label "Standard" ;
    rdfs:comment "A formal specification or standard relevant to semantic technologies." ;
    rdfs:subClassOf ns1:TechnologyArtifact .

ns1:StandardsBody a rdfs:Class ;
    rdfs:label "Standards body" ;
    rdfs:comment "An organization that publishes or governs technical standards relevant to the Semantic Web." ;
    rdfs:subClassOf ns1:Organization .

ns1:SyntaxLayer a rdfs:Class ;
    rdfs:label "Syntax layer" ;
    rdfs:comment "The layer covering concrete serializations such as Turtle, JSON-LD, and RDF/XML." ;
    rdfs:subClassOf ns1:ArchitectureLayer .

ns1:Taxonomy a rdfs:Class ;
    rdfs:label "Taxonomy" ;
    rdfs:comment "A hierarchical classification scheme based primarily on parent-child or subclass relationships." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:TechnologyArtifact a rdfs:Class ;
    rdfs:label "Technology artifact" ;
    rdfs:comment "A technical standard, language, format, interface, software system, or related artifact in the Semantic Web stack." ;
    rdfs:subClassOf ns1:Entity .

ns1:Triplestore a rdfs:Class ;
    rdfs:label "Triplestore" ;
    rdfs:comment "A graph database or database management system specialized for storing and querying RDF triples." ;
    rdfs:subClassOf ns1:GraphDatabase .

ns1:Vocabulary a rdfs:Class ;
    rdfs:label "Vocabulary" ;
    rdfs:comment "A controlled set of terms used to describe resources in a domain." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:bfo a ns1:FoundationalOntology ;
    rdfs:label "BFO" ;
    ns1:description "A domain-neutral upper-level ontology used as a structural foundation so different sub-ontologies can interoperate." ;
    ns1:name "Basic Formal Ontology" .

ns1:canStoreArtifact a rdf:Property ;
    rdfs:label "can store artifact" ;
    rdfs:comment "Links a triplestore or graph database to the kind of knowledge artifact that it can store or manage." ;
    rdfs:domain ns1:SoftwareSystem ;
    rdfs:range ns1:KnowledgeArtifact .

ns1:dbpedia a ns1:Dataset,
        ns1:KnowledgeGraph ;
    rdfs:label "DBpedia" ;
    ns1:description "The structured RDF counterpart of Wikipedia and a central hub in Linked Open Data." ;
    ns1:implementsDataModel ns1:rdf ;
    ns1:name "DBpedia" ;
    ns1:usesIdentifierScheme ns1:iri .

ns1:definesConcept a rdf:Property ;
    rdfs:label "defines concept" ;
    rdfs:comment "Links an ontology or vocabulary to a concept, property, or component that it defines." ;
    rdfs:domain ns1:KnowledgeArtifact ;
    rdfs:range ns1:Entity .

ns1:dependsOnLayer a rdf:Property ;
    rdfs:label "depends on layer" ;
    rdfs:comment "Relates an architecture layer to another layer on which it depends." ;
    rdfs:domain ns1:ArchitectureLayer ;
    rdfs:range ns1:ArchitectureLayer .

ns1:describesDomain a rdf:Property ;
    rdfs:label "describes domain" ;
    rdfs:comment "Links a knowledge artifact to the domain, topic, or conceptual area that it describes." ;
    rdfs:domain ns1:KnowledgeArtifact ;
    rdfs:range ns1:ConceptualTopic .

ns1:description a rdf:Property ;
    rdfs:label "description" ;
    rdfs:comment "A human-readable textual description of a resource." ;
    rdfs:domain ns1:Entity ;
    rdfs:range xsd:string .

ns1:detectsConstraintViolationAgainst a rdf:Property ;
    rdfs:label "detects constraint violation against" ;
    rdfs:comment "Links a reasoner or validation process to a constraint that it can test or detect violations against." ;
    rdfs:domain ns1:SoftwareSystem ;
    rdfs:range ns1:Constraint .

ns1:developedBy a rdf:Property ;
    rdfs:label "developed by" ;
    rdfs:comment "Links a software system or artifact to the person or organization that developed it." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:Agent .

ns1:developerMaintainerName a rdf:Property ;
    rdfs:label "developer or maintainer name" ;
    rdfs:comment "The raw developer or maintainer text value preserved from the source CSV." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:string .

ns1:dublin-core a ns1:Vocabulary ;
    rdfs:label "Dublin Core" ;
    ns1:description "A standard vocabulary for describing digital and physical resources." ;
    ns1:name "Dublin Core" .

ns1:enterprise-knowledge-graphs a ns1:KnowledgeGraph ;
    rdfs:label "Enterprise Knowledge Graphs" ;
    ns1:description "Internal knowledge graphs built by enterprises using RDF and OWL to integrate data from legacy systems without disruptive database migrations." ;
    ns1:implementsDataModel ns1:rdf ;
    ns1:name "Enterprise Knowledge Graphs" ;
    ns1:usesTechnology ns1:owl .

ns1:foaf a ns1:FoundationalOntology,
        ns1:Vocabulary ;
    rdfs:label "FOAF" ;
    ns1:description "A vocabulary used for describing people, their attributes, and their social networks." ;
    ns1:name "Friend of a Friend" .

ns1:followsPrinciple a rdf:Property ;
    rdfs:label "follows principle" ;
    rdfs:comment "Links a technology, artifact, or conceptual model to a guiding principle or assumption that it follows." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:Principle .

ns1:gene-ontology a ns1:Ontology ;
    rdfs:label "Gene Ontology" ;
    ns1:description "A large domain ontology standardizing the representation of gene and protein functions across biology." ;
    ns1:name "Gene Ontology" .

ns1:hasCapability a rdf:Property ;
    rdfs:label "has capability" ;
    rdfs:comment "Links a software system or artifact to a functional capability." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:Capability .

ns1:hasFeature a rdf:Property ;
    rdfs:label "has feature" ;
    rdfs:comment "Links a software system or artifact to a notable feature or specialization." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:Feature ;
    owl:inverseOf ns1:isFeatureOf .

ns1:hasLayer a rdf:Property ;
    rdfs:label "has layer" ;
    rdfs:comment "Links an architectural model or conceptual stack to one of its layers." ;
    rdfs:domain ns1:KnowledgeArtifact ;
    rdfs:range ns1:ArchitectureLayer ;
    owl:inverseOf ns1:isLayerOfArchitecture .

ns1:hasLicenseModel a rdf:Property ;
    rdfs:label "has license model" ;
    rdfs:comment "Links a software system to a normalized license model or licensing arrangement." ;
    rdfs:domain ns1:SoftwareSystem ;
    rdfs:range ns1:LicenseModel .

ns1:hasLogicalProfile a rdf:Property ;
    rdfs:label "has logical profile" ;
    rdfs:comment "Links an ontology language, ontology, or system to a logical profile that it uses or supports." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:LogicalProfile .

ns1:hasMaintainer a rdf:Property ;
    rdfs:label "has maintainer" ;
    rdfs:comment "Links a software system, especially a triplestore, to a maintaining organization." ;
    rdfs:domain ns1:SoftwareSystem ;
    rdfs:range ns1:Organization ;
    owl:inverseOf ns1:maintains .

ns1:hermit a ns1:Reasoner ;
    rdfs:label "HermiT" ;
    ns1:name "HermiT" ;
    ns1:performsInferenceTask ns1:classification-task,
        ns1:consistency-checking-task ;
    ns1:supportsReasoningCapability ns1:reasoner-capability .

ns1:homepage a rdf:Property ;
    rdfs:label "homepage" ;
    rdfs:comment "A homepage or web address for a resource, preserved as text when strict IRI validation is not guaranteed." ;
    rdfs:domain ns1:Entity ;
    rdfs:range xsd:string .

ns1:identifierValue a rdf:Property ;
    rdfs:label "identifier value" ;
    rdfs:comment "An external or internal identifier expressed as text." ;
    rdfs:domain ns1:Entity ;
    rdfs:range xsd:string .

ns1:implementsDataModel a rdf:Property ;
    rdfs:label "implements data model" ;
    rdfs:comment "Links a software system or technology artifact to a data model that it implements or supports." ;
    rdfs:domain ns1:TechnologyArtifact ;
    rdfs:range ns1:DataModel .

ns1:implementsStandard a rdf:Property ;
    rdfs:label "implements standard" ;
    rdfs:comment "Links a technology artifact or software system to a formal standard that it implements." ;
    rdfs:domain ns1:TechnologyArtifact ;
    rdfs:range ns1:Standard .

ns1:keyFeaturesText a rdf:Property ;
    rdfs:label "key features text" ;
    rdfs:comment "The raw key features or specializations text preserved from the source CSV." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:string .

ns1:knowledge-graph-concept a ns1:KnowledgeGraph ;
    rdfs:label "Knowledge Graph" ;
    ns1:describesDomain ns1:web-of-data ;
    ns1:description "A network of real-world entities connected by relationships that represents actual data instance networks." ;
    ns1:name "Knowledge Graph" .

ns1:licenseTypeText a rdf:Property ;
    rdfs:label "license type text" ;
    rdfs:comment "The raw license type text preserved from the source CSV." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:string .

ns1:linked-open-data a ns1:Community ;
    rdfs:label "Linked Open Data" ;
    ns1:description "A global movement to publish structured data so that it can be interlinked." ;
    ns1:name "Linked Open Data" .

ns1:maintainedBy a rdf:Property ;
    rdfs:label "maintained by" ;
    rdfs:comment "Links a software system or artifact to the organization that maintains it." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:Organization .

ns1:name a rdf:Property ;
    rdfs:label "name" ;
    rdfs:comment "A human-readable primary name for a resource." ;
    rdfs:domain ns1:Entity ;
    rdfs:range xsd:string .

ns1:ontology a owl:Ontology ;
    rdfs:label "Semantic Web project ontology" ;
    rdfs:comment "An RDF/RDFS-oriented ontology for Semantic Web concepts, ontology engineering concepts, and a catalog of commonly seen triplestores derived from the supplied project materials." .

ns1:ontology-concept a ns1:Ontology ;
    rdfs:label "Ontology" ;
    ns1:definesConcept ns1:attributes-concept,
        ns1:axioms-concept,
        ns1:classes-concept,
        ns1:constraints-topic,
        ns1:individuals-concept,
        ns1:relationships-concept ;
    ns1:describesDomain ns1:ontology-components-topic ;
    ns1:description "A formal, explicit specification of a shared conceptualization." ;
    ns1:developedBy ns1:thomas-r-gruber ;
    ns1:name "Ontology" .

ns1:openllet a ns1:Reasoner ;
    rdfs:label "Openllet" ;
    ns1:name "Openllet" ;
    ns1:performsInferenceTask ns1:classification-task,
        ns1:consistency-checking-task ;
    ns1:supportsReasoningCapability ns1:reasoner-capability .

ns1:organizesAsSubclassOf a rdf:Property ;
    rdfs:label "organizes as subclass of" ;
    rdfs:comment "Relates a class concept in a taxonomy or ontology to a broader class concept." ;
    rdfs:domain ns1:ClassConcept ;
    rdfs:range ns1:ClassConcept .

ns1:pellet a ns1:Reasoner ;
    rdfs:label "Pellet" ;
    ns1:name "Pellet" ;
    ns1:performsInferenceTask ns1:classification-task,
        ns1:consistency-checking-task ;
    ns1:supportsReasoningCapability ns1:reasoner-capability .

ns1:performsInferenceTask a rdf:Property ;
    rdfs:label "performs inference task" ;
    rdfs:comment "Links a reasoner or inference-capable system to a reasoning task it performs." ;
    rdfs:domain ns1:SoftwareSystem ;
    rdfs:range ns1:InferenceTask .

ns1:precedesLayer a rdf:Property ;
    rdfs:label "precedes layer" ;
    rdfs:comment "Relates a lower or earlier layer to a higher or later layer in the architecture stack." ;
    rdfs:domain ns1:ArchitectureLayer ;
    rdfs:range ns1:ArchitectureLayer .

ns1:primaryAPIInterfacesText a rdf:Property ;
    rdfs:label "primary API interfaces text" ;
    rdfs:comment "The raw primary API and interface text preserved from the source CSV." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:string .

ns1:providesManagedService a rdf:Property ;
    rdfs:label "provides managed service" ;
    rdfs:comment "Links an organization to a managed semantic or graph data service that it provides." ;
    rdfs:domain ns1:Organization ;
    rdfs:range ns1:ManagedService .

ns1:publishedBy a rdf:Property ;
    rdfs:label "published by" ;
    rdfs:comment "Links an artifact, specification, or dataset to the organization that published it." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:Organization .

ns1:schema-org a ns1:Vocabulary ;
    rdfs:label "Schema.org" ;
    ns1:description "A collaborative initiative whose vocabularies are embedded into HTML using JSON-LD or Microdata to structure data for search engine knowledge graphs." ;
    ns1:name "Schema.org" .

ns1:semantic-web a ns1:KnowledgeGraph ;
    rdfs:label "Semantic Web" ;
    ns1:description "An evolutionary extension of the World Wide Web that seeks to transform the web into a universal medium for data, information, and knowledge exchange by embedding explicit, machine-understandable semantics into web resources." ;
    ns1:developedBy ns1:tim-berners-lee ;
    ns1:followsPrinciple ns1:non-unique-name-assumption,
        ns1:open-world-assumption ;
    ns1:name "Semantic Web" ;
    ns1:publishedBy ns1:w3c .

ns1:supportsInterface a rdf:Property ;
    rdfs:label "supports interface" ;
    rdfs:comment "Links a software system to an API, interface, protocol, or workbench that it supports or exposes." ;
    rdfs:domain ns1:SoftwareSystem ;
    rdfs:range ns1:APIInterface .

ns1:supportsQueryLanguage a rdf:Property ;
    rdfs:label "supports query language" ;
    rdfs:comment "Links a software system or interface to a query language that it supports." ;
    rdfs:domain ns1:TechnologyArtifact ;
    rdfs:range ns1:QueryLanguage .

ns1:supportsReasoningCapability a rdf:Property ;
    rdfs:label "supports reasoning capability" ;
    rdfs:comment "Links a software system, ontology, or language to a reasoning capability that it supports." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:ReasoningCapability .

ns1:taxonomy-concept a ns1:Taxonomy ;
    rdfs:label "Taxonomy" ;
    ns1:describesDomain ns1:ontology-components-topic ;
    ns1:description "A narrow hierarchical classification scheme that understands tree-like parental structures and contains no advanced properties or logic." ;
    ns1:name "Taxonomy" .

ns1:usesIdentifierScheme a rdf:Property ;
    rdfs:label "uses identifier scheme" ;
    rdfs:comment "Links a resource to an identifier scheme such as URI or IRI." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:IdentifierScheme .

ns1:usesSerializationFormat a rdf:Property ;
    rdfs:label "uses serialization format" ;
    rdfs:comment "Links a dataset, software system, or artifact to a serialization format used to exchange or store data." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:SerializationFormat .

ns1:usesTechnology a rdf:Property ;
    rdfs:label "uses technology" ;
    rdfs:comment "Links a layer, artifact, or system to a technology artifact that it uses." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:TechnologyArtifact .

ns1:web-of-documents a ns1:ConceptualTopic ;
    rdfs:label "Web of Documents" ;
    ns1:description "The traditional World Wide Web architecture of unstructured and semi-structured documents designed for human consumption." ;
    ns1:name "Web of Documents" .

ns1:wikidata a ns1:Dataset,
        ns1:KnowledgeGraph ;
    rdfs:label "Wikidata" ;
    ns1:description "A central hub connecting many open datasets in the Linked Open Data ecosystem." ;
    ns1:name "Wikidata" ;
    ns1:usesIdentifierScheme ns1:iri .

