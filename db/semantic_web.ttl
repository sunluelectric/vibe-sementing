@prefix ns1: <http://example.org/semantic-web#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:API a rdfs:Class,
        owl:Class ;
    rdfs:label "API" ;
    rdfs:comment "An application programming interface." ;
    rdfs:subClassOf ns1:InterfaceTechnology .

ns1:ApplicationArea a rdfs:Class,
        owl:Class ;
    rdfs:label "Application area" ;
    rdfs:comment "A practical area where semantic web technologies are applied." ;
    rdfs:subClassOf ns1:Concept .

ns1:AttributeConcept a rdfs:Class,
        owl:Class ;
    rdfs:label "Attribute concept" ;
    rdfs:comment "A concept corresponding to datatype attributes." ;
    rdfs:subClassOf ns1:ModelingConstruct .

ns1:AxiomComponent a rdfs:Class,
        owl:Class ;
    rdfs:label "Axiom component" ;
    rdfs:comment "An axiom or constraint component in an ontology." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:AxiomConcept a rdfs:Class,
        owl:Class ;
    rdfs:label "Axiom concept" ;
    rdfs:comment "A concept corresponding to logical axioms or constraints." ;
    rdfs:subClassOf ns1:ModelingConstruct .

ns1:CharacterEncoding a rdfs:Class,
        owl:Class ;
    rdfs:label "Character encoding" ;
    rdfs:comment "A character encoding technology such as Unicode." ;
    rdfs:subClassOf ns1:Technology .

ns1:ClassConcept a rdfs:Class,
        owl:Class ;
    rdfs:label "Class concept" ;
    rdfs:comment "A concept corresponding to classes as ontology primitives." ;
    rdfs:subClassOf ns1:ModelingConstruct .

ns1:ClassificationReasoning a rdfs:Class,
        owl:Class ;
    rdfs:label "Classification reasoning" ;
    rdfs:comment "Reasoning process that computes inferred class hierarchies or memberships." ;
    rdfs:subClassOf ns1:ReasoningProcess .

ns1:ClosedWorldAssumption a rdfs:Class,
        owl:Class ;
    rdfs:label "Closed World Assumption" ;
    rdfs:comment "Assumption that absent information is treated as false." ;
    rdfs:subClassOf ns1:Principle .

ns1:Concept a rdfs:Class,
        owl:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "An abstract conceptual unit in the modeled domain." ;
    rdfs:subClassOf ns1:Entity .

ns1:ConsistencyChecking a rdfs:Class,
        owl:Class ;
    rdfs:label "Consistency checking" ;
    rdfs:comment "Reasoning process that detects logical contradictions." ;
    rdfs:subClassOf ns1:ReasoningProcess .

ns1:DataIntegrationUseCase a rdfs:Class,
        owl:Class ;
    rdfs:label "Data integration use case" ;
    rdfs:comment "Application area focused on integrating heterogeneous data sources." ;
    rdfs:subClassOf ns1:ApplicationArea .

ns1:DataModelLayer a rdfs:Class,
        owl:Class ;
    rdfs:label "Data model layer" ;
    rdfs:comment "Layer concerning RDF and RDFS data modeling." ;
    rdfs:subClassOf ns1:SemanticArchitectureLayer .

ns1:DataStoreTechnology a rdfs:Class,
        owl:Class ;
    rdfs:label "Data store technology" ;
    rdfs:comment "A technology used to persist, query, or manage structured data." ;
    rdfs:subClassOf ns1:Technology .

ns1:DataVirtualizationUseCase a rdfs:Class,
        owl:Class ;
    rdfs:label "Data virtualization use case" ;
    rdfs:comment "Application area focused on virtualized access across distributed or heterogeneous data stores." ;
    rdfs:subClassOf ns1:ApplicationArea .

ns1:Dataset a rdfs:Class,
        owl:Class ;
    rdfs:label "Dataset" ;
    rdfs:comment "A structured collection of data." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:DatatypePropertyComponent a rdfs:Class,
        owl:Class ;
    rdfs:label "Datatype property component" ;
    rdfs:comment "A datatype property component in an ontology." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:DeveloperOrganization a rdfs:Class,
        owl:Class ;
    rdfs:label "Developer organization" ;
    rdfs:comment "An organization responsible for development of a technology or artifact." ;
    rdfs:subClassOf ns1:Organization .

ns1:DistributedAnalyticsFeature a rdfs:Class,
        owl:Class ;
    rdfs:label "Distributed analytics feature" ;
    rdfs:comment "A feature supporting distributed or massively parallel analytics." ;
    rdfs:subClassOf ns1:Feature .

ns1:Document a rdfs:Class,
        owl:Class ;
    rdfs:label "Document" ;
    rdfs:comment "A textual or digital document." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:EnterpriseKnowledgeGraph a rdfs:Class,
        owl:Class ;
    rdfs:label "Enterprise Knowledge Graph" ;
    rdfs:comment "Application area for internal enterprise knowledge graph systems." ;
    rdfs:subClassOf ns1:ApplicationArea .

ns1:Entity a rdfs:Class,
        owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "Top-level class for described things in this ontology." .

ns1:Feature a rdfs:Class,
        owl:Class ;
    rdfs:label "Feature" ;
    rdfs:comment "A capability, property, or specialization of a technology or platform." ;
    rdfs:subClassOf ns1:Concept .

ns1:FoundationalOntology a rdfs:Class,
        owl:Class ;
    rdfs:label "Foundational ontology" ;
    rdfs:comment "An upper-level or reusable ontology intended to support broad interoperability." ;
    rdfs:subClassOf ns1:Ontology .

ns1:GraphDataSystem a rdfs:Class,
        owl:Class ;
    rdfs:label "Graph data system" ;
    rdfs:comment "A data management system centered on graph structures." ;
    rdfs:subClassOf ns1:DataStoreTechnology .

ns1:GraphDatabase a rdfs:Class,
        owl:Class ;
    rdfs:label "Graph database" ;
    rdfs:comment "A graph-oriented database technology." ;
    rdfs:subClassOf ns1:GraphDataSystem .

ns1:HighPerformanceFeature a rdfs:Class,
        owl:Class ;
    rdfs:label "High-performance feature" ;
    rdfs:comment "A feature focused on high-performance graph or query execution." ;
    rdfs:subClassOf ns1:Feature .

ns1:IRI a rdfs:Class,
        owl:Class ;
    rdfs:label "IRI" ;
    rdfs:comment "Internationalized Resource Identifier." ;
    rdfs:subClassOf ns1:Identifier .

ns1:Identifier a rdfs:Class,
        owl:Class ;
    rdfs:label "Identifier" ;
    rdfs:comment "A construct or value used to identify a resource." ;
    rdfs:subClassOf ns1:Concept .

ns1:IdentifierLayer a rdfs:Class,
        owl:Class ;
    rdfs:label "Identifier layer" ;
    rdfs:comment "Layer concerning URI, IRI, and character-set foundations." ;
    rdfs:subClassOf ns1:SemanticArchitectureLayer .

ns1:IndividualConcept a rdfs:Class,
        owl:Class ;
    rdfs:label "Individual concept" ;
    rdfs:comment "A concept corresponding to individuals or instances as ontology primitives." ;
    rdfs:subClassOf ns1:ModelingConstruct .

ns1:InterfaceTechnology a rdfs:Class,
        owl:Class ;
    rdfs:label "Interface technology" ;
    rdfs:comment "An API, interface, protocol, endpoint, or access mechanism." ;
    rdfs:subClassOf ns1:Technology .

ns1:JSONLDFormat a rdfs:Class,
        owl:Class ;
    rdfs:label "JSON-LD format" ;
    rdfs:comment "JSON for Linking Data serialization format." ;
    rdfs:subClassOf ns1:SerializationFormat .

ns1:KnowledgeArtifact a rdfs:Class,
        owl:Class ;
    rdfs:label "Knowledge artifact" ;
    rdfs:comment "A human- or machine-oriented artifact representing knowledge, such as a document, ontology, taxonomy, standard, or dataset." ;
    rdfs:subClassOf ns1:Entity .

ns1:KnowledgeGraph a rdfs:Class,
        owl:Class ;
    rdfs:label "Knowledge graph" ;
    rdfs:comment "A graph of entities and relationships representing structured knowledge." ;
    rdfs:subClassOf ns1:Dataset .

ns1:KnowledgeGraphPlatform a rdfs:Class,
        owl:Class ;
    rdfs:label "Knowledge graph platform" ;
    rdfs:comment "A platform supporting the creation, management, or use of knowledge graphs." ;
    rdfs:subClassOf ns1:Technology .

ns1:KnowledgeRepresentationLanguage a rdfs:Class,
        owl:Class ;
    rdfs:label "Knowledge representation language" ;
    rdfs:comment "A language for expressing structured semantics or knowledge models." ;
    rdfs:subClassOf ns1:LanguageTechnology .

ns1:LanguageTechnology a rdfs:Class,
        owl:Class ;
    rdfs:label "Language technology" ;
    rdfs:comment "A formal language used for representation, querying, or exchange." ;
    rdfs:subClassOf ns1:Technology .

ns1:LicenseOffering a rdfs:Class,
        owl:Class ;
    rdfs:label "License offering" ;
    rdfs:comment "A license arrangement or licensing description associated with a product or technology." ;
    rdfs:subClassOf ns1:Entity .

ns1:LinkedOpenData a rdfs:Class,
        owl:Class ;
    rdfs:label "Linked Open Data" ;
    rdfs:comment "Application area concerning open, interlinked structured datasets." ;
    rdfs:subClassOf ns1:ApplicationArea .

ns1:LogicProfile a rdfs:Class,
        owl:Class ;
    rdfs:label "Logic profile" ;
    rdfs:comment "A computational profile of an ontology language." ;
    rdfs:subClassOf ns1:Concept .

ns1:MaintainerOrganization a rdfs:Class,
        owl:Class ;
    rdfs:label "Maintainer organization" ;
    rdfs:comment "An organization responsible for maintenance of a technology or artifact." ;
    rdfs:subClassOf ns1:Organization .

ns1:ManagedServiceFeature a rdfs:Class,
        owl:Class ;
    rdfs:label "Managed service feature" ;
    rdfs:comment "A feature indicating managed-service operation or delivery." ;
    rdfs:subClassOf ns1:Feature .

ns1:MicrodataTechnology a rdfs:Class,
        owl:Class ;
    rdfs:label "Microdata technology" ;
    rdfs:comment "Markup technology for embedding structured data in HTML." ;
    rdfs:subClassOf ns1:Technology .

ns1:ModelingConstruct a rdfs:Class,
        owl:Class ;
    rdfs:label "Modeling construct" ;
    rdfs:comment "A conceptual construct used in semantic modeling." ;
    rdfs:subClassOf ns1:Concept .

ns1:MultiModelFeature a rdfs:Class,
        owl:Class ;
    rdfs:label "Multi-model feature" ;
    rdfs:comment "A feature supporting multiple data models or paradigms." ;
    rdfs:subClassOf ns1:Feature .

ns1:NonUniqueNameAssumption a rdfs:Class,
        owl:Class ;
    rdfs:label "Non-Unique Name Assumption" ;
    rdfs:comment "Assumption that different identifiers may denote the same real-world entity." ;
    rdfs:subClassOf ns1:Principle .

ns1:OWL2ELProfile a rdfs:Class,
        owl:Class ;
    rdfs:label "OWL 2 EL profile" ;
    rdfs:comment "OWL 2 EL profile for large class hierarchies with tractable reasoning." ;
    rdfs:subClassOf ns1:LogicProfile .

ns1:OWL2QLProfile a rdfs:Class,
        owl:Class ;
    rdfs:label "OWL 2 QL profile" ;
    rdfs:comment "OWL 2 QL profile optimized for query answering over relational systems." ;
    rdfs:subClassOf ns1:LogicProfile .

ns1:OWL2RLProfile a rdfs:Class,
        owl:Class ;
    rdfs:label "OWL 2 RL profile" ;
    rdfs:comment "OWL 2 RL profile optimized for rule-based reasoning." ;
    rdfs:subClassOf ns1:LogicProfile .

ns1:OWLTechnology a rdfs:Class,
        owl:Class ;
    rdfs:label "OWL technology" ;
    rdfs:comment "Technology or standard based on the Web Ontology Language." ;
    rdfs:subClassOf ns1:KnowledgeRepresentationLanguage,
        ns1:Standard .

ns1:ObjectPropertyComponent a rdfs:Class,
        owl:Class ;
    rdfs:label "Object property component" ;
    rdfs:comment "An object property component in an ontology." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:Ontology a rdfs:Class,
        owl:Class ;
    rdfs:label "Ontology" ;
    rdfs:comment "A formal, explicit specification of a shared conceptualization." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:OntologyClassComponent a rdfs:Class,
        owl:Class ;
    rdfs:label "Ontology class component" ;
    rdfs:comment "A class component in an ontology." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:OntologyComponent a rdfs:Class,
        owl:Class ;
    rdfs:label "Ontology component" ;
    rdfs:comment "A component used in the structure of an ontology." ;
    rdfs:subClassOf ns1:Concept .

ns1:OntologyIndividualComponent a rdfs:Class,
        owl:Class ;
    rdfs:label "Ontology individual component" ;
    rdfs:comment "An individual or instance component in an ontology." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:OntologyLayer a rdfs:Class,
        owl:Class ;
    rdfs:label "Ontology layer" ;
    rdfs:comment "Layer concerning ontologies such as OWL and SKOS." ;
    rdfs:subClassOf ns1:SemanticArchitectureLayer .

ns1:OpenWorldAssumption a rdfs:Class,
        owl:Class ;
    rdfs:label "Open World Assumption" ;
    rdfs:comment "Assumption that missing information is unknown rather than false." ;
    rdfs:subClassOf ns1:Principle .

ns1:Organization a rdfs:Class,
        owl:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "An organization such as a vendor, standards body, maintainer, or developer." ;
    rdfs:subClassOf ns1:Entity .

ns1:Principle a rdfs:Class,
        owl:Class ;
    rdfs:label "Principle" ;
    rdfs:comment "A conceptual principle or assumption relevant to semantic systems." ;
    rdfs:subClassOf ns1:Concept .

ns1:ProgrammingInterface a rdfs:Class,
        owl:Class ;
    rdfs:label "Programming interface" ;
    rdfs:comment "A programming-oriented interface such as a language SDK or native API." ;
    rdfs:subClassOf ns1:InterfaceTechnology .

ns1:ProofLayer a rdfs:Class,
        owl:Class ;
    rdfs:label "Proof layer" ;
    rdfs:comment "Layer concerning proof and explainability of inferences." ;
    rdfs:subClassOf ns1:SemanticArchitectureLayer .

ns1:Protocol a rdfs:Class,
        owl:Class ;
    rdfs:label "Protocol" ;
    rdfs:comment "A communication or interoperability protocol." ;
    rdfs:subClassOf ns1:InterfaceTechnology .

ns1:QueryEndpoint a rdfs:Class,
        owl:Class ;
    rdfs:label "Query endpoint" ;
    rdfs:comment "An endpoint used for query execution over a semantic or graph store." ;
    rdfs:subClassOf ns1:InterfaceTechnology .

ns1:QueryLanguage a rdfs:Class,
        owl:Class ;
    rdfs:label "Query language" ;
    rdfs:comment "A language used to query structured data or RDF graphs." ;
    rdfs:subClassOf ns1:LanguageTechnology .

ns1:QueryLayer a rdfs:Class,
        owl:Class ;
    rdfs:label "Query layer" ;
    rdfs:comment "Layer concerning graph query languages such as SPARQL." ;
    rdfs:subClassOf ns1:SemanticArchitectureLayer .

ns1:RDFSchemaTechnology a rdfs:Class,
        owl:Class ;
    rdfs:label "RDFS technology" ;
    rdfs:comment "Technology or standard based on RDF Schema." ;
    rdfs:subClassOf ns1:RDFTechnology .

ns1:RDFTechnology a rdfs:Class,
        owl:Class ;
    rdfs:label "RDF technology" ;
    rdfs:comment "Technology or standard based on the Resource Description Framework." ;
    rdfs:subClassOf ns1:KnowledgeRepresentationLanguage,
        ns1:Standard .

ns1:RDFXMLFormat a rdfs:Class,
        owl:Class ;
    rdfs:label "RDF/XML format" ;
    rdfs:comment "XML serialization format for RDF." ;
    rdfs:subClassOf ns1:SerializationFormat .

ns1:Reasoner a rdfs:Class,
        owl:Class ;
    rdfs:label "Reasoner" ;
    rdfs:comment "A software component that performs logical inference or consistency checking." ;
    rdfs:subClassOf ns1:Technology .

ns1:ReasoningFeature a rdfs:Class,
        owl:Class ;
    rdfs:label "Reasoning feature" ;
    rdfs:comment "A feature related to reasoning support." ;
    rdfs:subClassOf ns1:Feature .

ns1:ReasoningProcess a rdfs:Class,
        owl:Class ;
    rdfs:label "Reasoning process" ;
    rdfs:comment "A semantic reasoning activity performed over knowledge representations." ;
    rdfs:subClassOf ns1:Concept .

ns1:RelationshipConcept a rdfs:Class,
        owl:Class ;
    rdfs:label "Relationship concept" ;
    rdfs:comment "A concept corresponding to object relationships." ;
    rdfs:subClassOf ns1:ModelingConstruct .

ns1:RestrictionComponent a rdfs:Class,
        owl:Class ;
    rdfs:label "Restriction component" ;
    rdfs:comment "A restriction component used to constrain class membership or property use." ;
    rdfs:subClassOf ns1:OntologyComponent .

ns1:RulesLayer a rdfs:Class,
        owl:Class ;
    rdfs:label "Rules layer" ;
    rdfs:comment "Layer concerning semantic rules and rule languages." ;
    rdfs:subClassOf ns1:SemanticArchitectureLayer .

ns1:SKOSTechnology a rdfs:Class,
        owl:Class ;
    rdfs:label "SKOS technology" ;
    rdfs:comment "Technology or standard based on SKOS." ;
    rdfs:subClassOf ns1:KnowledgeRepresentationLanguage,
        ns1:Standard .

ns1:SPARQLTechnology a rdfs:Class,
        owl:Class ;
    rdfs:label "SPARQL technology" ;
    rdfs:comment "Technology or standard based on SPARQL." ;
    rdfs:subClassOf ns1:QueryLanguage,
        ns1:Standard .

ns1:SearchEngineKnowledgeGraph a rdfs:Class,
        owl:Class ;
    rdfs:label "Search engine knowledge graph" ;
    rdfs:comment "Application area concerning knowledge graphs used by search engines." ;
    rdfs:subClassOf ns1:ApplicationArea .

ns1:SemanticArchitectureLayer a rdfs:Class,
        owl:Class ;
    rdfs:label "Semantic architecture layer" ;
    rdfs:comment "A layer in the Semantic Web technology stack." ;
    rdfs:subClassOf ns1:Concept .

ns1:SemanticWeb a rdfs:Class,
        owl:Class ;
    rdfs:label "Semantic Web" ;
    rdfs:comment "The web of machine-understandable data and explicit semantics." ;
    rdfs:subClassOf ns1:Concept .

ns1:SerializationFormat a rdfs:Class,
        owl:Class ;
    rdfs:label "Serialization format" ;
    rdfs:comment "A syntax used to serialize RDF or semantic data." ;
    rdfs:subClassOf ns1:Technology .

ns1:SpecificationDocument a rdfs:Class,
        owl:Class ;
    rdfs:label "Specification document" ;
    rdfs:comment "A document that specifies a formal language, model, or standard." ;
    rdfs:subClassOf ns1:Document .

ns1:Standard a rdfs:Class,
        owl:Class ;
    rdfs:label "Standard" ;
    rdfs:comment "A formal or community standard." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:SyntaxLayer a rdfs:Class,
        owl:Class ;
    rdfs:label "Syntax layer" ;
    rdfs:comment "Layer concerning data syntax and serialization." ;
    rdfs:subClassOf ns1:SemanticArchitectureLayer .

ns1:Taxonomy a rdfs:Class,
        owl:Class ;
    rdfs:label "Taxonomy" ;
    rdfs:comment "A hierarchical classification scheme." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:Technology a rdfs:Class,
        owl:Class ;
    rdfs:label "Technology" ;
    rdfs:comment "A technical standard, language, system, or platform." ;
    rdfs:subClassOf ns1:Entity .

ns1:Triplestore a rdfs:Class,
        owl:Class ;
    rdfs:label "Triplestore" ;
    rdfs:comment "A database management system specialized for RDF triples." ;
    rdfs:subClassOf ns1:GraphDataSystem .

ns1:TrustLayer a rdfs:Class,
        owl:Class ;
    rdfs:label "Trust layer" ;
    rdfs:comment "Layer concerning trust, provenance, and reliability." ;
    rdfs:subClassOf ns1:SemanticArchitectureLayer .

ns1:TurtleFormat a rdfs:Class,
        owl:Class ;
    rdfs:label "Turtle format" ;
    rdfs:comment "Terse RDF Triple Language serialization format." ;
    rdfs:subClassOf ns1:SerializationFormat .

ns1:URI a rdfs:Class,
        owl:Class ;
    rdfs:label "URI" ;
    rdfs:comment "Uniform Resource Identifier." ;
    rdfs:subClassOf ns1:Identifier .

ns1:VirtualizationFeature a rdfs:Class,
        owl:Class ;
    rdfs:label "Virtualization feature" ;
    rdfs:comment "A feature related to data virtualization or virtual graphs." ;
    rdfs:subClassOf ns1:Feature .

ns1:Vocabulary a rdfs:Class,
        owl:Class ;
    rdfs:label "Vocabulary" ;
    rdfs:comment "A semantic vocabulary used to describe data or concepts." ;
    rdfs:subClassOf ns1:KnowledgeArtifact .

ns1:WebOfData a rdfs:Class,
        owl:Class ;
    rdfs:label "Web of Data" ;
    rdfs:comment "The data-centric web based on typed relationships and explicit semantics." ;
    rdfs:subClassOf ns1:Concept .

ns1:WebOfDocuments a rdfs:Class,
        owl:Class ;
    rdfs:label "Web of Documents" ;
    rdfs:comment "The traditional document-centric web." ;
    rdfs:subClassOf ns1:Concept .

ns1:WebResource a rdfs:Class,
        owl:Class ;
    rdfs:label "Web resource" ;
    rdfs:comment "A resource identifiable on the web." ;
    rdfs:subClassOf ns1:Entity .

ns1:Workbench a rdfs:Class,
        owl:Class ;
    rdfs:label "Workbench" ;
    rdfs:comment "A user-facing workbench or administration interface." ;
    rdfs:subClassOf ns1:InterfaceTechnology .

ns1: a owl:Ontology ;
    rdfs:label "Semantic Web and Triplestore Ontology" ;
    rdfs:comment "An RDF/RDFS-first ontology for Semantic Web concepts, ontology concepts, architecture layers, reasoning, standards, and triplestore catalog metadata derived from the supplied project documents and CSV." .

ns1:broaderThan a rdf:Property,
        owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "broader than" ;
    rdfs:comment "Relates a concept to another concept that is conceptually narrower than it." ;
    rdfs:domain ns1:Concept ;
    rdfs:range ns1:Concept ;
    owl:inverseOf ns1:narrowerThan .

ns1:description a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:comment "General textual description of an entity." ;
    rdfs:domain ns1:Entity ;
    rdfs:range xsd:string .

ns1:hasComponent a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "has component" ;
    rdfs:comment "Relates a composite knowledge artifact to a component entity." ;
    rdfs:domain ns1:KnowledgeArtifact ;
    rdfs:range ns1:Entity .

ns1:hasLayer a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "has layer" ;
    rdfs:comment "Relates the Semantic Web architecture to one of its layers." ;
    rdfs:domain ns1:SemanticWeb ;
    rdfs:range ns1:SemanticArchitectureLayer .

ns1:homepage a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "homepage" ;
    rdfs:comment "Homepage URI of an entity." ;
    rdfs:domain ns1:Entity ;
    rdfs:range xsd:anyURI .

ns1:identifierValue a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "identifier value" ;
    rdfs:comment "Literal content of an identifier." ;
    rdfs:domain ns1:Identifier ;
    rdfs:range xsd:string .

ns1:name a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "General name of an entity." ;
    rdfs:domain ns1:Entity ;
    rdfs:range xsd:string .

ns1:officialName a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "official name" ;
    rdfs:comment "Official name of an entity or organization." ;
    rdfs:domain ns1:Entity ;
    rdfs:range xsd:string .

ns1:partOf a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "part of" ;
    rdfs:comment "Relates an entity to a larger entity of which it is part." ;
    rdfs:domain ns1:Entity ;
    rdfs:range ns1:Entity .

ns1:supportsLayer a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "supports layer" ;
    rdfs:comment "Relates a technology to a Semantic Web architecture layer it supports." ;
    rdfs:domain ns1:Technology ;
    rdfs:range ns1:SemanticArchitectureLayer .

ns1:title a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:comment "Title of a knowledge artifact." ;
    rdfs:domain ns1:KnowledgeArtifact ;
    rdfs:range xsd:string .

<http://example.org/semantic-web/instance/bfo> a ns1:FoundationalOntology ;
    rdfs:label "BFO" ;
    ns1:description "A domain-neutral upper-level ontology used as a structural foundation for interoperability across sub-ontologies." ;
    ns1:name "Basic Formal Ontology" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/bing> a ns1:Organization ;
    rdfs:label "Bing" ;
    ns1:name "Bing" ;
    ns1:officialName "Bing" .

<http://example.org/semantic-web/instance/classification-reasoning> a ns1:ClassificationReasoning ;
    rdfs:label "Classification" ;
    ns1:description "A reasoning process that computes logical implications of class definitions and derives correct hierarchy placement." ;
    ns1:name "Classification" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/closed-world-assumption> a ns1:ClosedWorldAssumption ;
    rdfs:label "Closed World Assumption" ;
    ns1:description "The principle that information not present is generally treated as false in traditional database settings." ;
    ns1:name "Closed World Assumption" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/consistency-checking> a ns1:ConsistencyChecking ;
