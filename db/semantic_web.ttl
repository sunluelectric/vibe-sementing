    ns1:name "Web of Documents" .

<http://example.org/semantic-web/instance/data-model-layer> a ns1:DataModelLayer ;
    rdfs:label "Data Model layer" ;
    ns1:description "Layer covering RDF and RDF Schema as the foundational graph data model and schema vocabulary." ;
