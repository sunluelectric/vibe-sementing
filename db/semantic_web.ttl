@prefix ns1: <http://example.org/semantic-web#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:BinomialDistribution a rdfs:Class ;
    rdfs:label "BinomialDistribution" ;
    rdfs:comment "Binomial distribution family with parameters n and p." ;
    rdfs:subClassOf ns1:DiscreteDistribution .

ns1:Condition a rdfs:Class ;
    rdfs:label "Condition" ;
    rdfs:comment "An assumption or condition for a theorem (e.g., iid, finite variance)." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:ConfidenceInterval a rdfs:Class ;
    rdfs:label "ConfidenceInterval" ;
    rdfs:comment "A confidence interval with a confidence level and bounds." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:ContinuousDistribution a rdfs:Class ;
    rdfs:label "ContinuousDistribution" ;
    rdfs:comment "Continuous distribution family (has PDF)." ;
    rdfs:subClassOf ns1:Distribution .

ns1:DiscreteDistribution a rdfs:Class ;
    rdfs:label "DiscreteDistribution" ;
    rdfs:comment "Discrete distribution family (has PMF)." ;
    rdfs:subClassOf ns1:Distribution .

ns1:Distribution a rdfs:Class ;
    rdfs:label "Distribution" ;
    rdfs:comment "A probability distribution family (e.g., Normal, Poisson)." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:Document a rdfs:Class ;
    rdfs:label "Document" ;
    rdfs:comment "A document, notebook page, or PDF from which content is sourced." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:Estimator a rdfs:Class ;
    rdfs:label "Estimator" ;
    rdfs:comment "An estimation method (MLE, Bayesian estimator, etc.)." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:ExponentialDistribution a rdfs:Class ;
    rdfs:label "ExponentialDistribution" ;
    rdfs:comment "Exponential distribution family (continuous), often parametrized by rate λ." ;
    rdfs:subClassOf ns1:ContinuousDistribution .

ns1:GammaDistribution a rdfs:Class ;
    rdfs:label "GammaDistribution" ;
    rdfs:comment "Gamma distribution family (continuous)." ;
    rdfs:subClassOf ns1:ContinuousDistribution .

ns1:HypothesisTest a rdfs:Class ;
    rdfs:label "HypothesisTest" ;
    rdfs:comment "A hypothesis test instance linking test statistic, p-value and alpha." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:MathematicalEntity a rdfs:Class ;
    rdfs:label "MathematicalEntity" ;
    rdfs:comment "Root class for concepts introduced in the notebook (distributions, theorems, tools, etc.)." .

ns1:MathematicalExpression a rdfs:Class ;
    rdfs:label "MathematicalExpression" ;
    rdfs:comment "A node holding a formula or code snippet (LaTeX, MathML, R/Python code)." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:NormalDistribution a rdfs:Class ;
    rdfs:label "NormalDistribution" ;
    rdfs:comment "Normal (Gaussian) distribution family; parameters typically µ and σ²." ;
    rdfs:subClassOf ns1:ContinuousDistribution .

ns1:Parameter a rdfs:Class ;
    rdfs:label "Parameter" ;
    rdfs:comment "A model or distribution parameter (symbol and optional numeric value)." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:PoissonDistribution a rdfs:Class ;
    rdfs:label "PoissonDistribution" ;
    rdfs:comment "Poisson distribution family with rate parameter λ." ;
    rdfs:subClassOf ns1:DiscreteDistribution .

ns1:RandomVariable a rdfs:Class ;
    rdfs:label "RandomVariable" ;
    rdfs:comment "A random variable; linked to a distribution via sw:hasDistribution." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:SemanticWebConcept a rdfs:Class ;
    rdfs:label "SemanticWebConcept" ;
    rdfs:comment "Concepts related to the semantic web discussed in the notebook (RDF, RDFS, OWL, ALC)." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:Statistic a rdfs:Class ;
    rdfs:label "Statistic" ;
    rdfs:comment "A computed statistic (sample mean, variance, test statistic)." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:StudentTDistribution a rdfs:Class ;
    rdfs:label "StudentTDistribution" ;
    rdfs:comment "Student's t distribution family (continuous), used in small-sample inference." ;
    rdfs:subClassOf ns1:ContinuousDistribution .

ns1:Theorem a rdfs:Class ;
    rdfs:label "Theorem" ;
    rdfs:comment "A named mathematical or statistical theorem (e.g., CLT, LLN)." ;
    rdfs:subClassOf ns1:MathematicalEntity .

ns1:Tool a rdfs:Class ;
    rdfs:label "Tool" ;
    rdfs:comment "Software tool or package (R, Python, numpy, scipy, R packages)." ;
    rdfs:subClassOf ns1:MathematicalEntity .

<http://example.org/instance/binomial_dist_1> a ns1:BinomialDistribution ;
    rdfs:label "Binomial distribution (R dbinom/pbinom)" ;
    ns1:documentedIn <http://example.org/instance/doc_main> ;
    ns1:hasParameter <http://example.org/instance/binom_param_p>,
        <http://example.org/instance/binom_param_size> .

<http://example.org/instance/exponential_dist_1> a ns1:ExponentialDistribution ;
    rdfs:label "Exponential distribution" ;
    ns1:documentedIn <http://example.org/instance/doc_main> ;
    ns1:hasCDF <http://example.org/instance/exp_cdf_expr> ;
    ns1:hasPDF <http://example.org/instance/exp_pdf_expr> ;
    ns1:hasParameter <http://example.org/instance/exp_param_lambda> ;
    ns1:isSpecialCaseOf <http://example.org/instance/gamma_dist_1> .

<http://example.org/instance/expr_fibonacci_py> a ns1:MathematicalExpression ;
    rdfs:label "Fibonacci (Python snippet)" ;
    ns1:documentedIn <http://example.org/instance/doc_main> ;
    ns1:hasFormula """This is a piece of code written in Python.
ax = []
for i in range(20):
if i<=1:
ax.append(i)
else:
ax.append(ax[i-1]+ax[i-2])""" .

<http://example.org/instance/normal_dist_1> a ns1:NormalDistribution ;
    rdfs:label "Normal distribution (R dnorm defaults)" ;
    ns1:documentedIn <http://example.org/instance/doc_main> ;
    ns1:hasParameter <http://example.org/instance/normal_param_m>,
        <http://example.org/instance/normal_param_std> .

<http://example.org/instance/poisson_dist_1> a ns1:PoissonDistribution ;
    rdfs:label "Poisson distribution (R dpois/ppois)" ;
    ns1:documentedIn <http://example.org/instance/doc_main> ;
    ns1:hasPMF <http://example.org/instance/poisson_pmf_expr> ;
    ns1:hasParameter <http://example.org/instance/poisson_param_lambda> .

<http://example.org/instance/studentt_dist_1> a ns1:StudentTDistribution ;
    rdfs:label "Student's t distribution" ;
    ns1:documentedIn <http://example.org/instance/doc_main> ;
    ns1:hasPDF <http://example.org/instance/studentt_pdf_expr> ;
    ns1:hasParameter <http://example.org/instance/studentt_param_nu> .

<http://example.org/instance/theorem_clt> a ns1:Theorem ;
    rdfs:label "Central Limit Theorem" ;
    ns1:assumesCondition <http://example.org/instance/cond_finite_variance>,
        <http://example.org/instance/cond_iid> ;
    ns1:documentedIn <http://example.org/instance/doc_main> ;
    ns1:hasStatement "If X1,...,Xn are independent and identically distributed (iid) random variables with finite mean μ and finite variance σ^2, then the standardized sample mean converges in distribution to a standard normal as n → ∞ (equivalently, sqrt(n)(̅X - μ) -> N(0,σ^2))." .

<http://example.org/instance/theorem_lln> a ns1:Theorem ;
    rdfs:label "Law of Large Numbers" ;
    ns1:assumesCondition <http://example.org/instance/cond_finite_mean>,
        <http://example.org/instance/cond_iid> ;
    ns1:documentedIn <http://example.org/instance/doc_main> ;
    ns1:hasStatement "If X1,...,Xn are independent and identically distributed (iid) with finite mean μ, then the sample mean X̅ converges in probability to μ as n → ∞ (i.e., X̅ ->p μ)." .

<http://example.org/instance/tool_python> a ns1:Tool ;
    rdfs:label "Python" ;
    ns1:documentedIn <http://example.org/instance/doc_main> .

ns1:appliesTo a rdf:Property ;
    rdfs:label "appliesTo" ;
    rdfs:comment "Indicates the primary domain of a Theorem (e.g., distribution or RandomVariable it concerns)." ;
    rdfs:domain ns1:Theorem ;
    rdfs:range ns1:MathematicalEntity .

ns1:assumesCondition a rdf:Property ;
    rdfs:label "assumesCondition" ;
    rdfs:comment "Links a Theorem to a Condition (assumption) such as iid, finite variance." ;
    rdfs:domain ns1:Theorem ;
    rdfs:range ns1:Condition .

ns1:computedFrom a rdf:Property ;
    rdfs:label "computedFrom" ;
    rdfs:comment "Indicates the RandomVariable or sample from which a Statistic is computed." ;
    rdfs:domain ns1:Statistic ;
    rdfs:range ns1:RandomVariable .

ns1:documentedIn a rdf:Property ;
    rdfs:label "documentedIn" ;
    rdfs:comment "Provenance link: where the concept or formula is described (Document)." ;
    rdfs:domain ns1:MathematicalEntity ;
    rdfs:range ns1:Document .

ns1:estimates a rdf:Property ;
    rdfs:label "estimates" ;
    rdfs:comment "Links an Estimator to the Parameter(s) it targets." ;
    rdfs:domain ns1:Estimator ;
    rdfs:range ns1:Parameter .

ns1:hasCDF a rdf:Property ;
    rdfs:label "hasCDF" ;
    rdfs:comment "Link to a MathematicalExpression node containing the CDF formula." ;
    rdfs:domain ns1:Distribution ;
    rdfs:range ns1:MathematicalExpression .

ns1:hasConfidenceLevel a rdf:Property ;
    rdfs:label "hasConfidenceLevel" ;
    rdfs:comment "Confidence level associated with a ConfidenceInterval (e.g., 0.95)." ;
    rdfs:domain ns1:ConfidenceInterval ;
    rdfs:range xsd:double .

ns1:hasDistribution a rdf:Property ;
    rdfs:label "hasDistribution" ;
    rdfs:comment "Links a RandomVariable to its Distribution." ;
    rdfs:domain ns1:RandomVariable ;
    rdfs:range ns1:Distribution .

ns1:hasFormula a rdf:Property ;
    rdfs:label "hasFormula" ;
    rdfs:comment "Holds the text of a mathematical expression (LaTeX, MathML, or code snippet)." ;
    rdfs:domain ns1:MathematicalExpression ;
    rdfs:range xsd:string .

ns1:hasMean a rdf:Property ;
    rdfs:label "hasMean" ;
    rdfs:comment "Mean value associated with a distribution (numeric)." ;
    rdfs:domain ns1:Distribution ;
    rdfs:range xsd:double .

ns1:hasPDF a rdf:Property ;
    rdfs:label "hasPDF" ;
    rdfs:comment "Link to a MathematicalExpression node containing the PDF formula (for continuous distributions)." ;
    rdfs:domain ns1:Distribution ;
    rdfs:range ns1:MathematicalExpression .

ns1:hasPMF a rdf:Property ;
    rdfs:label "hasPMF" ;
    rdfs:comment "Link to a MathematicalExpression node containing the PMF formula (for discrete distributions)." ;
    rdfs:domain ns1:Distribution ;
    rdfs:range ns1:MathematicalExpression .

ns1:hasPValue a rdf:Property ;
    rdfs:label "hasPValue" ;
    rdfs:comment "P-value resulting from a hypothesis test (numeric in [0,1])." ;
    rdfs:domain ns1:HypothesisTest ;
    rdfs:range xsd:double .

ns1:hasParameter a rdf:Property ;
    rdfs:label "hasParameter" ;
    rdfs:comment "Links a Distribution to one of its Parameters." ;
    rdfs:domain ns1:Distribution ;
    rdfs:range ns1:Parameter .

ns1:hasSignificanceLevel a rdf:Property ;
    rdfs:label "hasSignificanceLevel" ;
    rdfs:comment "Significance level (alpha) used in a hypothesis test (numeric in (0,1])." ;
    rdfs:domain ns1:HypothesisTest ;
    rdfs:range xsd:double .

ns1:hasStatement a rdf:Property ;
    rdfs:label "hasStatement" ;
    rdfs:comment "Human-readable statement text for a Theorem." ;
    rdfs:domain ns1:Theorem ;
    rdfs:range xsd:string .

ns1:hasTestStatistic a rdf:Property ;
    rdfs:label "hasTestStatistic" ;
    rdfs:comment "The Statistic node used as the test statistic in a HypothesisTest." ;
    rdfs:domain ns1:HypothesisTest ;
    rdfs:range ns1:Statistic .

ns1:hasVariance a rdf:Property ;
    rdfs:label "hasVariance" ;
    rdfs:comment "Variance value associated with a distribution (numeric)." ;
    rdfs:domain ns1:Distribution ;
    rdfs:range xsd:double .

ns1:implementedIn a rdf:Property ;
    rdfs:label "implementedIn" ;
    rdfs:comment "Links an Estimator or method to a software Tool or package implementation." ;
    rdfs:domain ns1:Estimator ;
    rdfs:range ns1:Tool .

ns1:isSpecialCaseOf a rdf:Property ;
    rdfs:label "isSpecialCaseOf" ;
    rdfs:comment "Relates a Distribution to another Distribution it is a special case or limit of (e.g., Poisson limit of Binomial)." ;
    rdfs:domain ns1:Distribution ;
    rdfs:range ns1:Distribution .

ns1:mentionsSemanticWebConcept a rdf:Property ;
    rdfs:label "mentionsSemanticWebConcept" ;
    rdfs:comment "Indicates that a Document discusses a semantic-web concept (RDF, RDFS, OWL, ALC)." ;
    rdfs:domain ns1:Document ;
    rdfs:range ns1:SemanticWebConcept .

ns1:parameterSymbol a rdf:Property ;
    rdfs:label "parameterSymbol" ;
    rdfs:comment "Symbol used for a parameter in the notebook (e.g., 'µ', 'σ2', 'λ', 'p')." ;
    rdfs:domain ns1:Parameter ;
    rdfs:range xsd:string .

ns1:parameterValue a rdf:Property ;
    rdfs:label "parameterValue" ;
    rdfs:comment "Numeric value for a parameter when known (use xsd:double). Constraints like λ>0 are documented, validation is external." ;
    rdfs:domain ns1:Parameter ;
    rdfs:range xsd:double .

<http://example.org/instance/binom_param_p> a ns1:Parameter ;
    rdfs:label "Binomial probability parameter (p)" ;
    ns1:parameterSymbol "p" .

<http://example.org/instance/binom_param_size> a ns1:Parameter ;
    rdfs:label "Binomial size parameter" ;
    ns1:parameterSymbol "size" .

<http://example.org/instance/cond_finite_mean> a ns1:Condition ;
    rdfs:label "finite mean" .

<http://example.org/instance/cond_finite_variance> a ns1:Condition ;
    rdfs:label "finite variance" .

<http://example.org/instance/exp_cdf_expr> a ns1:MathematicalExpression ;
    rdfs:label "Exponential CDF" ;
    ns1:hasFormula "F(x; λ) = 1 - e^{-λ x}, x ≥ 0" .

<http://example.org/instance/exp_param_lambda> a ns1:Parameter ;
    rdfs:label "rate parameter" ;
    ns1:parameterSymbol "λ" .

<http://example.org/instance/exp_pdf_expr> a ns1:MathematicalExpression ;
    rdfs:label "Exponential PDF" ;
    ns1:hasFormula "f(x; λ) = λ e^{-λ x}, x ≥ 0" .

<http://example.org/instance/gamma_cdf_expr> a ns1:MathematicalExpression ;
    rdfs:label "Gamma CDF" ;
    ns1:hasFormula "F(x; α, β) = γ(α, β x) / Γ(α)" .

<http://example.org/instance/gamma_dist_1> a ns1:GammaDistribution ;
    rdfs:label "Gamma distribution" ;
    ns1:documentedIn <http://example.org/instance/doc_main> ;
    ns1:hasCDF <http://example.org/instance/gamma_cdf_expr> ;
    ns1:hasPDF <http://example.org/instance/gamma_pdf_expr> ;
    ns1:hasParameter <http://example.org/instance/gamma_param_alpha>,
        <http://example.org/instance/gamma_param_beta> .

<http://example.org/instance/gamma_param_alpha> a ns1:Parameter ;
    rdfs:label "shape parameter" ;
    ns1:parameterSymbol "α" .

<http://example.org/instance/gamma_param_beta> a ns1:Parameter ;
    rdfs:label "rate parameter" ;
    ns1:parameterSymbol "β" .

<http://example.org/instance/gamma_pdf_expr> a ns1:MathematicalExpression ;
    rdfs:label "Gamma PDF" ;
    ns1:hasFormula "f(x; α, β) = (β^α / Γ(α)) x^{α-1} e^{-β x}, x ≥ 0" .

<http://example.org/instance/normal_param_m> a ns1:Parameter ;
    rdfs:label "Normal mean parameter (m)" ;
    ns1:parameterSymbol "m" ;
    ns1:parameterValue 0e+00 .

<http://example.org/instance/normal_param_std> a ns1:Parameter ;
    rdfs:label "Normal std parameter (std)" ;
    ns1:parameterSymbol "std" ;
    ns1:parameterValue 1e+00 .

<http://example.org/instance/poisson_param_lambda> a ns1:Parameter ;
    rdfs:label "Poisson rate parameter (lambda)" ;
    ns1:parameterSymbol "lambda" .

<http://example.org/instance/poisson_pmf_expr> a ns1:MathematicalExpression ;
    rdfs:label "Poisson PMF" ;
    ns1:hasFormula "P(X=k; λ) = e^{-λ} λ^k / k!, k = 0,1,2, ..." .

<http://example.org/instance/studentt_param_nu> a ns1:Parameter ;
    rdfs:label "degrees of freedom" ;
    ns1:parameterSymbol "ν" .

<http://example.org/instance/studentt_pdf_expr> a ns1:MathematicalExpression ;
    rdfs:label "Student-t PDF" ;
    ns1:hasFormula "f(t; ν) = Γ((ν+1)/2) / (√(νπ) Γ(ν/2)) (1 + t^2/ν)^{-(ν+1)/2}" .

<http://example.org/instance/cond_iid> a ns1:Condition ;
    rdfs:label "iid" .

<http://example.org/instance/doc_main> a ns1:Document ;
    rdfs:label "main.pdf (notebook)" .

