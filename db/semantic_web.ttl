@prefix ns1: <http://example.org/semantic-web#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:API a rdfs:Class ;
    rdfs:label "API" ;
    rdfs:comment "API type or interface exposed by a triplestore (e.g., REST)." .

ns1:Agent a rdfs:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "Actor or agent (person or organization)." ;
    rdfs:subClassOf ns1:Resource .

ns1:Concept a rdfs:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "A conceptual term suitable for lightweight taxonomies (SKOS-like)." ;
    rdfs:subClassOf ns1:Resource .

ns1:Dataset a rdfs:Class ;
    rdfs:label "Dataset" ;
    rdfs:comment "A collection of RDF data or resources." ;
    rdfs:subClassOf ns1:Resource .

ns1:Dish a rdfs:Class ;
    rdfs:label "Dish" ;
    rdfs:comment "A prepared food item or recipe." ;
    rdfs:subClassOf ns1:Resource .

ns1:Feature a rdfs:Class ;
    rdfs:label "Feature" ;
    rdfs:comment "A named capability or feature of a triplestore." .

ns1:FoodItem a rdfs:Class ;
    rdfs:label "FoodItem" ;
    rdfs:comment "An ingredient or food item." ;
    rdfs:subClassOf ns1:Resource .

ns1:License a rdfs:Class ;
    rdfs:label "License" ;
    rdfs:comment "License resource for software products (e.g., Apache-2.0)." .

ns1:Meat a rdfs:Class ;
    rdfs:label "Meat" ;
    rdfs:comment "Animal-based food item." ;
    rdfs:subClassOf ns1:FoodItem .

ns1:Ontology a rdfs:Class ;
    rdfs:label "Ontology" ;
    rdfs:comment "A schema or ontology document describing classes and properties." ;
    rdfs:subClassOf ns1:Dataset .

ns1:Person a rdfs:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human person; FOAF-like person concept." ;
    rdfs:subClassOf ns1:Agent .

ns1:Protocol a rdfs:Class ;
    rdfs:label "Protocol" ;
    rdfs:comment "Network or access protocol (e.g., HTTP, SPARQL Protocol)." .

ns1:Resource a rdfs:Class ;
    rdfs:label "Resource" ;
    rdfs:comment "Generic information resource (datasets, documents, software)." .

ns1:Software a rdfs:Class ;
    rdfs:label "Software" ;
    rdfs:comment "Software artifact or product." ;
    rdfs:subClassOf ns1:Resource .

ns1:Triplestore a rdfs:Class ;
    rdfs:label "Triplestore" ;
    rdfs:comment "An RDF database / triplestore product." ;
    rdfs:subClassOf ns1:Software .

ns1:VegetarianDish a rdfs:Class ;
    rdfs:label "VegetarianDish" ;
    rdfs:comment "A Dish that contains no Meat items (intensional class in OWL examples)." ;
    rdfs:subClassOf ns1:Dish .

ns1:broader a rdf:Property ;
    rdfs:label "broader" ;
    rdfs:comment "Taxonomy relation between Concepts (SKOS-style broader)." ;
    rdfs:domain ns1:Concept ;
    rdfs:range ns1:Concept .

ns1:createdDate a rdf:Property ;
    rdfs:label "created date" ;
    rdfs:comment "Creation date of the resource." ;
    rdfs:domain ns1:Resource ;
    rdfs:range xsd:date .

ns1:creator a rdf:Property ;
    rdfs:label "creator" ;
    rdfs:comment "Agent that created a resource." ;
    rdfs:domain ns1:Resource ;
    rdfs:range ns1:Agent .

ns1:exposesAPI a rdf:Property ;
    rdfs:label "exposes API" ;
    rdfs:comment "Link to API nodes that the triplestore exposes." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range ns1:API .

ns1:featureName a rdf:Property ;
    rdfs:label "feature name" ;
    rdfs:comment "Short textual name for a Feature." ;
    rdfs:domain ns1:Feature ;
    rdfs:range xsd:string .

ns1:format a rdf:Property ;
    rdfs:label "format" ;
    rdfs:comment "Textual format or media type for a resource (e.g., Turtle)." ;
    rdfs:domain ns1:Resource ;
    rdfs:range xsd:string .

ns1:hasComponent a rdf:Property ;
    rdfs:label "has component" ;
    rdfs:comment "Alternate predicate for dish components; normalized to hasIngredient." ;
    rdfs:domain ns1:Dish ;
    rdfs:range ns1:FoodItem ;
    rdfs:subPropertyOf ns1:hasIngredient .

ns1:hasConcept a rdf:Property ;
    rdfs:label "has concept" ;
    rdfs:comment "Links an Ontology to Concepts it declares." ;
    rdfs:domain ns1:Ontology ;
    rdfs:range ns1:Concept .

ns1:hasFeature a rdf:Property ;
    rdfs:label "has feature" ;
    rdfs:comment "Attach a Feature node describing a capability to a Triplestore." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range ns1:Feature .

ns1:homepage a rdf:Property ;
    rdfs:label "homepage" ;
    rdfs:comment "Canonical homepage or product URL." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:anyURI .

ns1:isOpenSource a rdf:Property ;
    rdfs:label "is open source" ;
    rdfs:comment "Whether the triplestore product is open-source." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:boolean .

ns1:license a rdf:Property ;
    rdfs:label "license" ;
    rdfs:comment "License of the triplestore product." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range ns1:License .

ns1:prefLabel a rdf:Property ;
    rdfs:label "preferred label" ;
    rdfs:comment "Human-readable preferred label (convenience property)." ;
    rdfs:domain ns1:Resource ;
    rdfs:range xsd:string .

ns1:publisher a rdf:Property ;
    rdfs:label "publisher" ;
    rdfs:comment "Agent that published or distributes the resource." ;
    rdfs:domain ns1:Resource ;
    rdfs:range ns1:Agent .

ns1:storageType a rdf:Property ;
    rdfs:label "storage type" ;
    rdfs:comment "Textual description of storage/persistence type (e.g., native, federated)." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:string .

ns1:supportsProtocol a rdf:Property ;
    rdfs:label "supports protocol" ;
    rdfs:comment "Protocol supported by the triplestore (e.g., HTTP)." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range ns1:Protocol .

ns1:supportsReasoning a rdf:Property ;
    rdfs:label "supports reasoning" ;
    rdfs:comment "Whether the triplestore advertises built-in inference/reasoning support." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:boolean .

ns1:supportsSPARQL a rdf:Property ;
    rdfs:label "supports SPARQL" ;
    rdfs:comment "Whether the triplestore exposes a SPARQL endpoint." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:boolean .

ns1:supportsTransactions a rdf:Property ;
    rdfs:label "supports transactions" ;
    rdfs:comment "Whether the triplestore supports transactional updates." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:boolean .

ns1:vendor a rdf:Property ;
    rdfs:label "vendor" ;
    rdfs:comment "Vendor or organization providing the triplestore." ;
    rdfs:domain ns1:Triplestore ;
    rdfs:range xsd:string .

<http://example.org/semantic-web/instance/albert-einstein> a ns1:Person ;
    ns1:prefLabel "Albert Einstein" .

<http://example.org/semantic-web/instance/chicken-sandwich> a ns1:Dish ;
    ns1:hasIngredient <http://example.org/semantic-web/instance/bread>,
        <http://example.org/semantic-web/instance/chicken> ;
    ns1:prefLabel "Chicken Sandwich" .

<http://example.org/semantic-web/instance/margherita-pizza> a ns1:Dish ;
    ns1:hasIngredient <http://example.org/semantic-web/instance/cheese>,
        <http://example.org/semantic-web/instance/tomato> ;
    ns1:prefLabel "Margherita Pizza" .

<http://example.org/semantic-web/instance/ontology-intro> a ns1:Ontology ;
    ns1:hasConcept <http://example.org/semantic-web/instance/concept-attributes>,
        <http://example.org/semantic-web/instance/concept-axioms>,
        <http://example.org/semantic-web/instance/concept-classes>,
        <http://example.org/semantic-web/instance/concept-individuals>,
        <http://example.org/semantic-web/instance/concept-reasoning>,
        <http://example.org/semantic-web/instance/concept-relationships>,
        <http://example.org/semantic-web/instance/owl2-el>,
        <http://example.org/semantic-web/instance/owl2-ql>,
        <http://example.org/semantic-web/instance/owl2-rl> ;
    ns1:prefLabel "Comprehensive Introduction to Ontologies in Information Science" .

<http://example.org/semantic-web/instance/semanticweb-article> a ns1:Dataset ;
    ns1:hasConcept <http://example.org/semantic-web/instance/concept-enterprise-kg>,
        <http://example.org/semantic-web/instance/concept-identifiers>,
        <http://example.org/semantic-web/instance/concept-linked-open-data>,
        <http://example.org/semantic-web/instance/concept-nuna>,
        <http://example.org/semantic-web/instance/concept-owa>,
        <http://example.org/semantic-web/instance/concept-owl>,
        <http://example.org/semantic-web/instance/concept-rdf>,
        <http://example.org/semantic-web/instance/concept-rdfs>,
        <http://example.org/semantic-web/instance/concept-schemaorg>,
        <http://example.org/semantic-web/instance/concept-syntax>,
        <http://example.org/semantic-web/instance/sparql> ;
    ns1:prefLabel "The Semantic Web: Architecture, Logic, and Engineering" .

<http://example.org/semantic-web/instance/the-matrix> a ns1:Resource ;
    ns1:prefLabel "The Matrix (example: Movie)" .

<http://example.org/triplestore/allegrograph> a ns1:Triplestore ;
    rdfs:label "AllegroGraph" ;
    ns1:exposesAPI <http://example.org/api/sparql-1-1-python-java-lisp> ;
    ns1:hasFeature <http://example.org/feature/document-graph-database-with-advanced-temporal> ;
    ns1:license <http://example.org/license/commercial> ;
    ns1:prefLabel "AllegroGraph"^^xsd:string ;
    ns1:publisher <http://example.org/agent/franz-inc> .

<http://example.org/triplestore/amazon-neptune> a ns1:Triplestore ;
    rdfs:label "Amazon Neptune" ;
    ns1:exposesAPI <http://example.org/api/sparql-apache-tinkerpop-gremlin-opencypher> ;
    ns1:hasFeature <http://example.org/feature/fully-managed-cloud-database> ;
    ns1:license <http://example.org/license/commercial-managed-service> ;
    ns1:prefLabel "Amazon Neptune"^^xsd:string ;
    ns1:publisher <http://example.org/agent/amazon-web-services-aws> .

<http://example.org/triplestore/anzograph> a ns1:Triplestore ;
    rdfs:label "AnzoGraph" ;
    ns1:exposesAPI <http://example.org/api/sparql-1-1-cypher-c-api> ;
    ns1:hasFeature <http://example.org/feature/massively-parallel-processing-mpp-native-graph-database-designed-for-distributed-analytics> ;
    ns1:license <http://example.org/license/commercial> ;
    ns1:prefLabel "AnzoGraph"^^xsd:string ;
    ns1:publisher <http://example.org/agent/cambridge-semantics> .

<http://example.org/triplestore/apache-jena-tdb> a ns1:Triplestore ;
    rdfs:label "Apache Jena TDB" ;
    ns1:exposesAPI <http://example.org/api/sparql-1-1-native-jena-api> ;
    ns1:hasFeature <http://example.org/feature/component-of-the-apache-jena-framework-a-native> ;
    ns1:license <http://example.org/license/open-source-apache-2-0> ;
    ns1:prefLabel "Apache Jena TDB"^^xsd:string ;
    ns1:publisher <http://example.org/agent/apache-software-foundation> .

<http://example.org/triplestore/blazegraph> a ns1:Triplestore ;
    rdfs:label "Blazegraph" ;
    ns1:exposesAPI <http://example.org/api/sparql-1-1-blueprint-rdf4j> ;
    ns1:hasFeature <http://example.org/feature/high-performance-graph-database-historically-powered-wikidata-query-service> ;
    ns1:license <http://example.org/license/open-source-gplv3-commercial> ;
    ns1:prefLabel "Blazegraph"^^xsd:string ;
    ns1:publisher <http://example.org/agent/systap-acquired-by-amazon> .

<http://example.org/triplestore/graphdb> a ns1:Triplestore ;
    rdfs:label "GraphDB" ;
    ns1:exposesAPI <http://example.org/api/sparql-1-1-rdf4j-graphdb-workbench> ;
    ns1:hasFeature <http://example.org/feature/advanced-rdf-owl-reasoning> ;
    ns1:license <http://example.org/license/commercial-free-edition> ;
    ns1:prefLabel "GraphDB"^^xsd:string ;
    ns1:publisher <http://example.org/agent/ontotext> .

<http://example.org/triplestore/marklogic> a ns1:Triplestore ;
    rdfs:label "MarkLogic" ;
    ns1:exposesAPI <http://example.org/api/sparql-1-1-rest-java-node-js> ;
    ns1:hasFeature <http://example.org/feature/multi-model-nosql-database-integrating-xml> ;
    ns1:license <http://example.org/license/commercial> ;
    ns1:prefLabel "MarkLogic"^^xsd:string ;
    ns1:publisher <http://example.org/agent/progress-software> .

<http://example.org/triplestore/oracle-spatial-and-graph> a ns1:Triplestore ;
    rdfs:label "Oracle Spatial and Graph" ;
    ns1:exposesAPI <http://example.org/api/sparql-1-1-sql-property-graph> ;
    ns1:hasFeature <http://example.org/feature/enterprise-rdf-semantic-graph-support-built-natively-into-oracle-database> ;
    ns1:license <http://example.org/license/commercial> ;
    ns1:prefLabel "Oracle Spatial and Graph"^^xsd:string ;
    ns1:publisher <http://example.org/agent/oracle> .

<http://example.org/triplestore/rdf4j-formerly-sesame> a ns1:Triplestore ;
    rdfs:label "RDF4J (formerly Sesame)" ;
    ns1:exposesAPI <http://example.org/api/sparql-1-1-rdf4j-api> ;
    ns1:hasFeature <http://example.org/feature/java-framework-for-processing-rdf-data-that-includes-an-in-memory-and-disk-based-triplestore> ;
    ns1:license <http://example.org/license/open-source-edl> ;
    ns1:prefLabel "RDF4J (formerly Sesame)"^^xsd:string ;
    ns1:publisher <http://example.org/agent/eclipse-foundation> .

<http://example.org/triplestore/stardog> a ns1:Triplestore ;
    rdfs:label "Stardog" ;
    ns1:exposesAPI <http://example.org/api/sparql-1-1-graphql-java-api> ;
    ns1:hasFeature <http://example.org/feature/enterprise-knowledge-graph-platform-with-virtual-graphs-data-virtualization-and-logic-reasoning> ;
    ns1:license <http://example.org/license/commercial> ;
    ns1:prefLabel "Stardog"^^xsd:string ;
    ns1:publisher <http://example.org/agent/stardog-union> .

<http://example.org/triplestore/virtuoso> a ns1:Triplestore ;
    rdfs:label "Virtuoso" ;
    ns1:exposesAPI <http://example.org/api/sparql-sql-odbc-jdbc> ;
    ns1:hasFeature <http://example.org/feature/hybrid-relational-rdf-engine> ;
    ns1:license <http://example.org/license/open-source-gplv2-commercial> ;
    ns1:prefLabel "Virtuoso"^^xsd:string ;
    ns1:publisher <http://example.org/agent/openlink-software> .

<http://example.org/agent/amazon-web-services-aws> a ns1:Agent ;
    rdfs:label "Amazon Web Services (AWS)" .

<http://example.org/agent/apache-software-foundation> a ns1:Agent ;
    rdfs:label "Apache Software Foundation" .

<http://example.org/agent/cambridge-semantics> a ns1:Agent ;
    rdfs:label "Cambridge Semantics" .

<http://example.org/agent/eclipse-foundation> a ns1:Agent ;
    rdfs:label "Eclipse Foundation" .

<http://example.org/agent/franz-inc> a ns1:Agent ;
    rdfs:label "Franz Inc." .

<http://example.org/agent/ontotext> a ns1:Agent ;
    rdfs:label "Ontotext" .

<http://example.org/agent/openlink-software> a ns1:Agent ;
    rdfs:label "OpenLink Software" .

<http://example.org/agent/oracle> a ns1:Agent ;
    rdfs:label "Oracle" .

<http://example.org/agent/progress-software> a ns1:Agent ;
    rdfs:label "Progress Software" .

<http://example.org/agent/stardog-union> a ns1:Agent ;
    rdfs:label "Stardog Union" .

<http://example.org/agent/systap-acquired-by-amazon> a ns1:Agent ;
    rdfs:label "Systap (acquired by Amazon)" .

<http://example.org/api/sparql-1-1-blueprint-rdf4j> a ns1:API ;
    rdfs:label "SPARQL 1.1 / Blueprint / RDF4J" .

<http://example.org/api/sparql-1-1-cypher-c-api> a ns1:API ;
    rdfs:label "SPARQL 1.1 / Cypher / C++ API" .

<http://example.org/api/sparql-1-1-graphql-java-api> a ns1:API ;
    rdfs:label "SPARQL 1.1 / GraphQL / Java API" .

<http://example.org/api/sparql-1-1-native-jena-api> a ns1:API ;
    rdfs:label "SPARQL 1.1 / Native Jena API" .

<http://example.org/api/sparql-1-1-python-java-lisp> a ns1:API ;
    rdfs:label "SPARQL 1.1 / Python / Java / Lisp" .

<http://example.org/api/sparql-1-1-rdf4j-api> a ns1:API ;
    rdfs:label "SPARQL 1.1 / RDF4J API" .

<http://example.org/api/sparql-1-1-rdf4j-graphdb-workbench> a ns1:API ;
    rdfs:label "SPARQL 1.1 / RDF4J / GraphDB Workbench" .

<http://example.org/api/sparql-1-1-rest-java-node-js> a ns1:API ;
    rdfs:label "SPARQL 1.1 / REST / Java / Node.js" .

<http://example.org/api/sparql-1-1-sql-property-graph> a ns1:API ;
    rdfs:label "SPARQL 1.1 / SQL / Property Graph" .

<http://example.org/api/sparql-apache-tinkerpop-gremlin-opencypher> a ns1:API ;
    rdfs:label "SPARQL / Apache TinkerPop Gremlin / openCypher" .

<http://example.org/api/sparql-sql-odbc-jdbc> a ns1:API ;
    rdfs:label "SPARQL / SQL / ODBC / JDBC" .

<http://example.org/feature/advanced-rdf-owl-reasoning> a ns1:Feature ;
    rdfs:label "Advanced RDF/OWL reasoning" .

<http://example.org/feature/component-of-the-apache-jena-framework-a-native> a ns1:Feature ;
    rdfs:label "Component of the Apache Jena framework; a native" .

<http://example.org/feature/document-graph-database-with-advanced-temporal> a ns1:Feature ;
    rdfs:label "Document-Graph database with advanced temporal" .

<http://example.org/feature/enterprise-knowledge-graph-platform-with-virtual-graphs-data-virtualization-and-logic-reasoning> a ns1:Feature ;
    rdfs:label "Enterprise knowledge graph platform with virtual graphs (data virtualization) and logic reasoning." .

<http://example.org/feature/enterprise-rdf-semantic-graph-support-built-natively-into-oracle-database> a ns1:Feature ;
    rdfs:label "Enterprise RDF semantic graph support built natively into Oracle Database." .

<http://example.org/feature/fully-managed-cloud-database> a ns1:Feature ;
    rdfs:label "Fully managed cloud database" .

<http://example.org/feature/high-performance-graph-database-historically-powered-wikidata-query-service> a ns1:Feature ;
    rdfs:label "High-performance graph database (historically powered Wikidata Query Service)." .

<http://example.org/feature/hybrid-relational-rdf-engine> a ns1:Feature ;
    rdfs:label "Hybrid relational/RDF engine" .

<http://example.org/feature/java-framework-for-processing-rdf-data-that-includes-an-in-memory-and-disk-based-triplestore> a ns1:Feature ;
    rdfs:label "Java framework for processing RDF data that includes an in-memory and disk-based triplestore." .

<http://example.org/feature/massively-parallel-processing-mpp-native-graph-database-designed-for-distributed-analytics> a ns1:Feature ;
    rdfs:label "Massively Parallel Processing (MPP) native graph database designed for distributed analytics." .

<http://example.org/feature/multi-model-nosql-database-integrating-xml> a ns1:Feature ;
    rdfs:label "Multi-model NoSQL database integrating XML" .

