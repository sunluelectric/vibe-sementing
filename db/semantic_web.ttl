@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sw: <http://example.org/semantic-web#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sw:Adventure a rdfs:Class ;
    rdfs:label "Adventure" ;
    rdfs:comment "Top-level scenario container: metadata, scenes, rewards and recommendations." .

sw:Character a rdfs:Class ;
    rdfs:label "Character" ;
    rdfs:comment "An abstract actor: players, NPCs and monsters are characters." .

sw:Chest a rdfs:Class ;
    rdfs:label "Chest" ;
    rdfs:comment "A container item that can hold other items (quest chest)." ;
    rdfs:subClassOf sw:Item .

sw:Item a rdfs:Class ;
    rdfs:label "Item" ;
    rdfs:comment "A generic item, loot, or equipment." .

sw:Location a rdfs:Class ;
    rdfs:label "Location" ;
    rdfs:comment "A named place or locale referenced by a scene." .

sw:Monster a rdfs:Class ;
    rdfs:label "Monster" ;
    rdfs:comment "A hostile creature encountered in the adventure." ;
    rdfs:subClassOf sw:Character .

sw:Npc a rdfs:Class ;
    rdfs:label "Npc" ;
    rdfs:comment "Non-player character such as quest-givers or villagers." ;
    rdfs:subClassOf sw:Character .

sw:Player a rdfs:Class ;
    rdfs:label "Player" ;
    rdfs:comment "A player-controlled character." ;
    rdfs:subClassOf sw:Character .

sw:PlayerClass a rdfs:Class ;
    rdfs:label "PlayerClass" ;
    rdfs:comment "A playable class option (e.g. Fighter, Wizard, Rogue)." .

sw:Potion a rdfs:Class ;
    rdfs:label "Potion" ;
    rdfs:comment "A consumable potion such as a Healing Potion." ;
    rdfs:subClassOf sw:Item .

sw:Race a rdfs:Class ;
    rdfs:label "Race" ;
    rdfs:comment "A playable race option (e.g. Human, Elf, Dwarf)." .

sw:Scene a rdfs:Class ;
    rdfs:label "Scene" ;
    rdfs:comment "A self-contained scene in the adventure (e.g. Village Millhaven, Goblin Warren)." .

sw:Weapon a rdfs:Class ;
    rdfs:label "Weapon" ;
    rdfs:comment "A weapon (melee or thrown)." ;
    rdfs:subClassOf sw:Item .

sw:GoblinCaveOfAshenvale a sw:Adventure ;
    rdfs:label "The Goblin Cave of Ashenvale" ;
    sw:difficulty "Beginner-friendly" ;
    sw:hasRaceOption sw:Dwarf,
        sw:Elf,
        sw:Human ;
    sw:hasScene sw:Scene1_Millhaven,
        sw:Scene2_HillsideTrail,
        sw:Scene3_GoblinWarren,
        sw:Scene4_ReturnToMillhaven ;
    sw:offersClass sw:FighterClass,
        sw:RogueClass,
        sw:WizardClass ;
    sw:partySizeMax 4 ;
    sw:partySizeMin 2 ;
    sw:recommendedLevel 1 ;
    sw:rewardAmount 50.0 ;
    rdfs:comment "XP awards (summary): quest completion 100 XP; heirloom dagger returned 50 XP; maximum total XP (enemies + quest) 650." .

sw:abilityText a rdf:Property ;
    rdfs:label "abilityText" ;
    rdfs:comment "Text describing a special ability or trait (e.g. 'Nimble Escape')." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:string .

sw:armorClass a rdf:Property ;
    rdfs:label "armorClass" ;
    rdfs:comment "Armor Class (AC) as an integer." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:integer .

sw:attackBonus a rdf:Property ;
    rdfs:label "attackBonus" ;
    rdfs:comment "Numeric attack bonus (e.g. +4)." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:integer .

sw:carries a rdf:Property ;
    rdfs:label "carries" ;
    rdfs:comment "Indicates an Item carried by a Character (loot or equipment)." ;
    rdfs:domain sw:Character ;
    rdfs:range sw:Item .

sw:contains a rdf:Property ;
    rdfs:label "contains" ;
    rdfs:comment "Indicates that a chest or container contains an item." ;
    rdfs:domain sw:Chest ;
    rdfs:range sw:Item .

sw:damage a rdf:Property ;
    rdfs:label "damage" ;
    rdfs:comment "Textual damage expression for a weapon or attack (e.g. '1d4+1 piercing')." ;
    rdfs:domain sw:Item ;
    rdfs:range xsd:string .

sw:dc a rdf:Property ;
    rdfs:label "dc" ;
    rdfs:comment "Difficulty Class (DC) for a scene check (e.g. Stealth DC)." ;
    rdfs:domain sw:Scene ;
    rdfs:range xsd:integer .

sw:difficulty a rdf:Property ;
    rdfs:label "difficulty" ;
    rdfs:comment "Textual difficulty label for the adventure (e.g. 'Beginner-friendly')." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:string .

sw:encounters a rdf:Property ;
    rdfs:label "encounters" ;
    rdfs:comment "A flexible link listing characters encountered in a Scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Character .

sw:goldAmount a rdf:Property ;
    rdfs:label "goldAmount" ;
    rdfs:comment "Numeric gold amount for an item or chest contents." ;
    rdfs:domain sw:Item ;
    rdfs:range xsd:decimal .

sw:hasItem a rdf:Property ;
    rdfs:label "hasItem" ;
    rdfs:comment "Items placed or found in a Scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Item .

sw:hasLocation a rdf:Property ;
    rdfs:label "hasLocation" ;
    rdfs:comment "Associates a Scene with a Location." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Location .

sw:hasMonster a rdf:Property ;
    rdfs:label "hasMonster" ;
    rdfs:comment "Names a Monster present in a Scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Monster .

sw:hasNPC a rdf:Property ;
    rdfs:label "hasNPC" ;
    rdfs:comment "Names an NPC present in a Scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Npc .

sw:hasRaceOption a rdf:Property ;
    rdfs:label "hasRaceOption" ;
    rdfs:comment "Player race options offered by the Adventure." ;
    rdfs:domain sw:Adventure ;
    rdfs:range sw:Race .

sw:hasRole a rdf:Property ;
    rdfs:label "hasRole" ;
    rdfs:comment "Short role label for an NPC (e.g. 'Quest Giver', 'Village Elder')." ;
    rdfs:domain sw:Npc ;
    rdfs:range xsd:string .

sw:hasScene a rdf:Property ;
    rdfs:label "hasScene" ;
    rdfs:comment "Links an Adventure to its Scenes." ;
    rdfs:domain sw:Adventure ;
    rdfs:range sw:Scene .

sw:hp a rdf:Property ;
    rdfs:label "hp" ;
    rdfs:comment "Hit points (integer) for characters and monsters." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:integer .

sw:leadsTo a rdf:Property ;
    rdfs:label "leadsTo" ;
    rdfs:comment "Connects a Scene to another Scene via an exit." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Scene .

sw:objectiveText a rdf:Property ;
    rdfs:label "objectiveText" ;
    rdfs:comment "Short in-scene objective or goal text." ;
    rdfs:domain sw:Scene ;
    rdfs:range xsd:string .

sw:offersClass a rdf:Property ;
    rdfs:label "offersClass" ;
    rdfs:comment "Player classes offered by the Adventure." ;
    rdfs:domain sw:Adventure ;
    rdfs:range sw:PlayerClass .

sw:partySizeMax a rdf:Property ;
    rdfs:label "partySizeMax" ;
    rdfs:comment "Maximum recommended party size." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:integer .

sw:partySizeMin a rdf:Property ;
    rdfs:label "partySizeMin" ;
    rdfs:comment "Minimum recommended party size." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:integer .

sw:quantity a rdf:Property ;
    rdfs:label "quantity" ;
    rdfs:comment "Integer quantity for stackable items." ;
    rdfs:domain sw:Item ;
    rdfs:range xsd:integer .

sw:recommendedLevel a rdf:Property ;
    rdfs:label "recommendedLevel" ;
    rdfs:comment "Recommended character level for the adventure." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:integer .

sw:rewardAmount a rdf:Property ;
    rdfs:label "rewardAmount" ;
    rdfs:comment "Gold reward amount offered by NPCs or the village for the adventure objective." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:decimal .

sw:sceneDescription a rdf:Property ;
    rdfs:label "sceneDescription" ;
    rdfs:comment "Longer descriptive or DM notes for a scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range xsd:string .

sw:xpValue a rdf:Property ;
    rdfs:label "xpValue" ;
    rdfs:comment "Experience points awarded for defeating a monster or completing an event." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:integer .

sw:ChestKey a sw:Item ;
    rdfs:label "Chest Key" ;
    rdfs:comment "Small iron key used to open Aldric's locked wooden chest." .

sw:Chest_GoldChest a sw:Chest ;
    rdfs:label "Gold Chest (Aldric's)",
        "Locked Gold Chest (Aldric's)" ;
    sw:contains sw:Gold_200,
        sw:HealingPotion_S3 ;
    rdfs:comment "Locked wooden chest belonging to Aldric Thorn; contains 200 gp and a healing potion." .

sw:Dwarf a sw:Race ;
    rdfs:label "Dwarf" .

sw:Elf a sw:Race ;
    rdfs:label "Elf" .

sw:FighterClass a sw:PlayerClass ;
    rdfs:label "Fighter" .

sw:Goblin_Chamber1 a sw:Monster ;
    rdfs:label "Goblin (Chamber)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing). Ability: Nimble Escape." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Chamber2 a sw:Monster ;
    rdfs:label "Goblin (Chamber)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing). Ability: Nimble Escape." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Chamber3 a sw:Monster ;
    rdfs:label "Goblin (Chamber)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing). Ability: Nimble Escape." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Guard a sw:Monster ;
    rdfs:label "Goblin (Bodyguard)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing) or Shortbow. Ability: Nimble Escape." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Sentry1 a sw:Monster ;
    rdfs:label "Goblin (Sentry 1)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing, range 80/320 ft). Ability: Nimble Escape (can Disengage or Hide as a bonus action)." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Sentry2 a sw:Monster ;
    rdfs:label "Goblin (Sentry 2)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing, range 80/320 ft). Ability: Nimble Escape (can Disengage or Hide as a bonus action)." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Gold_12 a sw:Item ;
    rdfs:label "12 gp (scattered around the warren)" ;
    sw:goldAmount 12.0 ;
    sw:quantity 1 .

sw:Gold_200 a sw:Item ;
    rdfs:label "200 gp (stolen chest contents)" ;
    sw:goldAmount 200.0 ;
    sw:quantity 1 .

sw:Gold_3 a sw:Item ;
    rdfs:label "3 gp (found at trail post)" ;
    sw:goldAmount 3.0 ;
    sw:quantity 1 .

sw:Grix a sw:Monster ;
    rdfs:label "Grix (Goblin Boss)" ;
    sw:abilityText "Morningstar attack (+4 to hit, 2d6+2 piercing). Abilities: Redirect Attack (when hit, can redirect attack to a nearby goblin); Multiattack (2 attacks per turn)." ;
    sw:armorClass 17 ;
    sw:attackBonus 4 ;
    sw:carries sw:ChestKey,
        sw:HeirloomDagger ;
    sw:hp 21 ;
    sw:xpValue 200 .

sw:HealingPotion_S2 a sw:Potion ;
    rdfs:label "Healing Potion (tucked in sack near post)" ;
    sw:damage "Restores 2d4+2 HP when consumed (action to drink)" ;
    sw:quantity 1 .

sw:HealingPotion_S3 a sw:Potion ;
    rdfs:label "Healing Potion (in chest)" ;
    sw:damage "Restores 2d4+2 HP when consumed (action to drink)" ;
    sw:quantity 1 .

sw:HeirloomDagger a sw:Weapon ;
    rdfs:label "Heirloom Dagger (Thorn family)" ;
    sw:damage "1d4+1 piercing" ;
    sw:quantity 1 ;
    rdfs:comment "Properties: Finesse, Light, Thrown (range 20/60). Finely-crafted dagger with a silver pommel engraved with the Thorn family crest." .

sw:Human a sw:Race ;
    rdfs:label "Human" .

sw:Location_GoblinWarren a sw:Location ;
    rdfs:label "Ashenvale Burrows (Goblin Warren)" .

sw:Location_HillsideTrail a sw:Location ;
    rdfs:label "Hillside Trail (north of Millhaven)" .

sw:RogueClass a sw:PlayerClass ;
    rdfs:label "Rogue" .

sw:Scene1_Millhaven a sw:Scene ;
    rdfs:label "Scene 1: The Village of Millhaven" ;
    sw:hasLocation sw:Location_Millhaven ;
    sw:hasNPC sw:AldricThorn,
        sw:ElderMira ;
    sw:leadsTo sw:Scene2_HillsideTrail ;
    sw:objectiveText "Learn about the quest and agree to help." ;
    sw:sceneDescription "A small farming village at dusk. Aldric Thorn sits outside the inn, head bandaged and distressed; Elder Mira stands nearby. Players can ask questions to learn direction (north), approximate goblin numbers (4–5), and time of attack (dusk, ~2 hours ago)." .

sw:Scene4_ReturnToMillhaven a sw:Scene ;
    rdfs:label "Scene 4: Return to Millhaven" ;
    sw:hasLocation sw:Location_Millhaven ;
    sw:hasNPC sw:AldricThorn,
        sw:ElderMira ;
    sw:objectiveText "Deliver the chest and dagger to Aldric and Elder Mira; collect the village reward." ;
    sw:sceneDescription "Dawn in Millhaven. Aldric is overjoyed; Elder Mira pays the reward. Additional small roleplay/cleanup scene." .

sw:Scene_DeadEnd_Wilderness a sw:Scene ;
    rdfs:label "Back Crack / Wilderness (dead end)" ;
    sw:sceneDescription "A narrow crack and scramble leading outside; used as an escape route by Grix (dead end for players)." .

sw:TatteredMap a sw:Item ;
    rdfs:label "Tattered Map" ;
    sw:quantity 1 ;
    rdfs:comment "A worn map of the local area (flavor item)." .

sw:WizardClass a sw:PlayerClass ;
    rdfs:label "Wizard" .

sw:AldricThorn a sw:Npc ;
    rdfs:label "Aldric Thorn" ;
    sw:hasRole "Merchant; Quest Giver" ;
    rdfs:comment "Survived the ambush. Owner of the stolen gold chest and the family heirloom dagger (the dagger is especially important to him)." .

sw:ElderMira a sw:Npc ;
    rdfs:label "Elder Mira" ;
    sw:hasRole "Village Elder; Quest Authority" ;
    rdfs:comment "Offers a 50 gp reward for recovery of the stolen goods." .

sw:Location_Millhaven a sw:Location ;
    rdfs:label "Millhaven" .

sw:Scene2_HillsideTrail a sw:Scene ;
    rdfs:label "Scene 2: The Hillside Trail" ;
    sw:dc 13 ;
    sw:hasItem sw:Gold_3,
        sw:HealingPotion_S2 ;
    sw:hasLocation sw:Location_HillsideTrail ;
    sw:hasMonster sw:Goblin_Sentry1,
        sw:Goblin_Sentry2 ;
    sw:leadsTo sw:Scene3_GoblinWarren ;
    sw:objectiveText "Reach the cave. Optional: defeat or sneak past the 2 goblin sentries." ;
    sw:sceneDescription "A rocky trail under a half-moon. Goblin tracks in mud; cave entrance marked by a crude post with a skull." .

sw:Scene3_GoblinWarren a sw:Scene ;
    rdfs:label "Scene 3: The Goblin Warren" ;
    sw:dc 12,
        14 ;
    sw:hasItem sw:Chest_GoldChest,
        sw:Gold_12,
        sw:TatteredMap ;
    sw:hasLocation sw:Location_GoblinWarren ;
    sw:hasMonster sw:Goblin_Chamber1,
        sw:Goblin_Chamber2,
        sw:Goblin_Chamber3,
        sw:Goblin_Guard,
        sw:Grix ;
    sw:leadsTo sw:Scene_DeadEnd_Wilderness ;
    sw:objectiveText "Defeat the goblins, retrieve the chest key from Grix, and open the locked chest." ;
    sw:sceneDescription "Torch-lit cave chamber with bedrolls, gnawed bones, scattered stolen goods, and a locked wooden chest against the far wall. A bolted door leads to Grix's chamber." .

