    ns1:prefLabel "Attributes (Datatype Properties)" .

<http://example.org/semantic-web/instance/concept-axioms> a ns1:Concept ;
    ns1:prefLabel "Axioms (Constraints & Rules)" .

<http://example.org/semantic-web/instance/concept-classes> a ns1:Concept ;
    ns1:prefLabel "Classes (Concepts)" .

<http://example.org/semantic-web/instance/concept-enterprise-kg> a ns1:Concept ;
    ns1:prefLabel "Enterprise Knowledge Graphs (EKG)" .

<http://example.org/semantic-web/instance/concept-identifiers> a ns1:Concept ;
    ns1:prefLabel "IRIs / Identifiers" .

<http://example.org/semantic-web/instance/concept-individuals> a ns1:Concept ;
    ns1:prefLabel "Individuals (Instances)" .

<http://example.org/semantic-web/instance/concept-linked-open-data> a ns1:Concept ;
    ns1:prefLabel "Linked Open Data (LOD)" .

<http://example.org/semantic-web/instance/concept-nuna> a ns1:Concept ;
    ns1:prefLabel "Non-Unique Name Assumption (NUNA)" .

<http://example.org/semantic-web/instance/concept-owa> a ns1:Concept ;
    ns1:prefLabel "Open World Assumption (OWA)" .

<http://example.org/semantic-web/instance/concept-owl> a ns1:Concept ;
    ns1:prefLabel "OWL (Ontologies & Description Logics)" .

<http://example.org/semantic-web/instance/concept-rdf> a ns1:Concept ;
    ns1:prefLabel "RDF (Data Model)" .

<http://example.org/semantic-web/instance/concept-rdfs> a ns1:Concept ;
    ns1:prefLabel "RDFS (Schema & Hierarchies)" .

<http://example.org/semantic-web/instance/concept-reasoning> a ns1:Concept ;
    ns1:prefLabel "Semantic Reasoning (classification, consistency checking)" .

<http://example.org/semantic-web/instance/concept-relationships> a ns1:Concept ;
    ns1:prefLabel "Relationships (Object Properties)" .

<http://example.org/semantic-web/instance/concept-schemaorg> a ns1:Concept ;
    ns1:prefLabel "schema.org & Embedded Semantics (JSON-LD)" .

<http://example.org/semantic-web/instance/concept-syntax> a ns1:Concept ;
    ns1:prefLabel "Syntax & Serialization (Turtle, JSON-LD, RDF/XML)" .

<http://example.org/semantic-web/instance/owl2-el> a ns1:Concept ;
    ns1:prefLabel "OWL 2 EL" .

<http://example.org/semantic-web/instance/owl2-ql> a ns1:Concept ;
    ns1:prefLabel "OWL 2 QL" .

<http://example.org/semantic-web/instance/owl2-rl> a ns1:Concept ;
