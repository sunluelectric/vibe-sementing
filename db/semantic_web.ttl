    ns1:name "Uniform Resource Identifier" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/identifier-layer> .

<http://example.org/semantic-web/instance/w3c> a ns1:Organization ;
