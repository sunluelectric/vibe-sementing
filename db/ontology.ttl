@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sw: <http://example.org/semantic-web#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sw:API a rdfs:Class ;
    rdfs:label "API" ;
    rdfs:comment "API type or interface exposed by a triplestore (e.g., REST)." .

sw:Agent a rdfs:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "Actor or agent (person or organization)." ;
    rdfs:subClassOf sw:Resource .

sw:Concept a rdfs:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "A conceptual term suitable for lightweight taxonomies (SKOS-like)." ;
    rdfs:subClassOf sw:Resource .

sw:Dataset a rdfs:Class ;
    rdfs:label "Dataset" ;
    rdfs:comment "A collection of RDF data or resources." ;
    rdfs:subClassOf sw:Resource .

sw:Dish a rdfs:Class ;
    rdfs:label "Dish" ;
    rdfs:comment "A prepared food item or recipe." ;
    rdfs:subClassOf sw:Resource .

sw:Feature a rdfs:Class ;
    rdfs:label "Feature" ;
    rdfs:comment "A named capability or feature of a triplestore." .

sw:FoodItem a rdfs:Class ;
    rdfs:label "FoodItem" ;
    rdfs:comment "An ingredient or food item." ;
    rdfs:subClassOf sw:Resource .

sw:License a rdfs:Class ;
    rdfs:label "License" ;
    rdfs:comment "License resource for software products (e.g., Apache-2.0)." .

sw:Meat a rdfs:Class ;
    rdfs:label "Meat" ;
    rdfs:comment "Animal-based food item." ;
    rdfs:subClassOf sw:FoodItem .

sw:Ontology a rdfs:Class ;
    rdfs:label "Ontology" ;
    rdfs:comment "A schema or ontology document describing classes and properties." ;
    rdfs:subClassOf sw:Dataset .

sw:Person a rdfs:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human person; FOAF-like person concept." ;
    rdfs:subClassOf sw:Agent .

sw:Protocol a rdfs:Class ;
    rdfs:label "Protocol" ;
    rdfs:comment "Network or access protocol (e.g., HTTP, SPARQL Protocol)." .

sw:Resource a rdfs:Class ;
    rdfs:label "Resource" ;
    rdfs:comment "Generic information resource (datasets, documents, software)." .

sw:Software a rdfs:Class ;
    rdfs:label "Software" ;
    rdfs:comment "Software artifact or product." ;
    rdfs:subClassOf sw:Resource .

sw:Triplestore a rdfs:Class ;
    rdfs:label "Triplestore" ;
    rdfs:comment "An RDF database / triplestore product." ;
    rdfs:subClassOf sw:Software .

sw:VegetarianDish a rdfs:Class ;
    rdfs:label "VegetarianDish" ;
    rdfs:comment "A Dish that contains no Meat items (intensional class in OWL examples)." ;
    rdfs:subClassOf sw:Dish .

sw:broader a rdf:Property ;
    rdfs:label "broader" ;
    rdfs:comment "Taxonomy relation between Concepts (SKOS-style broader)." ;
    rdfs:domain sw:Concept ;
    rdfs:range sw:Concept .

sw:createdDate a rdf:Property ;
    rdfs:label "created date" ;
    rdfs:comment "Creation date of the resource." ;
    rdfs:domain sw:Resource ;
    rdfs:range xsd:date .

sw:creator a rdf:Property ;
    rdfs:label "creator" ;
    rdfs:comment "Agent that created a resource." ;
    rdfs:domain sw:Resource ;
    rdfs:range sw:Agent .

sw:exposesAPI a rdf:Property ;
    rdfs:label "exposes API" ;
    rdfs:comment "Link to API nodes that the triplestore exposes." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range sw:API .

sw:featureName a rdf:Property ;
    rdfs:label "feature name" ;
    rdfs:comment "Short textual name for a Feature." ;
    rdfs:domain sw:Feature ;
    rdfs:range xsd:string .

sw:format a rdf:Property ;
    rdfs:label "format" ;
    rdfs:comment "Textual format or media type for a resource (e.g., Turtle)." ;
    rdfs:domain sw:Resource ;
    rdfs:range xsd:string .

sw:hasComponent a rdf:Property ;
    rdfs:label "has component" ;
    rdfs:comment "Alternate predicate for dish components; normalized to hasIngredient." ;
    rdfs:domain sw:Dish ;
    rdfs:range sw:FoodItem ;
    rdfs:subPropertyOf sw:hasIngredient .

sw:hasConcept a rdf:Property ;
    rdfs:label "has concept" ;
    rdfs:comment "Links an Ontology to Concepts it declares." ;
    rdfs:domain sw:Ontology ;
    rdfs:range sw:Concept .

sw:hasFeature a rdf:Property ;
    rdfs:label "has feature" ;
    rdfs:comment "Attach a Feature node describing a capability to a Triplestore." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range sw:Feature .

sw:homepage a rdf:Property ;
    rdfs:label "homepage" ;
    rdfs:comment "Canonical homepage or product URL." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range xsd:anyURI .

sw:isOpenSource a rdf:Property ;
    rdfs:label "is open source" ;
    rdfs:comment "Whether the triplestore product is open-source." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range xsd:boolean .

sw:license a rdf:Property ;
    rdfs:label "license" ;
    rdfs:comment "License of the triplestore product." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range sw:License .

sw:prefLabel a rdf:Property ;
    rdfs:label "preferred label" ;
    rdfs:comment "Human-readable preferred label (convenience property)." ;
    rdfs:domain sw:Resource ;
    rdfs:range xsd:string .

sw:publisher a rdf:Property ;
    rdfs:label "publisher" ;
    rdfs:comment "Agent that published or distributes the resource." ;
    rdfs:domain sw:Resource ;
    rdfs:range sw:Agent .

sw:storageType a rdf:Property ;
    rdfs:label "storage type" ;
    rdfs:comment "Textual description of storage/persistence type (e.g., native, federated)." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range xsd:string .

sw:supportsProtocol a rdf:Property ;
    rdfs:label "supports protocol" ;
    rdfs:comment "Protocol supported by the triplestore (e.g., HTTP)." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range sw:Protocol .

sw:supportsReasoning a rdf:Property ;
    rdfs:label "supports reasoning" ;
    rdfs:comment "Whether the triplestore advertises built-in inference/reasoning support." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range xsd:boolean .

sw:supportsSPARQL a rdf:Property ;
    rdfs:label "supports SPARQL" ;
    rdfs:comment "Whether the triplestore exposes a SPARQL endpoint." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range xsd:boolean .

sw:supportsTransactions a rdf:Property ;
    rdfs:label "supports transactions" ;
    rdfs:comment "Whether the triplestore supports transactional updates." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range xsd:boolean .

sw:vendor a rdf:Property ;
    rdfs:label "vendor" ;
    rdfs:comment "Vendor or organization providing the triplestore." ;
    rdfs:domain sw:Triplestore ;
    rdfs:range xsd:string .

sw:hasIngredient a rdf:Property ;
    rdfs:label "has ingredient" ;
    rdfs:comment "Links a Dish to the FoodItems it contains." ;
    rdfs:domain sw:Dish ;
    rdfs:range sw:FoodItem .

