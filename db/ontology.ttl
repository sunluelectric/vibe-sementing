@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sw: <http://example.org/semantic-web#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sw:Adventure a rdfs:Class ;
    rdfs:label "Adventure" ;
    rdfs:comment "Top-level scenario container: metadata, scenes, rewards and recommendations." .

sw:Character a rdfs:Class ;
    rdfs:label "Character" ;
    rdfs:comment "An abstract actor: players, NPCs and monsters are characters." .

sw:Chest a rdfs:Class ;
    rdfs:label "Chest" ;
    rdfs:comment "A container item that can hold other items (quest chest)." ;
    rdfs:subClassOf sw:Item .

sw:Item a rdfs:Class ;
    rdfs:label "Item" ;
    rdfs:comment "A generic item, loot, or equipment." .

sw:Location a rdfs:Class ;
    rdfs:label "Location" ;
    rdfs:comment "A named place or locale referenced by a scene." .

sw:Monster a rdfs:Class ;
    rdfs:label "Monster" ;
    rdfs:comment "A hostile creature encountered in the adventure." ;
    rdfs:subClassOf sw:Character .

sw:Npc a rdfs:Class ;
    rdfs:label "Npc" ;
    rdfs:comment "Non-player character such as quest-givers or villagers." ;
    rdfs:subClassOf sw:Character .

sw:Player a rdfs:Class ;
    rdfs:label "Player" ;
    rdfs:comment "A player-controlled character." ;
    rdfs:subClassOf sw:Character .

sw:PlayerClass a rdfs:Class ;
    rdfs:label "PlayerClass" ;
    rdfs:comment "A playable class option (e.g. Fighter, Wizard, Rogue)." .

sw:Potion a rdfs:Class ;
    rdfs:label "Potion" ;
    rdfs:comment "A consumable potion such as a Healing Potion." ;
    rdfs:subClassOf sw:Item .

sw:Race a rdfs:Class ;
    rdfs:label "Race" ;
    rdfs:comment "A playable race option (e.g. Human, Elf, Dwarf)." .

sw:Scene a rdfs:Class ;
    rdfs:label "Scene" ;
    rdfs:comment "A self-contained scene in the adventure (e.g. Village Millhaven, Goblin Warren)." .

sw:Weapon a rdfs:Class ;
    rdfs:label "Weapon" ;
    rdfs:comment "A weapon (melee or thrown)." ;
    rdfs:subClassOf sw:Item .

sw:abilityText a rdf:Property ;
    rdfs:label "abilityText" ;
    rdfs:comment "Text describing a special ability or trait (e.g. 'Nimble Escape')." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:string .

sw:armorClass a rdf:Property ;
    rdfs:label "armorClass" ;
    rdfs:comment "Armor Class (AC) as an integer." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:integer .

sw:attackBonus a rdf:Property ;
    rdfs:label "attackBonus" ;
    rdfs:comment "Numeric attack bonus (e.g. +4)." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:integer .

sw:carries a rdf:Property ;
    rdfs:label "carries" ;
    rdfs:comment "Indicates an Item carried by a Character (loot or equipment)." ;
    rdfs:domain sw:Character ;
    rdfs:range sw:Item .

sw:contains a rdf:Property ;
    rdfs:label "contains" ;
    rdfs:comment "Indicates that a chest or container contains an item." ;
    rdfs:domain sw:Chest ;
    rdfs:range sw:Item .

sw:damage a rdf:Property ;
    rdfs:label "damage" ;
    rdfs:comment "Textual damage expression for a weapon or attack (e.g. '1d4+1 piercing')." ;
    rdfs:domain sw:Item ;
    rdfs:range xsd:string .

sw:dc a rdf:Property ;
    rdfs:label "dc" ;
    rdfs:comment "Difficulty Class (DC) for a scene check (e.g. Stealth DC)." ;
    rdfs:domain sw:Scene ;
    rdfs:range xsd:integer .

sw:difficulty a rdf:Property ;
    rdfs:label "difficulty" ;
    rdfs:comment "Textual difficulty label for the adventure (e.g. 'Beginner-friendly')." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:string .

sw:encounters a rdf:Property ;
    rdfs:label "encounters" ;
    rdfs:comment "A flexible link listing characters encountered in a Scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Character .

sw:goldAmount a rdf:Property ;
    rdfs:label "goldAmount" ;
    rdfs:comment "Numeric gold amount for an item or chest contents." ;
    rdfs:domain sw:Item ;
    rdfs:range xsd:decimal .

sw:hasItem a rdf:Property ;
    rdfs:label "hasItem" ;
    rdfs:comment "Items placed or found in a Scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Item .

sw:hasLocation a rdf:Property ;
    rdfs:label "hasLocation" ;
    rdfs:comment "Associates a Scene with a Location." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Location .

sw:hasMonster a rdf:Property ;
    rdfs:label "hasMonster" ;
    rdfs:comment "Names a Monster present in a Scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Monster .

sw:hasNPC a rdf:Property ;
    rdfs:label "hasNPC" ;
    rdfs:comment "Names an NPC present in a Scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Npc .

sw:hasRaceOption a rdf:Property ;
    rdfs:label "hasRaceOption" ;
    rdfs:comment "Player race options offered by the Adventure." ;
    rdfs:domain sw:Adventure ;
    rdfs:range sw:Race .

sw:hasRole a rdf:Property ;
    rdfs:label "hasRole" ;
    rdfs:comment "Short role label for an NPC (e.g. 'Quest Giver', 'Village Elder')." ;
    rdfs:domain sw:Npc ;
    rdfs:range xsd:string .

sw:hasScene a rdf:Property ;
    rdfs:label "hasScene" ;
    rdfs:comment "Links an Adventure to its Scenes." ;
    rdfs:domain sw:Adventure ;
    rdfs:range sw:Scene .

sw:hp a rdf:Property ;
    rdfs:label "hp" ;
    rdfs:comment "Hit points (integer) for characters and monsters." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:integer .

sw:leadsTo a rdf:Property ;
    rdfs:label "leadsTo" ;
    rdfs:comment "Connects a Scene to another Scene via an exit." ;
    rdfs:domain sw:Scene ;
    rdfs:range sw:Scene .

sw:objectiveText a rdf:Property ;
    rdfs:label "objectiveText" ;
    rdfs:comment "Short in-scene objective or goal text." ;
    rdfs:domain sw:Scene ;
    rdfs:range xsd:string .

sw:offersClass a rdf:Property ;
    rdfs:label "offersClass" ;
    rdfs:comment "Player classes offered by the Adventure." ;
    rdfs:domain sw:Adventure ;
    rdfs:range sw:PlayerClass .

sw:partySizeMax a rdf:Property ;
    rdfs:label "partySizeMax" ;
    rdfs:comment "Maximum recommended party size." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:integer .

sw:partySizeMin a rdf:Property ;
    rdfs:label "partySizeMin" ;
    rdfs:comment "Minimum recommended party size." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:integer .

sw:quantity a rdf:Property ;
    rdfs:label "quantity" ;
    rdfs:comment "Integer quantity for stackable items." ;
    rdfs:domain sw:Item ;
    rdfs:range xsd:integer .

sw:recommendedLevel a rdf:Property ;
    rdfs:label "recommendedLevel" ;
    rdfs:comment "Recommended character level for the adventure." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:integer .

sw:rewardAmount a rdf:Property ;
    rdfs:label "rewardAmount" ;
    rdfs:comment "Gold reward amount offered by NPCs or the village for the adventure objective." ;
    rdfs:domain sw:Adventure ;
    rdfs:range xsd:decimal .

sw:sceneDescription a rdf:Property ;
    rdfs:label "sceneDescription" ;
    rdfs:comment "Longer descriptive or DM notes for a scene." ;
    rdfs:domain sw:Scene ;
    rdfs:range xsd:string .

sw:xpValue a rdf:Property ;
    rdfs:label "xpValue" ;
    rdfs:comment "Experience points awarded for defeating a monster or completing an event." ;
    rdfs:domain sw:Character ;
    rdfs:range xsd:integer .

