@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sw: <http://example.org/semantic-web#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sw:API a rdfs:Class ;
    rdfs:label "API" ;
    rdfs:comment "An application programming interface." ;
    rdfs:subClassOf sw:Interface .

sw:ArchitectureLayer a rdfs:Class ;
    rdfs:label "Architecture layer" ;
    rdfs:comment "A conceptual layer in an architecture stack." ;
    rdfs:subClassOf sw:Concept .

sw:Axiom a rdfs:Class ;
    rdfs:label "Axiom" ;
    rdfs:comment "A logical assertion or rule in an ontology." ;
    rdfs:subClassOf sw:OntologyPrimitive .

sw:CardinalityConstraint a rdfs:Class ;
    rdfs:label "Cardinality constraint" ;
    rdfs:comment "A constraint on the number of values allowed for a property." ;
    rdfs:subClassOf sw:Constraint .

sw:CharacterSetStandard a rdfs:Class ;
    rdfs:label "Character set standard" ;
    rdfs:comment "A standard for character encoding, such as Unicode." ;
    rdfs:subClassOf sw:Standard,
        sw:Technology .

sw:ClassRestriction a rdfs:Class ;
    rdfs:label "Class restriction" ;
    rdfs:comment "A restriction imposed on a class using property-based logical conditions." ;
    rdfs:subClassOf sw:Axiom .

sw:ClassificationTask a rdfs:Class ;
    rdfs:label "Classification task" ;
    rdfs:comment "A reasoning task that computes class membership or taxonomy placement." ;
    rdfs:subClassOf sw:ReasoningTask .

sw:Concept a rdfs:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "A broad conceptual entity modeled in this schema." .

sw:ConsistencyCheckingTask a rdfs:Class ;
    rdfs:label "Consistency checking task" ;
    rdfs:comment "A reasoning task that detects logical contradictions." ;
    rdfs:subClassOf sw:ReasoningTask .

sw:Constraint a rdfs:Class ;
    rdfs:label "Constraint" ;
    rdfs:comment "A logical constraint that limits valid interpretations or usage patterns." ;
    rdfs:subClassOf sw:Axiom .

sw:DataModelLayer a rdfs:Class ;
    rdfs:label "Data model layer" ;
    rdfs:comment "The architecture layer concerned with RDF and RDF Schema data modeling." ;
    rdfs:subClassOf sw:ArchitectureLayer .

sw:DataModelTechnology a rdfs:Class ;
    rdfs:label "Data model technology" ;
    rdfs:comment "A data model technology such as RDF or RDFS." ;
    rdfs:subClassOf sw:Technology .

sw:DatabaseManagementSystem a rdfs:Class ;
    rdfs:label "Database management system" ;
    rdfs:comment "A software system for storing and managing data." ;
    rdfs:subClassOf sw:Technology .

sw:DatatypePropertyConcept a rdfs:Class ;
    rdfs:label "Datatype property concept" ;
    rdfs:comment "The ontology primitive representing an attribute that links to literal values." ;
    rdfs:subClassOf sw:OntologyPrimitive .

sw:DeploymentModel a rdfs:Class ;
    rdfs:label "Deployment model" ;
    rdfs:comment "A deployment or operational model for a software system, such as managed service or native component." ;
    rdfs:subClassOf sw:Concept .

sw:DisjointnessAxiom a rdfs:Class ;
    rdfs:label "Disjointness axiom" ;
    rdfs:comment "An axiom stating that two classes do not share individuals." ;
    rdfs:subClassOf sw:Constraint .

sw:Feature a rdfs:Class ;
    rdfs:label "Feature" ;
    rdfs:comment "A notable capability or product feature." ;
    rdfs:subClassOf sw:Concept .

sw:FoundationalOntology a rdfs:Class ;
    rdfs:label "Foundational ontology" ;
    rdfs:comment "A broadly reusable upper-level or foundational ontology or vocabulary." ;
    rdfs:subClassOf sw:Ontology,
        sw:Vocabulary .

sw:IdentifierLayer a rdfs:Class ;
    rdfs:label "Identifier layer" ;
    rdfs:comment "The architecture layer concerned with identifiers such as URI and IRI." ;
    rdfs:subClassOf sw:ArchitectureLayer .

sw:IdentifierScheme a rdfs:Class ;
    rdfs:label "Identifier scheme" ;
    rdfs:comment "A scheme for globally identifying resources, such as URI or IRI." ;
    rdfs:subClassOf sw:Technology .

sw:InformationResource a rdfs:Class ;
    rdfs:label "Information resource" ;
    rdfs:comment "A resource that conveys or structures information, such as a standard, ontology, or vocabulary." ;
    rdfs:subClassOf sw:Concept .

sw:Interface a rdfs:Class ;
    rdfs:label "Interface" ;
    rdfs:comment "A general interaction surface or access mechanism exposed by a software system." ;
    rdfs:subClassOf sw:Technology .

sw:KnowledgeGraph a rdfs:Class ;
    rdfs:label "Knowledge graph" ;
    rdfs:comment "A graph of entities linked by typed relationships." ;
    rdfs:subClassOf sw:KnowledgeOrganizationArtifact .

sw:KnowledgeOrganizationArtifact a rdfs:Class ;
    rdfs:label "Knowledge organization artifact" ;
    rdfs:comment "A structured artifact for organizing or expressing knowledge." ;
    rdfs:subClassOf sw:InformationResource .

sw:LicenseModel a rdfs:Class ;
    rdfs:label "License model" ;
    rdfs:comment "A structured or textual model of software licensing terms." ;
    rdfs:subClassOf sw:Concept .

sw:NonUniqueNameAssumption a rdfs:Class ;
    rdfs:label "Non-Unique Name Assumption" ;
    rdfs:comment "The principle that different identifiers may refer to the same real-world entity." ;
    rdfs:subClassOf sw:SemanticPrinciple .

sw:ObjectPropertyConcept a rdfs:Class ;
    rdfs:label "Object property concept" ;
    rdfs:comment "The ontology primitive representing a relationship between resources." ;
    rdfs:subClassOf sw:OntologyPrimitive .

sw:Ontology a rdfs:Class ;
    rdfs:label "Ontology" ;
    rdfs:comment "A formal, explicit specification of a shared conceptualization." ;
    rdfs:subClassOf sw:KnowledgeOrganizationArtifact .

sw:OntologyClass a rdfs:Class ;
    rdfs:label "Ontology class" ;
    rdfs:comment "The ontology primitive representing a class or concept category." ;
    rdfs:subClassOf sw:OntologyPrimitive .

sw:OntologyIndividual a rdfs:Class ;
    rdfs:label "Ontology individual" ;
    rdfs:comment "The ontology primitive representing a concrete instance or individual." ;
    rdfs:subClassOf sw:OntologyPrimitive .

sw:OntologyLanguage a rdfs:Class ;
    rdfs:label "Ontology language" ;
    rdfs:comment "A language used to define ontologies or semantic structures, such as OWL or SKOS." ;
    rdfs:subClassOf sw:Technology .

sw:OntologyLayer a rdfs:Class ;
    rdfs:label "Ontology layer" ;
    rdfs:comment "The architecture layer concerned with ontologies and schema languages such as OWL and SKOS." ;
    rdfs:subClassOf sw:ArchitectureLayer .

sw:OntologyPrimitive a rdfs:Class ;
    rdfs:label "Ontology primitive" ;
    rdfs:comment "A core building block of an ontology." ;
    rdfs:subClassOf sw:Concept .

sw:OntologyProfile a rdfs:Class ;
    rdfs:label "Ontology profile" ;
    rdfs:comment "A constrained profile of an ontology language, such as an OWL 2 profile." ;
    rdfs:subClassOf sw:Concept .

sw:OpenWorldAssumption a rdfs:Class ;
    rdfs:label "Open World Assumption" ;
    rdfs:comment "The principle that missing information is unknown rather than false." ;
    rdfs:subClassOf sw:SemanticPrinciple .

sw:Organization a rdfs:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "An organization that develops, maintains, publishes, or standardizes a technology or resource." ;
    rdfs:subClassOf sw:Concept .

sw:ProgrammingInterface a rdfs:Class ;
    rdfs:label "Programming interface" ;
    rdfs:comment "A language-specific or native programming interface." ;
    rdfs:subClassOf sw:Interface .

sw:ProofLayer a rdfs:Class ;
    rdfs:label "Proof layer" ;
    rdfs:comment "The architecture layer concerned with proof and justification." ;
    rdfs:subClassOf sw:ArchitectureLayer .

sw:PropertyCharacteristic a rdfs:Class ;
    rdfs:label "Property characteristic" ;
    rdfs:comment "A logical characteristic of a property, such as symmetric, transitive, or functional." ;
    rdfs:subClassOf sw:Axiom .

sw:Protocol a rdfs:Class ;
    rdfs:label "Protocol" ;
    rdfs:comment "A protocol or standards-based interface used for communication or query." ;
    rdfs:subClassOf sw:Interface .

sw:QueryLanguage a rdfs:Class ;
    rdfs:label "Query language" ;
    rdfs:comment "A language used to query structured graph data." ;
    rdfs:subClassOf sw:Technology .

sw:QueryLayer a rdfs:Class ;
    rdfs:label "Query layer" ;
    rdfs:comment "The architecture layer concerned with query languages such as SPARQL." ;
    rdfs:subClassOf sw:ArchitectureLayer .

sw:Reasoner a rdfs:Class ;
    rdfs:label "Reasoner" ;
    rdfs:comment "A reasoning engine used to infer classifications or detect inconsistencies." ;
    rdfs:subClassOf sw:Technology .

sw:ReasoningTask a rdfs:Class ;
    rdfs:label "Reasoning task" ;
    rdfs:comment "A reasoning or inference task performed over semantic data." ;
    rdfs:subClassOf sw:Concept .

sw:RuleLanguage a rdfs:Class ;
    rdfs:label "Rule language" ;
    rdfs:comment "A language used to express logic rules over semantic data." ;
    rdfs:subClassOf sw:Technology .

sw:RulesLayer a rdfs:Class ;
    rdfs:label "Rules layer" ;
    rdfs:comment "The architecture layer concerned with rules and logic languages." ;
    rdfs:subClassOf sw:ArchitectureLayer .

sw:SemanticPrinciple a rdfs:Class ;
    rdfs:label "Semantic principle" ;
    rdfs:comment "A foundational semantic or logical principle used in semantic web modeling." ;
    rdfs:subClassOf sw:Concept .

sw:SemanticWeb a rdfs:Class ;
    rdfs:label "Semantic Web" ;
    rdfs:comment "The web of data paradigm in which machine-understandable semantics are embedded into web resources." ;
    rdfs:subClassOf sw:Concept .

sw:SerializationFormat a rdfs:Class ;
    rdfs:label "Serialization format" ;
    rdfs:comment "A concrete syntax for serializing RDF graphs." ;
    rdfs:subClassOf sw:Technology .

sw:Specialization a rdfs:Class ;
    rdfs:label "Specialization" ;
    rdfs:comment "A specialized focus area, optimization target, or domain emphasis." ;
    rdfs:subClassOf sw:Feature .

sw:Standard a rdfs:Class ;
    rdfs:label "Standard" ;
    rdfs:comment "A formal technical standard or specification." ;
    rdfs:subClassOf sw:InformationResource .

sw:SyntaxLayer a rdfs:Class ;
    rdfs:label "Syntax layer" ;
    rdfs:comment "The architecture layer concerned with concrete serialization syntaxes." ;
    rdfs:subClassOf sw:ArchitectureLayer .

sw:Taxonomy a rdfs:Class ;
    rdfs:label "Taxonomy" ;
    rdfs:comment "A hierarchical classification scheme focused on parent-child or subclass relationships." ;
    rdfs:subClassOf sw:KnowledgeOrganizationArtifact .

sw:Technology a rdfs:Class ;
    rdfs:label "Technology" ;
    rdfs:comment "A technology, language, framework element, or software system in the semantic web ecosystem." ;
    rdfs:subClassOf sw:Concept .

sw:Triplestore a rdfs:Class ;
    rdfs:label "Triplestore" ;
    rdfs:comment "An RDF-oriented database or graph repository platform." ;
    rdfs:subClassOf sw:DatabaseManagementSystem .

sw:TrustLayer a rdfs:Class ;
    rdfs:label "Trust layer" ;
    rdfs:comment "The architecture layer concerned with trust and provenance confidence." ;
    rdfs:subClassOf sw:ArchitectureLayer .

sw:Vocabulary a rdfs:Class ;
    rdfs:label "Vocabulary" ;
    rdfs:comment "A set of named terms used to describe resources and relationships." ;
    rdfs:subClassOf sw:KnowledgeOrganizationArtifact .

sw:WebArchitecture a rdfs:Class ;
    rdfs:label "Web architecture" ;
    rdfs:comment "A layered technical architecture such as the Semantic Web layer cake." ;
    rdfs:subClassOf sw:Concept .

sw:Workbench a rdfs:Class ;
    rdfs:label "Workbench" ;
    rdfs:comment "A graphical or administrative workbench interface." ;
    rdfs:subClassOf sw:Interface .

sw: a owl:Ontology ;
    rdfs:label "Semantic Web and Triplestore Ontology" ;
    rdfs:comment "An RDF/RDFS-first ontology for semantic web concepts, ontology concepts, and a catalog of triplestore systems derived from the project documents and CSV structure." .

sw:contrastsWith a rdf:Property ;
    rdfs:label "contrasts with" ;
    rdfs:comment "Links a concept or artifact to another that it is explicitly contrasted with." ;
    rdfs:domain sw:Concept ;
    rdfs:range sw:Concept .

sw:definesConcept a rdf:Property ;
    rdfs:label "defines concept" ;
    rdfs:comment "Links an ontology or vocabulary to a concept that it defines." ;
    rdfs:domain sw:KnowledgeOrganizationArtifact ;
    rdfs:range sw:Concept .

sw:definesProperty a rdf:Property ;
    rdfs:label "defines property" ;
    rdfs:comment "Links an ontology or vocabulary to a property that it defines." ;
    rdfs:domain sw:KnowledgeOrganizationArtifact ;
    rdfs:range rdf:Property .

sw:description a rdf:Property ;
    rdfs:label "description" ;
    rdfs:comment "A descriptive text value." ;
    rdfs:domain sw:Concept ;
    rdfs:range xsd:string .

sw:enablesTask a rdf:Property ;
    rdfs:label "enables task" ;
    rdfs:comment "Links a technology or concept to a task that it enables or performs." ;
    rdfs:domain sw:Concept ;
    rdfs:range sw:ReasoningTask .

sw:equivalentResource a rdf:Property ;
    rdfs:label "equivalent resource" ;
    rdfs:comment "Links two identifiers or resources that denote the same real-world entity." ;
    rdfs:domain sw:Concept ;
    rdfs:range sw:Concept ;
    rdfs:subPropertyOf owl:sameAs .

sw:extendsTechnology a rdf:Property ;
    rdfs:label "extends technology" ;
    rdfs:comment "Links a technology to another technology that it extends conceptually or functionally." ;
    rdfs:domain sw:Technology ;
    rdfs:range sw:Technology .

sw:featureText a rdf:Property ;
    rdfs:label "feature text" ;
    rdfs:comment "The original textual feature or specialization description from source data." ;
    rdfs:domain sw:Technology ;
    rdfs:range xsd:string .

sw:hasAxiom a rdf:Property ;
    rdfs:label "has axiom" ;
    rdfs:comment "Links an ontology to one of its axioms." ;
    rdfs:domain sw:Ontology ;
    rdfs:range sw:Axiom .

sw:hasDeploymentModel a rdf:Property ;
    rdfs:label "has deployment model" ;
    rdfs:comment "Links a software system to a deployment model." ;
    rdfs:domain sw:Technology ;
    rdfs:range sw:DeploymentModel .

sw:hasLayer a rdf:Property ;
    rdfs:label "has layer" ;
    rdfs:comment "Links an architecture to one of its conceptual layers." ;
    rdfs:domain sw:WebArchitecture ;
    rdfs:range sw:ArchitectureLayer .

sw:hasLicenseModel a rdf:Property ;
    rdfs:label "has license model" ;
    rdfs:comment "Links a triplestore or software system to a structured license model resource." ;
    rdfs:domain sw:Technology ;
    rdfs:range sw:LicenseModel .

sw:hasPrimitive a rdf:Property ;
    rdfs:label "has primitive" ;
    rdfs:comment "Links an ontology to one of its primitives." ;
    rdfs:domain sw:Ontology ;
    rdfs:range sw:OntologyPrimitive .

sw:hasProfile a rdf:Property ;
    rdfs:label "has profile" ;
    rdfs:comment "Links an ontology language to a profile." ;
    rdfs:domain sw:OntologyLanguage ;
    rdfs:range sw:OntologyProfile .

sw:hasSpecialization a rdf:Property ;
    rdfs:label "has specialization" ;
    rdfs:comment "Links a technology or system to a specialization." ;
    rdfs:domain sw:Technology ;
    rdfs:range sw:Specialization ;
    rdfs:subPropertyOf sw:hasFeature .

sw:identifier a rdf:Property ;
    rdfs:label "identifier" ;
    rdfs:comment "An identifier, code, or local key expressed as text." ;
    rdfs:domain sw:Concept ;
    rdfs:range xsd:string .

sw:isCommercial a rdf:Property ;
    rdfs:label "is commercial" ;
    rdfs:comment "Boolean convenience flag indicating whether a system has a commercial licensing component." ;
    rdfs:domain sw:Technology ;
    rdfs:range xsd:boolean .

sw:isDeveloperOf a rdf:Property ;
    rdfs:label "is developer of" ;
    rdfs:comment "Inverse of developed by." ;
    rdfs:domain sw:Organization ;
    rdfs:range sw:Concept ;
    owl:inverseOf sw:developedBy .

sw:isMaintainerOf a rdf:Property ;
    rdfs:label "is maintainer of" ;
    rdfs:comment "Inverse of maintained by." ;
    rdfs:domain sw:Organization ;
    rdfs:range sw:Concept ;
    owl:inverseOf sw:maintainedBy .

sw:isOpenSource a rdf:Property ;
    rdfs:label "is open source" ;
    rdfs:comment "Boolean convenience flag indicating whether a system has an open-source licensing component." ;
    rdfs:domain sw:Technology ;
    rdfs:range xsd:boolean .

sw:layerUsesTechnology a rdf:Property ;
    rdfs:label "layer uses technology" ;
    rdfs:comment "Links an architecture layer to a technology associated with that layer." ;
    rdfs:domain sw:ArchitectureLayer ;
    rdfs:range sw:Technology .

sw:licenseText a rdf:Property ;
    rdfs:label "license text" ;
    rdfs:comment "The original textual license description from source data." ;
    rdfs:domain sw:Technology ;
    rdfs:range xsd:string .

sw:name a rdf:Property ;
    rdfs:label "name" ;
    rdfs:comment "A human-readable name." ;
    rdfs:domain sw:Concept ;
    rdfs:range xsd:string .

sw:offersAPI a rdf:Property ;
    rdfs:label "offers API" ;
    rdfs:comment "Links a software system to an API it offers." ;
    rdfs:domain sw:Technology ;
    rdfs:range sw:API ;
    rdfs:subPropertyOf sw:offersInterface .

sw:offersProtocol a rdf:Property ;
    rdfs:label "offers protocol" ;
    rdfs:comment "Links a software system to a protocol interface it offers." ;
    rdfs:domain sw:Technology ;
    rdfs:range sw:Protocol ;
    rdfs:subPropertyOf sw:offersInterface .

sw:offersWorkbench a rdf:Property ;
    rdfs:label "offers workbench" ;
    rdfs:comment "Links a software system to a workbench-style interface it offers." ;
    rdfs:domain sw:Technology ;
    rdfs:range sw:Workbench ;
    rdfs:subPropertyOf sw:offersInterface .

sw:primaryInterfaceText a rdf:Property ;
    rdfs:label "primary interface text" ;
    rdfs:comment "The original textual API/interface description from source data." ;
    rdfs:domain sw:Technology ;
    rdfs:range xsd:string .

sw:publishedBy a rdf:Property ;
    rdfs:label "published by" ;
    rdfs:comment "Links a standard, ontology, or vocabulary to its publisher or standards body." ;
    rdfs:domain sw:InformationResource ;
    rdfs:range sw:Organization .

sw:queriesWith a rdf:Property ;
    rdfs:label "queries with" ;
    rdfs:comment "Links a graph, repository, or technology to a query language." ;
    rdfs:domain sw:Concept ;
    rdfs:range sw:QueryLanguage .

sw:serializedAs a rdf:Property ;
    rdfs:label "serialized as" ;
    rdfs:comment "Links a resource or data model to a serialization format used to express it." ;
    rdfs:domain sw:Concept ;
    rdfs:range sw:SerializationFormat .

sw:supportsPrinciple a rdf:Property ;
    rdfs:label "supports principle" ;
    rdfs:comment "Links a semantic web resource or technology to a semantic principle it relies on or reflects." ;
    rdfs:domain sw:Concept ;
    rdfs:range sw:SemanticPrinciple .

sw:usedFor a rdf:Property ;
    rdfs:label "used for" ;
    rdfs:comment "Links a resource to a textual statement of its purpose or use case." ;
    rdfs:domain sw:Concept ;
    rdfs:range xsd:string .

sw:developedBy a rdf:Property ;
    rdfs:label "developed by" ;
    rdfs:comment "Links a technology or resource to its developer." ;
    rdfs:domain sw:Concept ;
    rdfs:range sw:Organization .

sw:hasFeature a rdf:Property ;
    rdfs:label "has feature" ;
    rdfs:comment "Links a technology or system to a feature." ;
    rdfs:domain sw:Technology ;
    rdfs:range sw:Feature .

sw:maintainedBy a rdf:Property ;
    rdfs:label "maintained by" ;
    rdfs:comment "Links a technology or resource to its maintainer." ;
    rdfs:domain sw:Concept ;
    rdfs:range sw:Organization .

sw:offersInterface a rdf:Property ;
    rdfs:label "offers interface" ;
    rdfs:comment "Links a software system to an interface it offers." ;
    rdfs:domain sw:Technology ;
    rdfs:range sw:Interface .

