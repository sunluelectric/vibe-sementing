@prefix dnd: <http://example.org/dnd-adventure#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dnd:Adventure a rdfs:Class ;
    rdfs:label "Adventure" ;
    rdfs:comment "Top-level container for an adventure composed of quests and scenes." .

dnd:Character a rdfs:Class ;
    rdfs:label "Character" ;
    rdfs:comment "Any character-like agent in the adventure (players, NPCs, monsters)." .

dnd:Check a rdfs:Class ;
    rdfs:label "Check" ;
    rdfs:comment "A mechanical skill or ability check (DC and type)." .

dnd:Encounter a rdfs:Class ;
    rdfs:label "Encounter" ;
    rdfs:comment "A conflict or challenge that occurs within a scene; links to participants." .

dnd:Item a rdfs:Class ;
    rdfs:label "Item" ;
    rdfs:comment "Tangible object such as loot, potions, chests, equipment." .

dnd:Location a rdfs:Class ;
    rdfs:label "Location" ;
    rdfs:comment "A physical or descriptive place such as a village, trail, or cave chamber." .

dnd:Monster a rdfs:Class ;
    rdfs:label "Monster" ;
    rdfs:comment "A hostile creature or adversary (goblins, bosses)." ;
    rdfs:subClassOf dnd:Character .

dnd:Npc a rdfs:Class ;
    rdfs:label "Non-Player Character" ;
    rdfs:comment "A non-player character such as a quest giver or villager." ;
    rdfs:subClassOf dnd:Character .

dnd:Player a rdfs:Class ;
    rdfs:label "Player" ;
    rdfs:comment "A player-controlled character; subclassing is kept flat to ease data ingestion." .

dnd:PlayerOption a rdfs:Class ;
    rdfs:label "Player Option" ;
    rdfs:comment "A selectable option for players (character class, race)." .

dnd:Quest a rdfs:Class ;
    rdfs:label "Quest" ;
    rdfs:comment "A goal-driven task inside an adventure (for example: recover stolen goods)." .

dnd:Reward a rdfs:Class ;
    rdfs:label "Reward" ;
    rdfs:comment "A reward object for quests or NPC offers (gold, items, XP)." .

dnd:Scene a rdfs:Class ;
    rdfs:label "Scene" ;
    rdfs:comment "A narrated location or encounter node; scenes have descriptions, exits and encounters." .

dnd:VictoryCondition a rdfs:Class ;
    rdfs:label "Victory Condition" ;
    rdfs:comment "A textual condition describing success for a quest or objective." .

dnd:Weapon a rdfs:Class ;
    rdfs:label "Weapon" ;
    rdfs:comment "A weapon used for attacks; modeled as a kind of Item." ;
    rdfs:subClassOf dnd:Item .

dnd:armorClass a rdf:Property ;
    rdfs:label "armor class" ;
    rdfs:comment "Armor Class (AC) value for a character or monster." ;
    rdfs:domain dnd:Character ;
    rdfs:range xsd:nonNegativeInteger .

dnd:carries a rdf:Property ;
    rdfs:label "carries" ;
    rdfs:comment "States that a Character carries or possesses an Item." ;
    rdfs:domain dnd:Character ;
    rdfs:range dnd:Item .

dnd:checkDC a rdf:Property ;
    rdfs:label "check DC" ;
    rdfs:comment "Numeric difficulty class (DC) for a Check." ;
    rdfs:domain dnd:Check ;
    rdfs:range xsd:nonNegativeInteger .

dnd:checkType a rdf:Property ;
    rdfs:label "check type" ;
    rdfs:comment "Skill or ability type for a Check (e.g., 'Dexterity/Stealth')." ;
    rdfs:domain dnd:Check ;
    rdfs:range xsd:string .

dnd:conditionDescription a rdf:Property ;
    rdfs:label "condition description" ;
    rdfs:comment "Text describing a victory condition for a quest." ;
    rdfs:domain dnd:VictoryCondition ;
    rdfs:range xsd:string .

dnd:damage a rdf:Property ;
    rdfs:label "damage" ;
    rdfs:comment "Damage expression for weapons, stored as text (e.g. '1d4+1 piercing')." ;
    rdfs:domain dnd:Weapon ;
    rdfs:range xsd:string .

dnd:description a rdf:Property ;
    rdfs:label "description" ;
    rdfs:comment "Longer textual description for scenes, items, locations, etc." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:string .

dnd:difficultyLevel a rdf:Property ;
    rdfs:label "difficulty level" ;
    rdfs:comment "Textual difficulty (Beginner-friendly, etc.)." ;
    rdfs:domain dnd:Quest ;
    rdfs:range xsd:string .

dnd:exitTo a rdf:Property ;
    rdfs:label "exit to" ;
    rdfs:comment "Scene-to-scene navigation; an exit leads from one Scene to another." ;
    rdfs:domain dnd:Scene ;
    rdfs:range dnd:Scene .

dnd:goldAmount a rdf:Property ;
    rdfs:label "gold amount" ;
    rdfs:comment "Amount of gold coins in a Reward." ;
    rdfs:domain dnd:Reward ;
    rdfs:range xsd:nonNegativeInteger .

dnd:hasEncounter a rdf:Property ;
    rdfs:label "has encounter" ;
    rdfs:comment "Links a Scene to an Encounter that occurs in it." ;
    rdfs:domain dnd:Scene ;
    rdfs:range dnd:Encounter .

dnd:hasObjective a rdf:Property ;
    rdfs:label "has objective" ;
    rdfs:comment "Short textual description of the quest objective." ;
    rdfs:domain dnd:Quest ;
    rdfs:range xsd:string .

dnd:hasQuest a rdf:Property ;
    rdfs:label "has quest" ;
    rdfs:comment "Links an Adventure to a Quest it contains." ;
    rdfs:domain dnd:Adventure ;
    rdfs:range dnd:Quest .

dnd:hasReward a rdf:Property ;
    rdfs:label "has reward" ;
    rdfs:comment "Associates a Quest with its Reward (gold, items, XP)." ;
    rdfs:domain dnd:Quest ;
    rdfs:range dnd:Reward .

dnd:hasScene a rdf:Property ;
    rdfs:label "has scene" ;
    rdfs:comment "Associates an Adventure with Scenes that belong to it." ;
    rdfs:domain dnd:Adventure ;
    rdfs:range dnd:Scene .

dnd:hp a rdf:Property ;
    rdfs:label "hit points" ;
    rdfs:comment "Hit points of a character or monster." ;
    rdfs:domain dnd:Character ;
    rdfs:range xsd:nonNegativeInteger .

dnd:includesItem a rdf:Property ;
    rdfs:label "includes item" ;
    rdfs:comment "A Reward may include zero or more Items." ;
    rdfs:domain dnd:Reward ;
    rdfs:range dnd:Item .

dnd:itemProperty a rdf:Property ;
    rdfs:label "item property" ;
    rdfs:comment "Short string listing item properties (e.g., 'Finesse, Light, Thrown')." ;
    rdfs:domain dnd:Item ;
    rdfs:range xsd:string .

dnd:itemType a rdf:Property ;
    rdfs:label "item type" ;
    rdfs:comment "Category or type label for an item (e.g., 'Healing Potion', 'Simple Melee Weapon')." ;
    rdfs:domain dnd:Item ;
    rdfs:range xsd:string .

dnd:locatedIn a rdf:Property ;
    rdfs:label "located in" ;
    rdfs:comment "Links a Scene to the Location where it takes place." ;
    rdfs:domain dnd:Scene ;
    rdfs:range dnd:Location .

dnd:name a rdf:Property ;
    rdfs:label "name" ;
    rdfs:comment "General name used for characters, items, scenes and other resources." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:string .

dnd:personality a rdf:Property ;
    rdfs:label "personality" ;
    rdfs:comment "Short personality notes for an NPC (e.g., 'nervous, grateful')." ;
    rdfs:domain dnd:Character ;
    rdfs:range xsd:string .

dnd:recommendedLevel a rdf:Property ;
    rdfs:label "recommended level" ;
    rdfs:comment "Numeric recommended character level for the quest." ;
    rdfs:domain dnd:Quest ;
    rdfs:range xsd:nonNegativeInteger .

dnd:recommendedPartySize a rdf:Property ;
    rdfs:label "recommended party size" ;
    rdfs:comment "Human-readable recommended party size, e.g. '2–4'." ;
    rdfs:domain dnd:Quest ;
    rdfs:range xsd:string .

dnd:rewardXP a rdf:Property ;
    rdfs:label "reward XP" ;
    rdfs:comment "Experience points granted as a reward." ;
    rdfs:domain dnd:Reward ;
    rdfs:range xsd:nonNegativeInteger .

dnd:role a rdf:Property ;
    rdfs:label "role" ;
    rdfs:comment "Character role (e.g., 'Merchant', 'Quest Giver')." ;
    rdfs:domain dnd:Character ;
    rdfs:range xsd:string .

dnd:victoryCondition a rdf:Property ;
    rdfs:label "victory condition" ;
    rdfs:comment "Links a Quest to one of its victory conditions." ;
    rdfs:domain dnd:Quest ;
    rdfs:range dnd:VictoryCondition .

dnd:xpValue a rdf:Property ;
    rdfs:label "XP value" ;
    rdfs:comment "Experience points awarded for defeating a creature." ;
    rdfs:domain dnd:Character ;
    rdfs:range xsd:nonNegativeInteger .

