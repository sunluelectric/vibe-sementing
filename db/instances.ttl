    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-1-1-rdf4j-graphdb-workbench> .

<http://example.org/semantic-web/instance/triplestore/marklogic> a ns1:Triplestore ;
    rdfs:label "MarkLogic" ;
    ns1:developerMaintainerName "Progress Software"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/multi-model-nosql-database-integrating-xml> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/progress-software> ;
    ns1:keyFeaturesText "Multi-model NoSQL database integrating XML"^^xsd:string ;
    ns1:licenseTypeText "Commercial"^^xsd:string ;
    ns1:name "MarkLogic"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL 1.1 / REST / Java / Node.js"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-1-1-rest-java-node-js> .

<http://example.org/semantic-web/instance/triplestore/oracle-spatial-and-graph> a ns1:Triplestore ;
    rdfs:label "Oracle Spatial and Graph" ;
    ns1:developerMaintainerName "Oracle"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/enterprise-rdf-semantic-graph-support-built-natively-into-oracle-database> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial> ;
