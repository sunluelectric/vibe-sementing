@prefix ns1: <http://example.org/semantic-web#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:bfo a ns1:FoundationalOntology ;
    rdfs:label "BFO" ;
    ns1:description "A domain-neutral upper-level ontology used as a structural foundation so different sub-ontologies can interoperate." ;
    ns1:name "Basic Formal Ontology" .

ns1:dbpedia a ns1:Dataset,
        ns1:KnowledgeGraph ;
    rdfs:label "DBpedia" ;
    ns1:description "The structured RDF counterpart of Wikipedia and a central hub in Linked Open Data." ;
    ns1:implementsDataModel ns1:rdf ;
    ns1:name "DBpedia" ;
    ns1:usesIdentifierScheme ns1:iri .

ns1:dublin-core a ns1:Vocabulary ;
    rdfs:label "Dublin Core" ;
    ns1:description "A standard vocabulary for describing digital and physical resources." ;
    ns1:name "Dublin Core" .

ns1:enterprise-knowledge-graphs a ns1:KnowledgeGraph ;
    rdfs:label "Enterprise Knowledge Graphs" ;
    ns1:description "Internal knowledge graphs built by enterprises using RDF and OWL to integrate data from legacy systems without disruptive database migrations." ;
    ns1:implementsDataModel ns1:rdf ;
    ns1:name "Enterprise Knowledge Graphs" ;
    ns1:usesTechnology ns1:owl .

ns1:foaf a ns1:FoundationalOntology,
        ns1:Vocabulary ;
    rdfs:label "FOAF" ;
    ns1:description "A vocabulary used for describing people, their attributes, and their social networks." ;
    ns1:name "Friend of a Friend" .

ns1:gene-ontology a ns1:Ontology ;
    rdfs:label "Gene Ontology" ;
    ns1:description "A large domain ontology standardizing the representation of gene and protein functions across biology." ;
    ns1:name "Gene Ontology" .

ns1:hermit a ns1:Reasoner ;
    rdfs:label "HermiT" ;
    ns1:name "HermiT" ;
    ns1:performsInferenceTask ns1:classification-task,
        ns1:consistency-checking-task ;
    ns1:supportsReasoningCapability ns1:reasoner-capability .

ns1:knowledge-graph-concept a ns1:KnowledgeGraph ;
    rdfs:label "Knowledge Graph" ;
    ns1:describesDomain ns1:web-of-data ;
    ns1:description "A network of real-world entities connected by relationships that represents actual data instance networks." ;
    ns1:name "Knowledge Graph" .

ns1:linked-open-data a ns1:Community ;
    rdfs:label "Linked Open Data" ;
    ns1:description "A global movement to publish structured data so that it can be interlinked." ;
    ns1:name "Linked Open Data" .

ns1:ontology-concept a ns1:Ontology ;
    rdfs:label "Ontology" ;
    ns1:definesConcept ns1:attributes-concept,
        ns1:axioms-concept,
        ns1:classes-concept,
        ns1:constraints-topic,
        ns1:individuals-concept,
        ns1:relationships-concept ;
    ns1:describesDomain ns1:ontology-components-topic ;
    ns1:description "A formal, explicit specification of a shared conceptualization." ;
    ns1:developedBy ns1:thomas-r-gruber ;
    ns1:name "Ontology" .

ns1:openllet a ns1:Reasoner ;
    rdfs:label "Openllet" ;
    ns1:name "Openllet" ;
    ns1:performsInferenceTask ns1:classification-task,
        ns1:consistency-checking-task ;
    ns1:supportsReasoningCapability ns1:reasoner-capability .

ns1:pellet a ns1:Reasoner ;
    rdfs:label "Pellet" ;
    ns1:name "Pellet" ;
    ns1:performsInferenceTask ns1:classification-task,
        ns1:consistency-checking-task ;
    ns1:supportsReasoningCapability ns1:reasoner-capability .

ns1:schema-org a ns1:Vocabulary ;
    rdfs:label "Schema.org" ;
    ns1:description "A collaborative initiative whose vocabularies are embedded into HTML using JSON-LD or Microdata to structure data for search engine knowledge graphs." ;
    ns1:name "Schema.org" .

ns1:semantic-web a ns1:KnowledgeGraph ;
    rdfs:label "Semantic Web" ;
    ns1:description "An evolutionary extension of the World Wide Web that seeks to transform the web into a universal medium for data, information, and knowledge exchange by embedding explicit, machine-understandable semantics into web resources." ;
    ns1:developedBy ns1:tim-berners-lee ;
    ns1:followsPrinciple ns1:non-unique-name-assumption,
        ns1:open-world-assumption ;
    ns1:name "Semantic Web" ;
    ns1:publishedBy ns1:w3c .

ns1:taxonomy-concept a ns1:Taxonomy ;
    rdfs:label "Taxonomy" ;
    ns1:describesDomain ns1:ontology-components-topic ;
    ns1:description "A narrow hierarchical classification scheme that understands tree-like parental structures and contains no advanced properties or logic." ;
    ns1:name "Taxonomy" .

ns1:web-of-documents a ns1:ConceptualTopic ;
    rdfs:label "Web of Documents" ;
    ns1:description "The traditional World Wide Web architecture of unstructured and semi-structured documents designed for human consumption." ;
    ns1:name "Web of Documents" .

ns1:wikidata a ns1:Dataset,
        ns1:KnowledgeGraph ;
    rdfs:label "Wikidata" ;
    ns1:description "A central hub connecting many open datasets in the Linked Open Data ecosystem." ;
    ns1:name "Wikidata" ;
    ns1:usesIdentifierScheme ns1:iri .

<http://example.org/semantic-web/instance/triplestore/allegrograph> a ns1:Triplestore ;
    rdfs:label "AllegroGraph" ;
    ns1:developerMaintainerName "Franz Inc."^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/document-graph-database-with-advanced-temporal> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/franz-inc> ;
    ns1:keyFeaturesText "Document-Graph database with advanced temporal"^^xsd:string ;
    ns1:licenseTypeText "Commercial"^^xsd:string ;
    ns1:name "AllegroGraph"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL 1.1 / Python / Java / Lisp"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-1-1-python-java-lisp> .

<http://example.org/semantic-web/instance/triplestore/amazon-neptune> a ns1:Triplestore ;
    rdfs:label "Amazon Neptune" ;
    ns1:developerMaintainerName "Amazon Web Services (AWS)"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/fully-managed-cloud-database> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial-managed-service> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/amazon-web-services-aws> ;
    ns1:keyFeaturesText "Fully managed cloud database"^^xsd:string ;
    ns1:licenseTypeText "Commercial (Managed Service)"^^xsd:string ;
    ns1:name "Amazon Neptune"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL / Apache TinkerPop Gremlin / openCypher"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-apache-tinkerpop-gremlin-opencypher> .

<http://example.org/semantic-web/instance/triplestore/anzograph> a ns1:Triplestore ;
    rdfs:label "AnzoGraph" ;
    ns1:developerMaintainerName "Cambridge Semantics"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/massively-parallel-processing-mpp-native-graph-database-designed-for-distributed-analytics> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/cambridge-semantics> ;
    ns1:keyFeaturesText "Massively Parallel Processing (MPP) native graph database designed for distributed analytics."^^xsd:string ;
    ns1:licenseTypeText "Commercial"^^xsd:string ;
    ns1:name "AnzoGraph"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL 1.1 / Cypher / C++ API"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-1-1-cypher-c-api> .

<http://example.org/semantic-web/instance/triplestore/apache-jena-tdb> a ns1:Triplestore ;
    rdfs:label "Apache Jena TDB" ;
    ns1:developerMaintainerName "Apache Software Foundation"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/component-of-the-apache-jena-framework-a-native> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/open-source-apache-2-0> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/apache-software-foundation> ;
    ns1:keyFeaturesText "Component of the Apache Jena framework; a native"^^xsd:string ;
    ns1:licenseTypeText "Open Source (Apache 2.0)"^^xsd:string ;
    ns1:name "Apache Jena TDB"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL 1.1 / Native Jena API"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-1-1-native-jena-api> .

<http://example.org/semantic-web/instance/triplestore/blazegraph> a ns1:Triplestore ;
    rdfs:label "Blazegraph" ;
    ns1:developerMaintainerName "Systap (acquired by Amazon)"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/high-performance-graph-database-historically-powered-wikidata-query-service> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/open-source-gplv3-commercial> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/systap-acquired-by-amazon> ;
    ns1:keyFeaturesText "High-performance graph database (historically powered Wikidata Query Service)."^^xsd:string ;
    ns1:licenseTypeText "Open Source (GPLv3) / Commercial"^^xsd:string ;
    ns1:name "Blazegraph"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL 1.1 / Blueprint / RDF4J"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-1-1-blueprint-rdf4j> .

<http://example.org/semantic-web/instance/triplestore/graphdb> a ns1:Triplestore ;
    rdfs:label "GraphDB" ;
    ns1:developerMaintainerName "Ontotext"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/advanced-rdf-owl-reasoning> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial-free-edition> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/ontotext> ;
    ns1:keyFeaturesText "Advanced RDF/OWL reasoning"^^xsd:string ;
