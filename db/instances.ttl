    ns1:keyFeaturesText "Enterprise RDF semantic graph support built natively into Oracle Database."^^xsd:string ;
    ns1:licenseTypeText "Commercial"^^xsd:string ;
    ns1:name "Oracle Spatial and Graph"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL 1.1 / SQL / Property Graph"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-1-1-sql-property-graph> .

<http://example.org/semantic-web/instance/triplestore/rdf4j-formerly-sesame> a ns1:Triplestore ;
    rdfs:label "RDF4J (formerly Sesame)" ;
    ns1:developerMaintainerName "Eclipse Foundation"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/java-framework-for-processing-rdf-data-that-includes-an-in-memory-and-disk-based-triplestore> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/open-source-edl> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/eclipse-foundation> ;
    ns1:keyFeaturesText "Java framework for processing RDF data that includes an in-memory and disk-based triplestore."^^xsd:string ;
    ns1:licenseTypeText "Open Source (EDL)"^^xsd:string ;
    ns1:name "RDF4J (formerly Sesame)"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL 1.1 / RDF4J API"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-1-1-rdf4j-api> .

<http://example.org/semantic-web/instance/triplestore/stardog> a ns1:Triplestore ;
    rdfs:label "Stardog" ;
    ns1:developerMaintainerName "Stardog Union"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/enterprise-knowledge-graph-platform-with-virtual-graphs-data-virtualization-and-logic-reasoning> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/stardog-union> ;
    ns1:keyFeaturesText "Enterprise knowledge graph platform with virtual graphs (data virtualization) and logic reasoning."^^xsd:string ;
    ns1:licenseTypeText "Commercial"^^xsd:string ;
    ns1:name "Stardog"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL 1.1 / GraphQL / Java API"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-1-1-graphql-java-api> .

<http://example.org/semantic-web/instance/triplestore/virtuoso> a ns1:Triplestore ;
    rdfs:label "Virtuoso" ;
    ns1:developerMaintainerName "OpenLink Software"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/hybrid-relational-rdf-engine> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/open-source-gplv2-commercial> ;
    ns1:hasMaintainer <http://example.org/semantic-web/instance/organization/openlink-software> ;
    ns1:keyFeaturesText "Hybrid relational/RDF engine"^^xsd:string ;
    ns1:licenseTypeText "Open Source (GPLv2) / Commercial"^^xsd:string ;
    ns1:name "Virtuoso"^^xsd:string ;
    ns1:primaryAPIInterfacesText "SPARQL / SQL / ODBC / JDBC"^^xsd:string ;
    ns1:supportsInterface <http://example.org/semantic-web/instance/api-interface/sparql-sql-odbc-jdbc> .

ns1:attributes-concept a ns1:AttributeProperty ;
    rdfs:label "Attributes" ;
    ns1:description "Datatype properties that describe characteristics, features, or data values associated with a class or individual." ;
    ns1:name "Attributes" .

ns1:axioms-concept a ns1:Axiom ;
    rdfs:label "Axioms" ;
    ns1:description "Explicit logical assertions that are always true within an ontology and that constrain the model and support reasoning." ;
    ns1:name "Axioms" .

ns1:classes-concept a ns1:ClassConcept ;
    rdfs:label "Classes" ;
    ns1:description "Abstract concepts or categories that exist within a domain and are typically organized into hierarchies." ;
    ns1:name "Classes" .

ns1:constraints-topic a ns1:Constraint ;
    rdfs:label "Constraints and Rules" ;
    ns1:description "Restrictions and logical rules used to limit modeling choices, define domain boundaries, and support reasoning." ;
    ns1:name "Constraints and Rules" .

ns1:individuals-concept a ns1:Individual ;
    rdfs:label "Individuals" ;
    ns1:description "Actual concrete real-world objects that belong to a specific class." ;
    ns1:name "Individuals" .

ns1:json-ld a ns1:Language,
        ns1:SerializationFormat ;
    rdfs:label "JSON-LD" ;
    ns1:description "A JSON-based format for linking data and embedding semantic data into standard JSON structures." ;
    ns1:name "JSON-LD" .

ns1:non-unique-name-assumption a ns1:NonUniqueNameAssumption ;
    rdfs:label "Non-Unique Name Assumption" ;
    ns1:description "The assumption that two different identifiers can refer to the same real-world entity unless asserted otherwise." ;
    ns1:name "Non-Unique Name Assumption" .

ns1:open-world-assumption a ns1:OpenWorldAssumption ;
    rdfs:label "Open World Assumption" ;
    ns1:description "The assumption that missing information is treated as unknown rather than false." ;
    ns1:name "Open World Assumption" .

ns1:owl-2-el a ns1:OWL2ELProfile ;
    rdfs:label "OWL 2 EL" ;
    ns1:description "A profile of OWL 2 tailored for domains with massive numbers of classes and complex subclass hierarchies, supporting polynomial-time reasoning." ;
    ns1:name "OWL 2 EL" .

ns1:owl-2-ql a ns1:OWL2QLProfile ;
    rdfs:label "OWL 2 QL" ;
    ns1:description "A profile of OWL 2 designed for query answering and smooth integration with relational databases through translation to SQL." ;
    ns1:name "OWL 2 QL" .

ns1:owl-2-rl a ns1:OWL2RLProfile ;
    rdfs:label "OWL 2 RL" ;
    ns1:description "A profile of OWL 2 optimized for scalable rule-based reasoning using forward-chaining or backward-chaining rule platforms." ;
    ns1:name "OWL 2 RL" .

ns1:rdf-xml a ns1:Language,
        ns1:SerializationFormat ;
    rdfs:label "RDF/XML" ;
    ns1:description "The historical XML-based RDF serialization format." ;
    ns1:name "RDF/XML" .

ns1:rdfs a ns1:DataModel,
        ns1:Standard ;
    rdfs:label "RDFS" ;
    ns1:description "A foundational vocabulary for creating basic hierarchies and constraints such as class, subclass, domain, and range." ;
    ns1:name "RDF Schema" ;
    ns1:publishedBy ns1:w3c .

ns1:relationships-concept a ns1:RelationshipProperty ;
    rdfs:label "Relationships" ;
    ns1:description "Object properties that define how classes and individuals interact with or relate to one another." ;
    ns1:name "Relationships" .

ns1:rif a ns1:Language,
        ns1:RuleLanguage ;
    rdfs:label "RIF" ;
    ns1:description "A rule language used in the upper Semantic Web layers for combining ontologies with rule-based logic." ;
    ns1:name "RIF" .

ns1:skos a ns1:Language,
        ns1:OntologyLanguage ;
    rdfs:label "SKOS" ;
    ns1:description "A language used to represent basic thesauri, taxonomies, and classification schemes that do not require full Description Logics." ;
    ns1:name "Simple Knowledge Organization System" .

ns1:sparql a ns1:Language,
        ns1:QueryLanguage,
        ns1:Standard ;
    rdfs:label "SPARQL" ;
    ns1:description "The query language for the Semantic Web that executes graph-pattern matching against RDF graphs and can span federated endpoints." ;
    ns1:name "SPARQL" ;
    ns1:publishedBy ns1:w3c .

ns1:swrl a ns1:Language,
        ns1:RuleLanguage ;
    rdfs:label "SWRL" ;
    ns1:description "A rule language used for expressing Horn-clause style rules with ontologies." ;
    ns1:name "SWRL" .

ns1:thomas-r-gruber a ns1:Person ;
    rdfs:label "Thomas R. Gruber" ;
    ns1:name "Thomas R. Gruber" .

ns1:tim-berners-lee a ns1:Person ;
    rdfs:label "Tim Berners-Lee" ;
    ns1:name "Tim Berners-Lee" .

ns1:turtle a ns1:Language,
        ns1:SerializationFormat ;
    rdfs:label "Turtle" ;
    ns1:description "A compact, human-readable RDF serialization format." ;
    ns1:name "Turtle" .

ns1:uri a ns1:IdentifierScheme ;
    rdfs:label "URI" ;
    ns1:name "URI" .

ns1:web-of-data a ns1:ConceptualTopic ;
    rdfs:label "Web of Data" ;
    ns1:description "A web in which the primary unit is a resource or entity and data is expressed as highly structured explicit graphs with typed relationships." ;
    ns1:name "Web of Data" .

<http://example.org/semantic-web/instance/api-interface/sparql-1-1-blueprint-rdf4j> a ns1:APIInterface ;
    rdfs:label "SPARQL 1.1 / Blueprint / RDF4J" .

