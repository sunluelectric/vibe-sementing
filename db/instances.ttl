@prefix ns1: <http://example.org/semantic-web#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:gruber-ontology-definition a ns1:OntologyConcept ;
    rdfs:label "Gruber ontology definition" ;
    ns1:description "Definition attributed in the source to Thomas R. Gruber, computer scientist." ;
    ns1:name "An ontology is a formal, explicit specification of a shared conceptualization" ;
    ns1:relatedTo ns1:ontology-as-knowledge-structure,
        ns1:thomas-r-gruber .

ns1:hermit a ns1:Reasoner ;
    rdfs:label "HermiT" ;
    ns1:description "Reasoner example named in the source." ;
    ns1:name "HermiT" .

ns1:ontology-introduction-document a ns1:EducationalDocument,
        ns1:MarkdownDocument ;
    rdfs:label "Comprehensive Introduction to Ontologies in Information Science" ;
    ns1:description "Source document describing ontologies in information science, ontology components, taxonomy versus knowledge graph versus ontology, OWL profiles, semantic reasoning, and foundational ontologies." ;
    ns1:hasTopic ns1:foundational-ontologies,
        ns1:knowledge-graph-as-entity-network,
        ns1:ontology-as-knowledge-structure,
        ns1:owl-technology,
        ns1:semantic-reasoning,
        ns1:taxonomy-as-classification-scheme ;
    ns1:name "Comprehensive Introduction to Ontologies in Information Science" .

ns1:openllet a ns1:Reasoner ;
    rdfs:label "Openllet" ;
    ns1:description "Reasoner example named in the source." ;
    ns1:name "Openllet" .

ns1:owl-2-el a ns1:LogicalProfile ;
    rdfs:label "OWL 2 EL" ;
    ns1:description "OWL 2 EL is an OWL 2 profile tailored for domains with massive numbers of classes and complex subclass hierarchies but relatively simple property relationships. Reasoning can be computed in polynomial time and it is favored in biomedical ontologies such as SNOMED CT." ;
    ns1:name "OWL 2 EL" ;
    ns1:partOf ns1:owl-technology .

ns1:owl-2-ql a ns1:LogicalProfile ;
    rdfs:label "OWL 2 QL" ;
    ns1:description "OWL 2 QL is an OWL 2 profile designed to work smoothly with standard relational databases. It allows semantic queries to be translated into optimized SQL queries and supports enterprise data virtualization and data integration." ;
    ns1:name "OWL 2 QL" ;
    ns1:partOf ns1:owl-technology .

ns1:owl-2-rl a ns1:LogicalProfile ;
    rdfs:label "OWL 2 RL" ;
    ns1:description "OWL 2 RL is an OWL 2 profile optimized for heavy relational reasoning while preserving scalability. It maps to standard database rule engines and supports forward-chaining and backward-chaining rule platforms." ;
    ns1:name "OWL 2 RL" ;
    ns1:partOf ns1:owl-technology .

ns1:pellet a ns1:Reasoner ;
    rdfs:label "Pellet" ;
    ns1:description "Reasoner example named in the source." ;
    ns1:name "Pellet" .

ns1:reasoner-software a ns1:Reasoner ;
    rdfs:label "Reasoner" ;
    ns1:description "A reasoner is software such as HermiT, Pellet, or Openllet that ingests an ontology and performs logical reasoning tasks." ;
    ns1:enablesCapability ns1:classification-task,
        ns1:consistency-checking-task ;
    ns1:name "Reasoner" .

ns1:schema-org a ns1:Vocabulary ;
    rdfs:label "Schema.org" ;
    ns1:description "Schema.org is a collaborative initiative by Google, Bing, Yandex, and Yahoo. Websites embed lightweight semantic vocabularies into HTML using JSON-LD or Microdata to support search engine optimization and search engine knowledge graphs." ;
    ns1:name "Schema.org" ;
    ns1:usesSyntax ns1:json-ld,
        ns1:microdata .

ns1:semantic-web-document a ns1:EducationalDocument,
        ns1:MarkdownDocument ;
    rdfs:label "The Semantic Web: Architecture, Logic, and Engineering" ;
    ns1:description "Source document describing the Semantic Web as an extension of the traditional web, the move from documents to data, the Semantic Web layer stack, mathematical principles, and modern implementations." ;
    ns1:hasTopic ns1:enterprise-knowledge-graphs,
        ns1:linked-open-data-instance,
        ns1:non-unique-name-assumption-instance,
        ns1:open-world-assumption-instance,
        ns1:semantic-web,
        ns1:semantic-web-layer-cake,
        ns1:web-of-data,
        ns1:web-of-documents ;
    ns1:name "The Semantic Web: Architecture, Logic, and Engineering" .

<http://example.org/semantic-web/instance/triplestore/allegrograph> a ns1:Triplestore ;
    rdfs:label "AllegroGraph" ;
    ns1:developerMaintainerLiteral "Franz Inc."^^xsd:string ;
    ns1:keyFeaturesLiteral "Document-Graph database with advanced temporal"^^xsd:string ;
    ns1:licenseTypeLiteral "Commercial"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL 1.1 / Python / Java / Lisp"^^xsd:string ;
    ns1:triplestoreName "AllegroGraph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/amazon-neptune> a ns1:Triplestore ;
    rdfs:label "Amazon Neptune" ;
    ns1:developerMaintainerLiteral "Amazon Web Services (AWS)"^^xsd:string ;
    ns1:keyFeaturesLiteral "Fully managed cloud database"^^xsd:string ;
    ns1:licenseTypeLiteral "Commercial (Managed Service)"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL / Apache TinkerPop Gremlin / openCypher"^^xsd:string ;
    ns1:triplestoreName "Amazon Neptune"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/anzograph> a ns1:Triplestore ;
    rdfs:label "AnzoGraph" ;
    ns1:developerMaintainerLiteral "Cambridge Semantics"^^xsd:string ;
    ns1:keyFeaturesLiteral "Massively Parallel Processing (MPP) native graph database designed for distributed analytics."^^xsd:string ;
    ns1:licenseTypeLiteral "Commercial"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL 1.1 / Cypher / C++ API"^^xsd:string ;
    ns1:triplestoreName "AnzoGraph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/apache-jena-tdb> a ns1:Triplestore ;
    rdfs:label "Apache Jena TDB" ;
    ns1:developerMaintainerLiteral "Apache Software Foundation"^^xsd:string ;
    ns1:keyFeaturesLiteral "Component of the Apache Jena framework; a native"^^xsd:string ;
    ns1:licenseTypeLiteral "Open Source (Apache 2.0)"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL 1.1 / Native Jena API"^^xsd:string ;
    ns1:triplestoreName "Apache Jena TDB"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/blazegraph> a ns1:Triplestore ;
    rdfs:label "Blazegraph" ;
    ns1:developerMaintainerLiteral "Systap (acquired by Amazon)"^^xsd:string ;
    ns1:keyFeaturesLiteral "High-performance graph database (historically powered Wikidata Query Service)."^^xsd:string ;
    ns1:licenseTypeLiteral "Open Source (GPLv3) / Commercial"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL 1.1 / Blueprint / RDF4J"^^xsd:string ;
    ns1:triplestoreName "Blazegraph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/graphdb> a ns1:Triplestore ;
    rdfs:label "GraphDB" ;
    ns1:developerMaintainerLiteral "Ontotext"^^xsd:string ;
    ns1:keyFeaturesLiteral "Advanced RDF/OWL reasoning"^^xsd:string ;
    ns1:licenseTypeLiteral "Commercial / Free Edition"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL 1.1 / RDF4J / GraphDB Workbench"^^xsd:string ;
    ns1:triplestoreName "GraphDB"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/marklogic> a ns1:Triplestore ;
    rdfs:label "MarkLogic" ;
    ns1:developerMaintainerLiteral "Progress Software"^^xsd:string ;
    ns1:keyFeaturesLiteral "Multi-model NoSQL database integrating XML"^^xsd:string ;
    ns1:licenseTypeLiteral "Commercial"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL 1.1 / REST / Java / Node.js"^^xsd:string ;
    ns1:triplestoreName "MarkLogic"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/oracle-spatial-and-graph> a ns1:Triplestore ;
    rdfs:label "Oracle Spatial and Graph" ;
    ns1:developerMaintainerLiteral "Oracle"^^xsd:string ;
    ns1:keyFeaturesLiteral "Enterprise RDF semantic graph support built natively into Oracle Database."^^xsd:string ;
    ns1:licenseTypeLiteral "Commercial"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL 1.1 / SQL / Property Graph"^^xsd:string ;
    ns1:triplestoreName "Oracle Spatial and Graph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/rdf4j-formerly-sesame> a ns1:Triplestore ;
    rdfs:label "RDF4J (formerly Sesame)" ;
    ns1:developerMaintainerLiteral "Eclipse Foundation"^^xsd:string ;
    ns1:keyFeaturesLiteral "Java framework for processing RDF data that includes an in-memory and disk-based triplestore."^^xsd:string ;
    ns1:licenseTypeLiteral "Open Source (EDL)"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL 1.1 / RDF4J API"^^xsd:string ;
    ns1:triplestoreName "RDF4J (formerly Sesame)"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/stardog> a ns1:Triplestore ;
    rdfs:label "Stardog" ;
    ns1:developerMaintainerLiteral "Stardog Union"^^xsd:string ;
    ns1:keyFeaturesLiteral "Enterprise knowledge graph platform with virtual graphs (data virtualization) and logic reasoning."^^xsd:string ;
    ns1:licenseTypeLiteral "Commercial"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL 1.1 / GraphQL / Java API"^^xsd:string ;
    ns1:triplestoreName "Stardog"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/virtuoso> a ns1:Triplestore ;
    rdfs:label "Virtuoso" ;
    ns1:developerMaintainerLiteral "OpenLink Software"^^xsd:string ;
    ns1:keyFeaturesLiteral "Hybrid relational/RDF engine"^^xsd:string ;
    ns1:licenseTypeLiteral "Open Source (GPLv2) / Commercial"^^xsd:string ;
    ns1:primaryApiInterfacesLiteral "SPARQL / SQL / ODBC / JDBC"^^xsd:string ;
    ns1:triplestoreName "Virtuoso"^^xsd:string .

ns1:bfo a ns1:FoundationalOntology ;
    rdfs:label "BFO" ;
    ns1:description "BFO is a domain-neutral upper-level ontology used as a structural foundation to help sub-ontologies interoperate." ;
    ns1:name "Basic Formal Ontology" .

ns1:class-component a ns1:ClassConcept ;
    rdfs:label "Classes" ;
    ns1:description "Classes are abstract concepts or categories in a domain, typically organized into strict taxonomies or hierarchies using subclass and superclass relationships. Examples include Person, Automobile, MedicalCondition, and FinancialTransaction." ;
    ns1:name "Classes" ;
    ns1:partOf ns1:ontology-as-knowledge-structure .

ns1:conceptualization-aspect a ns1:OntologyConcept ;
    rdfs:label "Conceptualization aspect of ontology" ;
    ns1:description "An ontology is an abstract model of a real-world phenomenon or domain that identifies relevant concepts of that domain." ;
    ns1:name "Conceptualization" ;
    ns1:partOf ns1:ontology-as-knowledge-structure .

ns1:constraint-component a ns1:Constraint ;
    rdfs:label "Constraints" ;
    ns1:description "Constraints are model restrictions such as disjointness or cardinality that limit valid interpretations of ontology data." ;
    ns1:name "Constraints" ;
    ns1:partOf ns1:axiom-component .

ns1:datatype-property-component a ns1:DatatypePropertyConcept ;
    rdfs:label "Attributes or datatype properties" ;
    ns1:description "Attributes describe characteristics, features, or data values associated with a class or individual and link an instance to primitive data such as a string, integer, or boolean." ;
    ns1:name "Attributes" ;
    ns1:partOf ns1:ontology-as-knowledge-structure .

ns1:dbpedia a ns1:KnowledgeGraphHub ;
    rdfs:label "DBpedia" ;
    ns1:description "DBpedia is the structured RDF counterpart of Wikipedia and is described as a central hub in Linked Open Data." ;
    ns1:name "DBpedia" ;
    ns1:usesDataModel ns1:rdf .

ns1:description-logics a ns1:DescriptionLogic ;
    rdfs:label "Description Logics" ;
    ns1:description "Description Logics provide the logical foundation used by OWL for advanced ontology modeling and reasoning." ;
    ns1:name "Description Logics" .

ns1:dublin-core a ns1:FoundationalOntology ;
    rdfs:label "Dublin Core" ;
    ns1:description "Dublin Core is a standard vocabulary for describing digital and physical resources using terms such as creator, date, format, and publisher." ;
    ns1:name "Dublin Core" .

ns1:enterprise-knowledge-graphs a ns1:EnterpriseKnowledgeGraph ;
    rdfs:label "Enterprise Knowledge Graphs" ;
    ns1:description "Modern enterprises use Semantic Web standards to build internal knowledge graphs. RDF and OWL help integrate data from legacy CRM systems, ERP software, and supply chain logs without catastrophic database migrations." ;
    ns1:name "Enterprise Knowledge Graphs" ;
    ns1:usesDataModel ns1:rdf ;
    ns1:usesTechnology ns1:owl-technology .

ns1:explicit-aspect a ns1:OntologyConcept ;
    rdfs:label "Explicit aspect of ontology" ;
    ns1:description "All concepts, properties, relations, functions, and constraints must be clearly defined without ambiguity." ;
    ns1:name "Explicit" ;
    ns1:partOf ns1:ontology-as-knowledge-structure .

ns1:foaf a ns1:FoundationalOntology ;
    rdfs:label "FOAF" ;
    ns1:description "FOAF is used for describing people, their attributes, and their social networks." ;
    ns1:name "Friend of a Friend" .

ns1:formal-aspect a ns1:OntologyConcept ;
    rdfs:label "Formal aspect of ontology" ;
    ns1:description "An ontology must be machine-readable and mathematically rigorous so that computers can process it and perform logical reasoning." ;
    ns1:name "Formal" ;
    ns1:partOf ns1:ontology-as-knowledge-structure .

ns1:foundational-ontologies a ns1:OntologyConcept ;
    rdfs:label "Foundational ontologies" ;
    ns1:description "Established standard ontologies are often reused or inherited because ontology development from scratch is labor-intensive." ;
    ns1:hasPart ns1:bfo,
        ns1:dublin-core,
        ns1:foaf,
        ns1:gene-ontology,
        ns1:skos ;
    ns1:name "Foundational Ontologies" .

ns1:gene-ontology a ns1:FoundationalOntology ;
    rdfs:label "Gene Ontology" ;
    ns1:description "Gene Ontology is a large domain ontology standardizing the representation of gene and protein functions across biology." ;
    ns1:name "Gene Ontology" .

ns1:individual-component a ns1:IndividualConcept ;
    rdfs:label "Individuals" ;
    ns1:description "Individuals are concrete real-world objects that belong to a class and represent data points that populate an ontology. Examples include AlbertEinstein as a Person and TheMatrix as a Movie." ;
    ns1:name "Individuals" ;
    ns1:partOf ns1:ontology-as-knowledge-structure .

ns1:iri a ns1:IdentifierScheme,
        ns1:Standard ;
    rdfs:label "IRI" ;
    ns1:description "IRI extends URI by allowing non-ASCII characters. In the Semantic Web each entity can be assigned a global unique IRI to prevent naming collisions across disparate databases." ;
    ns1:name "Internationalized Resource Identifier" .

ns1:linked-open-data-instance a ns1:LinkedOpenData ;
    rdfs:label "Linked Open Data" ;
    ns1:description "Linked Open Data is a global movement to publish structured data so it can be interlinked. DBpedia and Wikidata serve as central hubs connecting hundreds of open datasets in physics, medicine, geography, and pop culture." ;
    ns1:hasPart ns1:dbpedia,
        ns1:wikidata ;
    ns1:name "Linked Open Data" .

ns1:microdata a ns1:SerializationSyntax ;
    rdfs:label "Microdata" ;
    ns1:description "Microdata is named in the source as a syntax used with Schema.org to embed lightweight semantic vocabularies into HTML." ;
    ns1:name "Microdata" .

ns1:non-unique-name-assumption-instance a ns1:NonUniqueNameAssumption ;
    rdfs:label "Non-Unique Name Assumption" ;
    ns1:description "The Non-Unique Name Assumption states that two different URIs can refer to the same real-world entity. The source notes that explicit identity mapping can merge decentralized data silos into a single knowledge graph." ;
    ns1:name "Non-Unique Name Assumption" .

ns1:open-world-assumption-instance a ns1:OpenWorldAssumption ;
    rdfs:label "Open World Assumption" ;
    ns1:description "In the Semantic Web, missing information is treated as unknown rather than false. If a graph does not state that a person has a spouse, it does not mean the person is single; the data has not yet been asserted." ;
    ns1:name "Open World Assumption" .

ns1:rdf-xml a ns1:SerializationSyntax,
        ns1:Standard ;
    rdfs:label "RDF/XML" ;
    ns1:description "RDF/XML is the historical XML-based RDF serialization format." ;
    ns1:name "RDF/XML" .

ns1:rdfs a ns1:SchemaLanguage,
        ns1:Standard ;
    rdfs:label "RDFS" ;
    ns1:description "RDF Schema is a foundational vocabulary that lets developers create basic hierarchies and introduces concepts such as class, subclass, domain, and range." ;
    ns1:name "RDF Schema" ;
    ns1:usesDataModel ns1:rdf .

ns1:relationship-component a ns1:ObjectPropertyConcept,
        ns1:RelationshipConcept ;
    rdfs:label "Relationships or object properties" ;
    ns1:description "Relationships define how classes and individuals interact with or relate to one another as binary relations connecting one resource to another." ;
    ns1:name "Relationships" ;
    ns1:partOf ns1:ontology-as-knowledge-structure .

ns1:rif a ns1:RuleLanguage,
        ns1:Standard ;
    rdfs:label "RIF" ;
    ns1:description "RIF is named in the source as a rules technology in the upper Semantic Web layers." ;
    ns1:name "Rule Interchange Format" .

ns1:rule-component a ns1:Rule ;
    rdfs:label "Rules" ;
    ns1:description "Rules are logical expressions that support deduction and reasoning over ontology data." ;
    ns1:name "Rules" ;
    ns1:partOf ns1:axiom-component .

ns1:semantic-reasoning a ns1:ReasoningFeature ;
    rdfs:label "Semantic reasoning" ;
    ns1:description "Semantic reasoning is the defining characteristic of an ontology over a standard database schema. A reasoner can ingest an ontology and automatically perform classification and consistency checking." ;
    ns1:enablesCapability ns1:classification-task,
        ns1:consistency-checking-task ;
    ns1:name "Semantic Reasoning" .

ns1:shared-aspect a ns1:OntologyConcept ;
    rdfs:label "Shared aspect of ontology" ;
    ns1:description "An ontology reflects consensus among a community or group rather than a single individual perspective." ;
    ns1:name "Shared" ;
    ns1:partOf ns1:ontology-as-knowledge-structure .

ns1:sparql a ns1:GraphQueryLanguage,
        ns1:QueryLanguage,
        ns1:Standard ;
    rdfs:label "SPARQL" ;
    ns1:description "SPARQL is the SQL equivalent for the Semantic Web. It executes graph-pattern matching against RDF graphs and can span multiple federated endpoints globally." ;
    ns1:name "SPARQL Protocol and RDF Query Language" .

ns1:swrl a ns1:RuleLanguage,
        ns1:Standard ;
    rdfs:label "SWRL" ;
    ns1:description "SWRL is named in the source as a rules technology that combines ontologies with Horn-clause logic rules for advanced reasoning." ;
    ns1:name "Semantic Web Rule Language" .

ns1:thomas-r-gruber a ns1:Person ;
    rdfs:label "Thomas R. Gruber" ;
    ns1:description "Computer scientist cited for the definition of ontology as a formal, explicit specification of a shared conceptualization." ;
    ns1:name "Thomas R. Gruber" .

ns1:tim-berners-lee a ns1:Person ;
    rdfs:label "Tim Berners-Lee" ;
    ns1:description "Tim Berners-Lee is identified in the source as championing the Semantic Web." ;
    ns1:name "Tim Berners-Lee" .

ns1:trust-layer a ns1:TrustLayer ;
    rdfs:label "Trust layer" ;
    ns1:aboveLayer ns1:proof-layer ;
    ns1:buildsOnLayer ns1:proof-layer ;
    ns1:description "The trust layer concerns cryptographic verification and reliability assessment of semantic data." ;
    ns1:name "Trust" .

ns1:turtle a ns1:SerializationSyntax,
        ns1:Standard ;
    rdfs:label "Turtle" ;
    ns1:description "Turtle is a compact, human-readable serialization format for RDF graphs." ;
    ns1:name "Terse RDF Triple Language" .

ns1:unicode a ns1:CharacterEncoding,
        ns1:Standard ;
    rdfs:label "Unicode" ;
    ns1:description "Unicode ensures universal character encoding support." ;
    ns1:name "Unicode" .

ns1:uri a ns1:IdentifierScheme,
        ns1:Standard ;
    rdfs:label "URI" ;
    ns1:description "URI is an identifier scheme used to identify resources on the web." ;
    ns1:name "Uniform Resource Identifier" .

ns1:wikidata a ns1:KnowledgeGraphHub ;
    rdfs:label "Wikidata" ;
    ns1:description "Wikidata is described as a central hub in Linked Open Data connecting many open datasets." ;
    ns1:name "Wikidata" .

ns1:classification-task a ns1:ClassificationTask ;
    rdfs:label "Classification" ;
    ns1:description "A reasoning task in which the reasoner computes logical implications of class definitions and builds the correct hierarchy. The source example classifies MargheritaPizza as VegetarianDish when it contains only cheese and tomato and zero meat items." ;
    ns1:name "Classification" .

ns1:consistency-checking-task a ns1:ConsistencyCheckingTask ;
    rdfs:label "Consistency checking" ;
    ns1:description "A reasoning task in which the reasoner detects logical contradictions, such as an entity asserted as both Human and Machine when those classes are disjoint." ;
    ns1:name "Consistency Checking" .

ns1:json-ld a ns1:SerializationSyntax,
        ns1:Standard ;
    rdfs:label "JSON-LD" ;
    ns1:description "JSON-LD is a popular web development syntax that injects semantic data into standard JSON structures." ;
    ns1:name "JSON for Linking Data" .

ns1:semantic-web a ns1:SemanticWebConcept,
        ns1:SemanticWebImplementation ;
    rdfs:label "Semantic Web" ;
    ns1:championedBy ns1:tim-berners-lee ;
    ns1:description "The Semantic Web is an evolutionary extension of the World Wide Web that seeks to transform the web into a universal medium for data, information, and knowledge exchange by embedding explicit, machine-understandable semantics into web resources." ;
    ns1:name "Semantic Web" ;
    ns1:relatedTo ns1:semantic-web-layer-cake,
        ns1:w3c,
        ns1:web-of-data .

ns1:semantic-web-layer-cake a ns1:SemanticWebConcept ;
    rdfs:label "Semantic Web Layer Cake" ;
    ns1:description "The Semantic Web layer stack is a hierarchy in which each layer builds upon capabilities of the layer below it." ;
    ns1:hasPart ns1:data-model-layer,
        ns1:identifier-layer,
        ns1:logic-layer,
        ns1:ontology-layer,
        ns1:proof-layer,
        ns1:query-layer,
        ns1:syntax-layer,
        ns1:trust-layer ;
    ns1:name "Semantic Web Layer Cake" .

ns1:skos a ns1:SchemaLanguage,
        ns1:Standard ;
    rdfs:label "SKOS" ;
    ns1:description "SKOS is used to represent basic thesauri, taxonomies, and classification schemes that do not require full Description Logics." ;
    ns1:name "Simple Knowledge Organization System" .

ns1:w3c a ns1:StandardsBody ;
    rdfs:label "World Wide Web Consortium" ;
    ns1:description "The World Wide Web Consortium is identified in the source as the organization that initiated the Semantic Web and standardizes technologies such as OWL." ;
    ns1:name "World Wide Web Consortium" .

ns1:web-of-documents a ns1:SemanticWebConcept ;
    rdfs:label "Web of Documents" ;
    ns1:contrastsWith ns1:web-of-data ;
    ns1:description "The traditional web uses documents such as HTML pages and PDFs as the primary unit, untyped hyperlinks, unstructured text and implicit schemas, and machine roles focused on display, indexing, and routing." ;
    ns1:name "Web of Documents" .

ns1:axiom-component a ns1:Axiom ;
    rdfs:label "Axioms" ;
    ns1:description "Axioms are explicit logical assertions that are always true within an ontology. They constrain the model, define domain boundaries, and provide mathematical rules used by reasoning engines." ;
    ns1:hasPart ns1:constraint-component,
        ns1:rule-component ;
    ns1:name "Axioms" ;
    ns1:partOf ns1:ontology-as-knowledge-structure .

ns1:data-model-layer a ns1:DataModelLayer ;
    rdfs:label "Data model layer" ;
    ns1:aboveLayer ns1:syntax-layer ;
    ns1:buildsOnLayer ns1:syntax-layer ;
    ns1:containsTechnology ns1:rdf,
        ns1:rdfs ;
    ns1:description "The data model layer includes RDF and RDF Schema. RDF models data as directed labeled graphs with triples, while RDFS provides foundational vocabulary for basic hierarchies and constraints." ;
    ns1:name "Data Model" .

ns1:identifier-layer a ns1:IdentifierLayer ;
    rdfs:label "Identifiers and character sets layer" ;
    ns1:containsTechnology ns1:iri,
        ns1:unicode,
        ns1:uri ;
    ns1:description "The base layer includes URI, IRI, and Unicode. IRIs assign global unique identifiers to entities and Unicode ensures universal character encoding support." ;
    ns1:name "Identifiers and Character Sets" .

ns1:knowledge-graph-as-entity-network a ns1:KnowledgeGraph ;
    rdfs:label "Knowledge graph" ;
    ns1:contrastsWith ns1:ontology-as-knowledge-structure,
        ns1:taxonomy-as-classification-scheme ;
    ns1:description "A knowledge graph is a network of real-world entities as nodes connected by relationships as edges. It represents actual data instance networks and can be governed by an ontology." ;
    ns1:name "Knowledge Graph" ;
    ns1:relatedTo ns1:ontology-as-knowledge-structure .

ns1:logic-layer a ns1:LogicLayer ;
    rdfs:label "Logic layer" ;
    ns1:aboveLayer ns1:query-layer ;
    ns1:buildsOnLayer ns1:query-layer ;
    ns1:containsTechnology ns1:rif,
        ns1:swrl ;
    ns1:description "The logic layer supports rules that combine ontologies with Horn-clause logic to allow advanced reasoning." ;
    ns1:name "Logic" .

ns1:ontology-layer a ns1:OntologyLayer ;
    rdfs:label "Ontology layer" ;
    ns1:aboveLayer ns1:data-model-layer ;
    ns1:buildsOnLayer ns1:data-model-layer ;
    ns1:containsTechnology ns1:owl-technology,
        ns1:skos ;
    ns1:description "The ontology layer includes OWL and SKOS. OWL provides advanced structural modeling based on Description Logics." ;
    ns1:name "Ontology" .

ns1:proof-layer a ns1:ProofLayer ;
    rdfs:label "Proof layer" ;
    ns1:aboveLayer ns1:logic-layer ;
    ns1:buildsOnLayer ns1:logic-layer ;
    ns1:description "The proof layer concerns proof and provenance tracking, including knowing where a statement came from." ;
    ns1:name "Proof" .

ns1:query-layer a ns1:QueryLayer ;
    rdfs:label "Query layer" ;
    ns1:aboveLayer ns1:ontology-layer ;
    ns1:buildsOnLayer ns1:ontology-layer ;
    ns1:containsTechnology ns1:sparql ;
    ns1:description "The query layer includes SPARQL, which executes graph-pattern matching against RDF graphs and can span federated endpoints." ;
    ns1:name "Query" .

ns1:syntax-layer a ns1:SyntaxLayer ;
    rdfs:label "Syntax and serialization layer" ;
    ns1:aboveLayer ns1:identifier-layer ;
    ns1:buildsOnLayer ns1:identifier-layer ;
    ns1:containsTechnology ns1:json-ld,
        ns1:rdf-xml,
        ns1:turtle ;
    ns1:description "The syntax layer serializes semantic graphs into transportable text formats such as Turtle, JSON-LD, and RDF/XML." ;
    ns1:name "Syntax and Serialization" .

ns1:taxonomy-as-classification-scheme a ns1:Taxonomy ;
    rdfs:label "Taxonomy" ;
    ns1:contrastsWith ns1:knowledge-graph-as-entity-network,
        ns1:ontology-as-knowledge-structure ;
    ns1:description "A taxonomy is a narrow hierarchical classification scheme. It only understands tree-like parent and child structures and contains no advanced properties or logic." ;
    ns1:name "Taxonomy" .

ns1:web-of-data a ns1:SemanticWebConcept ;
    rdfs:label "Web of Data" ;
    ns1:contrastsWith ns1:web-of-documents ;
    ns1:description "The Semantic Web uses resources, entities, concepts, and events as primary units, typed relationships, explicit graph structures, and machine roles involving reasoning, inference, integration, and execution." ;
    ns1:name "Web of Data" ;
    ns1:relatedTo ns1:semantic-web .

ns1:rdf a ns1:DataModel,
        ns1:Standard ;
    rdfs:label "RDF" ;
    ns1:description "RDF is the fundamental Semantic Web data model. It models data as a directed labeled graph, and atomic statements are expressed as triples with subject, predicate, and object." ;
    ns1:name "Resource Description Framework" .

ns1:owl-technology a ns1:OntologyLanguage,
        ns1:Standard ;
    rdfs:label "OWL" ;
    ns1:description "OWL is the primary Semantic Web ontology language, standardized by the W3C. It extends RDF Schema using Description Logics and supports property characteristics, class restrictions, cardinality constraints, and class relations." ;
    ns1:name "Web Ontology Language" ;
    ns1:standardizedBy ns1:w3c ;
    ns1:usesTechnology ns1:description-logics .

ns1:ontology-as-knowledge-structure a ns1:Ontology ;
    rdfs:label "Ontology" ;
    ns1:contrastsWith ns1:knowledge-graph-as-entity-network,
        ns1:taxonomy-as-classification-scheme ;
    ns1:description "In computer science, information science, and artificial intelligence, an ontology is a formal, explicit specification of a shared conceptualization. It defines concepts, properties, relations, functions, constraints, vocabulary, logic, and boundaries for a domain." ;
    ns1:hasPart ns1:axiom-component,
        ns1:class-component,
        ns1:conceptualization-aspect,
        ns1:datatype-property-component,
        ns1:explicit-aspect,
        ns1:formal-aspect,
        ns1:individual-component,
        ns1:relationship-component,
        ns1:shared-aspect ;
    ns1:name "Ontology" .

