@prefix ns1: <http://example.org/semantic-web#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/semantic-web/instance/bfo> a ns1:FoundationalOntology ;
    rdfs:label "BFO" ;
    ns1:description "A domain-neutral upper-level ontology used as a structural foundation for interoperability among ontologies." ;
    ns1:title "Basic Formal Ontology" .

<http://example.org/semantic-web/instance/classification-reasoning> a ns1:ClassificationReasoning ;
    rdfs:label "Classification" ;
    ns1:description "Reasoning task that computes logical implications of class definitions and builds the correct hierarchy." ;
    ns1:name "Classification" .

<http://example.org/semantic-web/instance/closed-world-assumption> a ns1:ClosedWorldAssumption ;
    rdfs:label "Closed World Assumption" ;
    ns1:description "In traditional databases, information not present is generally assumed to be false." ;
    ns1:name "Closed World Assumption" .

<http://example.org/semantic-web/instance/consistency-checking> a ns1:ConsistencyChecking ;
    rdfs:label "Consistency checking" ;
    ns1:description "Reasoning task that analyzes an ontology to find logical contradictions." ;
    ns1:name "Consistency Checking" .

<http://example.org/semantic-web/instance/data-integration-use-case> a ns1:DataIntegrationUseCase ;
    rdfs:label "Data Integration" ;
    ns1:description "Use case focused on integrating data from multiple heterogeneous systems." ;
    ns1:name "Data Integration" .

<http://example.org/semantic-web/instance/data-virtualization-use-case> a ns1:DataVirtualizationUseCase ;
    rdfs:label "Data Virtualization" ;
    ns1:description "Use case focused on virtualized access to data without copying it into a dedicated triplestore." ;
    ns1:name "Data Virtualization" .

<http://example.org/semantic-web/instance/dbpedia> a ns1:Dataset ;
    rdfs:label "DBpedia" ;
    ns1:description "Structured RDF counterpart of Wikipedia and a central hub of Linked Open Data." ;
    ns1:title "DBpedia" .

<http://example.org/semantic-web/instance/dublin-core> a ns1:Vocabulary ;
    rdfs:label "Dublin Core" ;
    ns1:description "Standard vocabulary for describing digital and physical resources." ;
    ns1:title "Dublin Core" .

<http://example.org/semantic-web/instance/enterprise-knowledge-graph> a ns1:EnterpriseKnowledgeGraph ;
    rdfs:label "Enterprise Knowledge Graph" ;
    ns1:description "Enterprise use of semantic web standards to build internal knowledge graphs integrating heterogeneous systems." ;
    ns1:name "Enterprise Knowledge Graph" .

<http://example.org/semantic-web/instance/foaf> a ns1:Vocabulary ;
    rdfs:label "FOAF" ;
    ns1:description "Friend of a Friend vocabulary used for describing people, their attributes, and their social networks." ;
    ns1:title "FOAF" .

<http://example.org/semantic-web/instance/gene-ontology> a ns1:Ontology ;
    rdfs:label "Gene Ontology" ;
    ns1:description "A large domain ontology standardizing the representation of gene and protein functions across biology." ;
    ns1:title "Gene Ontology" .

<http://example.org/semantic-web/instance/hermit-reasoner> a ns1:Reasoner ;
    rdfs:label "HermiT" ;
    ns1:description "Example reasoner mentioned as software that can ingest an ontology and perform semantic reasoning." ;
    ns1:name "HermiT" .

<http://example.org/semantic-web/instance/iri-concept> a ns1:IRI ;
    rdfs:label "IRI" ;
    ns1:description "Internationalized Resource Identifier allowing non-ASCII characters for global resource identification." ;
    ns1:name "IRI" ;
    ns1:partOf <http://example.org/semantic-web/instance/identifier-character-sets-layer> .

<http://example.org/semantic-web/instance/json-ld-format> a ns1:JSONLDFormat ;
    rdfs:label "JSON-LD" ;
    ns1:description "JSON for Linking Data; a popular format for embedding semantic data into JSON structures." ;
    ns1:name "JSON-LD" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/syntax-serialization-layer> .

<http://example.org/semantic-web/instance/knowledge-graph-artifact> a ns1:KnowledgeGraph ;
    rdfs:label "Knowledge Graph" ;
    ns1:description "A network of real-world entities connected by relationships that represents actual data instance networks." ;
    ns1:title "Knowledge Graph" .

<http://example.org/semantic-web/instance/linked-open-data> a ns1:LinkedOpenData ;
    rdfs:label "Linked Open Data" ;
    ns1:description "A global movement to publish structured data so that it can be interlinked." ;
    ns1:name "Linked Open Data" .

<http://example.org/semantic-web/instance/microdata-technology> a ns1:MicrodataTechnology ;
    rdfs:label "Microdata" ;
    ns1:description "HTML embedding technology used with lightweight semantic vocabularies such as Schema.org." ;
    ns1:name "Microdata" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/syntax-serialization-layer> .

<http://example.org/semantic-web/instance/non-unique-name-assumption> a ns1:NonUniqueNameAssumption ;
    rdfs:label "Non-Unique Name Assumption" ;
    ns1:description "Two different URIs can refer to the same real-world entity, requiring explicit mappings when needed." ;
    ns1:name "Non-Unique Name Assumption" .

<http://example.org/semantic-web/instance/ontology-definition-document> a ns1:Document ;
    rdfs:label "Comprehensive Introduction to Ontologies in Information Science" ;
    ns1:description "Document explaining ontology definitions, core components, OWL profiles, reasoning, and foundational ontologies." ;
    ns1:title "Comprehensive Introduction to Ontologies in Information Science" .

<http://example.org/semantic-web/instance/ontology-gruber-definition> a ns1:Ontology ;
    rdfs:label "Ontology as formal explicit shared conceptualization" ;
    ns1:description "An ontology is a formal, explicit specification of a shared conceptualization." ;
    ns1:hasComponent <http://example.org/semantic-web/instance/attribute-concept>,
        <http://example.org/semantic-web/instance/axiom-concept>,
        <http://example.org/semantic-web/instance/class-concept>,
        <http://example.org/semantic-web/instance/individual-concept>,
        <http://example.org/semantic-web/instance/relationship-concept> ;
    ns1:title "Ontology definition" .

<http://example.org/semantic-web/instance/open-world-assumption> a ns1:OpenWorldAssumption ;
    rdfs:label "Open World Assumption" ;
    ns1:description "Missing information in the Semantic Web is treated as unknown rather than false." ;
    ns1:name "Open World Assumption" .

<http://example.org/semantic-web/instance/openllet-reasoner> a ns1:Reasoner ;
    rdfs:label "Openllet" ;
    ns1:description "Example reasoner mentioned as software that can perform ontology reasoning tasks." ;
    ns1:name "Openllet" .

<http://example.org/semantic-web/instance/owl-2-el-profile> a ns1:OWL2ELProfile ;
    rdfs:label "OWL 2 EL" ;
    ns1:description "OWL 2 profile tailored for massive numbers of classes and complex subclass hierarchies with polynomial-time reasoning." ;
    ns1:name "OWL 2 EL" .

<http://example.org/semantic-web/instance/owl-2-ql-profile> a ns1:OWL2QLProfile ;
    rdfs:label "OWL 2 QL" ;
    ns1:description "OWL 2 profile designed for efficient query answering over relational databases and data virtualization scenarios." ;
    ns1:name "OWL 2 QL" .

<http://example.org/semantic-web/instance/owl-2-rl-profile> a ns1:OWL2RLProfile ;
    rdfs:label "OWL 2 RL" ;
    ns1:description "OWL 2 profile optimized for scalable rule-based reasoning using database rule engines." ;
    ns1:name "OWL 2 RL" .

<http://example.org/semantic-web/instance/owl-technology> a ns1:OWLTechnology ;
    rdfs:label "OWL" ;
    ns1:description "Web Ontology Language for advanced structural semantic modeling based on description logics." ;
    ns1:name "OWL" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/ontology-layer-instance> .

<http://example.org/semantic-web/instance/pellet-reasoner> a ns1:Reasoner ;
    rdfs:label "Pellet" ;
    ns1:description "Example reasoner mentioned as software that can perform ontology reasoning tasks." ;
    ns1:name "Pellet" .

<http://example.org/semantic-web/instance/rdf-technology> a ns1:RDFTechnology ;
    rdfs:label "RDF" ;
    ns1:description "Resource Description Framework, the fundamental directed labeled graph data model using triples." ;
    ns1:name "RDF" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/data-model-layer-instance> .

<http://example.org/semantic-web/instance/rdf-xml-format> a ns1:RDFXMLFormat ;
    rdfs:label "RDF/XML" ;
    ns1:description "Historical XML-based serialization format for RDF graphs." ;
    ns1:name "RDF/XML" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/syntax-serialization-layer> .

<http://example.org/semantic-web/instance/rdfs-technology> a ns1:RDFSchemaTechnology ;
    rdfs:label "RDFS" ;
    ns1:description "RDF Schema, a foundational vocabulary for classes, subclassing, domain, and range." ;
    ns1:name "RDFS" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/data-model-layer-instance> .

<http://example.org/semantic-web/instance/schema-org> a ns1:Vocabulary ;
    rdfs:label "Schema.org" ;
    ns1:description "Collaborative initiative whose lightweight semantic vocabularies are embedded in web pages using JSON-LD or Microdata." ;
    ns1:title "Schema.org" .

<http://example.org/semantic-web/instance/search-engine-knowledge-graph> a ns1:SearchEngineKnowledgeGraph ;
    rdfs:label "Search Engine Knowledge Graph" ;
    ns1:description "Knowledge graph usage pattern associated with search engine optimization and structured web data." ;
    ns1:name "Search Engine Knowledge Graph" .

<http://example.org/semantic-web/instance/semantic-web-architecture-document> a ns1:Document ;
    rdfs:label "The Semantic Web: Architecture, Logic, and Engineering" ;
    ns1:description "Document explaining the Semantic Web, the layer cake, logical assumptions, and modern implementation patterns." ;
    ns1:title "The Semantic Web: Architecture, Logic, and Engineering" .

<http://example.org/semantic-web/instance/semantic-web-paradigm> a ns1:SemanticWeb ;
    rdfs:label "Semantic Web" ;
    ns1:description "An evolutionary extension of the World Wide Web that seeks to transform the web into a universal medium for data, information, and knowledge exchange by embedding explicit, machine-understandable semantics into web resources." ;
    ns1:hasLayer <http://example.org/semantic-web/instance/data-model-layer-instance>,
        <http://example.org/semantic-web/instance/identifier-character-sets-layer>,
        <http://example.org/semantic-web/instance/ontology-layer-instance>,
        <http://example.org/semantic-web/instance/proof-rules-layer>,
        <http://example.org/semantic-web/instance/query-layer-instance>,
        <http://example.org/semantic-web/instance/syntax-serialization-layer>,
        <http://example.org/semantic-web/instance/trust-layer-instance> ;
    ns1:name "Semantic Web" .

<http://example.org/semantic-web/instance/skos-technology> a ns1:SKOSTechnology ;
    rdfs:label "SKOS" ;
    ns1:description "Simple Knowledge Organization System used to represent thesauri, taxonomies, and classification schemes." ;
    ns1:name "SKOS" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/ontology-layer-instance> .

<http://example.org/semantic-web/instance/skos-vocabulary> a ns1:Vocabulary ;
    rdfs:label "SKOS" ;
    ns1:description "Vocabulary for representing basic thesauri, taxonomies, and classification schemes." ;
    ns1:title "SKOS" .

<http://example.org/semantic-web/instance/sparql-technology> a ns1:SPARQLTechnology ;
    rdfs:label "SPARQL" ;
    ns1:description "SPARQL Protocol and RDF Query Language for graph-pattern matching over RDF data." ;
    ns1:name "SPARQL" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/query-layer-instance> .

<http://example.org/semantic-web/instance/taxonomy-artifact> a ns1:Taxonomy ;
    rdfs:label "Taxonomy" ;
    ns1:description "A narrow hierarchical classification scheme focused on parent-child structures without advanced properties or logic." ;
    ns1:title "Taxonomy" .

<http://example.org/semantic-web/instance/thomas-gruber> a ns1:Entity ;
    rdfs:label "Thomas R. Gruber" ;
    ns1:description "Computer scientist quoted for the canonical ontology definition." ;
    ns1:name "Thomas R. Gruber" .

<http://example.org/semantic-web/instance/tim-berners-lee> a ns1:Entity ;
    rdfs:label "Tim Berners-Lee" ;
    ns1:description "Figure cited as championing the Semantic Web initiative." ;
    ns1:name "Tim Berners-Lee" .

<http://example.org/semantic-web/instance/triplestore/allegrograph> a ns1:Triplestore ;
    rdfs:label "AllegroGraph" ;
    ns1:description "Commercial"^^xsd:string,
        "Document-Graph database with advanced temporal"^^xsd:string,
        "SPARQL 1.1 / Python / Java / Lisp"^^xsd:string ;
    ns1:name "AllegroGraph"^^xsd:string ;
    ns1:officialName "Franz Inc."^^xsd:string ;
    ns1:title "AllegroGraph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/amazon-neptune> a ns1:Triplestore ;
    rdfs:label "Amazon Neptune" ;
    ns1:description "Commercial (Managed Service)"^^xsd:string,
        "Fully managed cloud database"^^xsd:string,
        "SPARQL / Apache TinkerPop Gremlin / openCypher"^^xsd:string ;
    ns1:name "Amazon Neptune"^^xsd:string ;
    ns1:officialName "Amazon Web Services (AWS)"^^xsd:string ;
    ns1:title "Amazon Neptune"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/anzograph> a ns1:Triplestore ;
    rdfs:label "AnzoGraph" ;
    ns1:description "Commercial"^^xsd:string,
        "Massively Parallel Processing (MPP) native graph database designed for distributed analytics."^^xsd:string,
        "SPARQL 1.1 / Cypher / C++ API"^^xsd:string ;
    ns1:name "AnzoGraph"^^xsd:string ;
    ns1:officialName "Cambridge Semantics"^^xsd:string ;
    ns1:title "AnzoGraph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/apache-jena-tdb> a ns1:Triplestore ;
    rdfs:label "Apache Jena TDB" ;
    ns1:description "Component of the Apache Jena framework; a native"^^xsd:string,
        "Open Source (Apache 2.0)"^^xsd:string,
        "SPARQL 1.1 / Native Jena API"^^xsd:string ;
    ns1:name "Apache Jena TDB"^^xsd:string ;
    ns1:officialName "Apache Software Foundation"^^xsd:string ;
    ns1:title "Apache Jena TDB"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/blazegraph> a ns1:Triplestore ;
    rdfs:label "Blazegraph" ;
    ns1:description "High-performance graph database (historically powered Wikidata Query Service)."^^xsd:string,
        "Open Source (GPLv3) / Commercial"^^xsd:string,
        "SPARQL 1.1 / Blueprint / RDF4J"^^xsd:string ;
    ns1:name "Blazegraph"^^xsd:string ;
    ns1:officialName "Systap (acquired by Amazon)"^^xsd:string ;
    ns1:title "Blazegraph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/graphdb> a ns1:Triplestore ;
    rdfs:label "GraphDB" ;
    ns1:description "Advanced RDF/OWL reasoning"^^xsd:string,
        "Commercial / Free Edition"^^xsd:string,
        "SPARQL 1.1 / RDF4J / GraphDB Workbench"^^xsd:string ;
    ns1:name "GraphDB"^^xsd:string ;
    ns1:officialName "Ontotext"^^xsd:string ;
    ns1:title "GraphDB"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/marklogic> a ns1:Triplestore ;
    rdfs:label "MarkLogic" ;
    ns1:description "Commercial"^^xsd:string,
        "Multi-model NoSQL database integrating XML"^^xsd:string,
        "SPARQL 1.1 / REST / Java / Node.js"^^xsd:string ;
    ns1:name "MarkLogic"^^xsd:string ;
    ns1:officialName "Progress Software"^^xsd:string ;
    ns1:title "MarkLogic"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/oracle-spatial-and-graph> a ns1:Triplestore ;
    rdfs:label "Oracle Spatial and Graph" ;
    ns1:description "Commercial"^^xsd:string,
        "Enterprise RDF semantic graph support built natively into Oracle Database."^^xsd:string,
        "SPARQL 1.1 / SQL / Property Graph"^^xsd:string ;
    ns1:name "Oracle Spatial and Graph"^^xsd:string ;
    ns1:officialName "Oracle"^^xsd:string ;
    ns1:title "Oracle Spatial and Graph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/rdf4j-formerly-sesame> a ns1:Triplestore ;
    rdfs:label "RDF4J (formerly Sesame)" ;
    ns1:description "Java framework for processing RDF data that includes an in-memory and disk-based triplestore."^^xsd:string,
        "Open Source (EDL)"^^xsd:string,
        "SPARQL 1.1 / RDF4J API"^^xsd:string ;
    ns1:name "RDF4J (formerly Sesame)"^^xsd:string ;
    ns1:officialName "Eclipse Foundation"^^xsd:string ;
    ns1:title "RDF4J (formerly Sesame)"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/stardog> a ns1:Triplestore ;
    rdfs:label "Stardog" ;
    ns1:description "Commercial"^^xsd:string,
        "Enterprise knowledge graph platform with virtual graphs (data virtualization) and logic reasoning."^^xsd:string,
        "SPARQL 1.1 / GraphQL / Java API"^^xsd:string ;
    ns1:name "Stardog"^^xsd:string ;
    ns1:officialName "Stardog Union"^^xsd:string ;
    ns1:title "Stardog"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/virtuoso> a ns1:Triplestore ;
    rdfs:label "Virtuoso" ;
    ns1:description "Hybrid relational/RDF engine"^^xsd:string,
        "Open Source (GPLv2) / Commercial"^^xsd:string,
        "SPARQL / SQL / ODBC / JDBC"^^xsd:string ;
    ns1:name "Virtuoso"^^xsd:string ;
    ns1:officialName "OpenLink Software"^^xsd:string ;
    ns1:title "Virtuoso"^^xsd:string .

<http://example.org/semantic-web/instance/turtle-format> a ns1:TurtleFormat ;
    rdfs:label "Turtle" ;
    ns1:description "A compact, human-readable RDF serialization format." ;
    ns1:name "Turtle" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/syntax-serialization-layer> .

<http://example.org/semantic-web/instance/unicode-encoding> a ns1:CharacterEncoding ;
    rdfs:label "Unicode" ;
    ns1:description "Universal character encoding support used in the Semantic Web stack." ;
    ns1:name "Unicode" ;
    ns1:partOf <http://example.org/semantic-web/instance/identifier-character-sets-layer> .

<http://example.org/semantic-web/instance/uri-concept> a ns1:URI ;
    rdfs:label "URI" ;
    ns1:description "Uniform Resource Identifier concept used to identify web resources." ;
    ns1:name "URI" ;
    ns1:partOf <http://example.org/semantic-web/instance/identifier-character-sets-layer> .

<http://example.org/semantic-web/instance/web-of-data> a ns1:WebOfData ;
    rdfs:label "Web of Data" ;
    ns1:description "The machine-understandable, data-centric web based on typed relationships and explicit semantics." ;
    ns1:name "Web of Data" .

<http://example.org/semantic-web/instance/web-of-documents> a ns1:WebOfDocuments ;
    rdfs:label "Web of Documents" ;
    ns1:description "The traditional World Wide Web architecture of unstructured and semi-structured documents designed for human consumption." ;
    ns1:name "Web of Documents" .

<http://example.org/semantic-web/instance/wikidata> a ns1:Dataset ;
    rdfs:label "Wikidata" ;
    ns1:description "Central linked open dataset connecting many other open datasets." ;
    ns1:title "Wikidata" .

<http://example.org/semantic-web/instance/world-wide-web-consortium> a ns1:Organization ;
    rdfs:label "World Wide Web Consortium" ;
    ns1:name "World Wide Web Consortium" ;
    ns1:officialName "World Wide Web Consortium" .

<http://example.org/semantic-web/instance/attribute-concept> a ns1:AttributeConcept ;
    rdfs:label "Attributes" ;
    ns1:description "Datatype properties that describe characteristics, features, or data values associated with a class or individual." ;
    ns1:name "Attributes" .

<http://example.org/semantic-web/instance/axiom-concept> a ns1:AxiomConcept ;
    rdfs:label "Axioms" ;
    ns1:description "Logical assertions, constraints, and rules that are always true within an ontology and support reasoning." ;
    ns1:name "Axioms" .

<http://example.org/semantic-web/instance/class-concept> a ns1:ClassConcept ;
    rdfs:label "Classes" ;
    ns1:description "Abstract concepts or categories that exist within a domain and are often organized into taxonomies or hierarchies." ;
    ns1:name "Classes" .

<http://example.org/semantic-web/instance/individual-concept> a ns1:IndividualConcept ;
    rdfs:label "Individuals" ;
    ns1:description "Actual concrete real-world objects that belong to a specific class." ;
    ns1:name "Individuals" .

<http://example.org/semantic-web/instance/proof-rules-layer> a ns1:ProofLayer,
        ns1:RulesLayer ;
    rdfs:label "Proof and rules layer" ;
    ns1:description "Upper Semantic Web layer combining rules, logic, and proof capabilities." ;
    ns1:name "Proof/Rules" .

<http://example.org/semantic-web/instance/relationship-concept> a ns1:RelationshipConcept ;
    rdfs:label "Relationships" ;
    ns1:description "Object properties defining how classes and individuals interact with or relate to one another." ;
    ns1:name "Relationships" .

<http://example.org/semantic-web/instance/trust-layer-instance> a ns1:TrustLayer ;
    rdfs:label "Trust layer" ;
    ns1:description "Upper layer concerning reliability, provenance, and trust in semantic data." ;
    ns1:name "Trust" .

<http://example.org/semantic-web/instance/query-layer-instance> a ns1:QueryLayer ;
    rdfs:label "Query layer" ;
    ns1:description "Layer for querying RDF graphs using SPARQL." ;
    ns1:name "Query" .

<http://example.org/semantic-web/instance/data-model-layer-instance> a ns1:DataModelLayer ;
    rdfs:label "Data model layer" ;
    ns1:description "Layer centered on RDF and RDFS as the fundamental graph data model and schema vocabulary." ;
    ns1:name "Data Model" .

<http://example.org/semantic-web/instance/ontology-layer-instance> a ns1:OntologyLayer ;
    rdfs:label "Ontology layer" ;
    ns1:description "Layer for richer semantic modeling using ontology languages such as OWL and systems such as SKOS." ;
    ns1:name "Ontology" .

<http://example.org/semantic-web/instance/identifier-character-sets-layer> a ns1:IdentifierLayer ;
    rdfs:label "Identifiers and character sets layer" ;
    ns1:description "Layer covering URI/IRI identifiers and Unicode character encoding." ;
    ns1:name "Identifiers and Character Sets" .

<http://example.org/semantic-web/instance/syntax-serialization-layer> a ns1:SyntaxLayer ;
    rdfs:label "Syntax and serialization layer" ;
    ns1:description "Layer for serializing semantic graphs into concrete text formats." ;
    ns1:name "Syntax and Serialization" .

