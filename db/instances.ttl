@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sw: <http://example.org/semantic-web#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sw:GoblinCaveOfAshenvale a sw:Adventure ;
    rdfs:label "The Goblin Cave of Ashenvale" ;
    sw:difficulty "Beginner-friendly" ;
    sw:hasRaceOption sw:Dwarf,
        sw:Elf,
        sw:Human ;
    sw:hasScene sw:Scene1_Millhaven,
        sw:Scene2_HillsideTrail,
        sw:Scene3_GoblinWarren,
        sw:Scene4_ReturnToMillhaven ;
    sw:offersClass sw:FighterClass,
        sw:RogueClass,
        sw:WizardClass ;
    sw:partySizeMax 4 ;
    sw:partySizeMin 2 ;
    sw:recommendedLevel 1 ;
    sw:rewardAmount 50.0 ;
    rdfs:comment "XP awards (summary): quest completion 100 XP; heirloom dagger returned 50 XP; maximum total XP (enemies + quest) 650." .

sw:ChestKey a sw:Item ;
    rdfs:label "Chest Key" ;
    rdfs:comment "Small iron key used to open Aldric's locked wooden chest." .

sw:Chest_GoldChest a sw:Chest ;
    rdfs:label "Gold Chest (Aldric's)",
        "Locked Gold Chest (Aldric's)" ;
    sw:contains sw:Gold_200,
        sw:HealingPotion_S3 ;
    rdfs:comment "Locked wooden chest belonging to Aldric Thorn; contains 200 gp and a healing potion." .

sw:Dwarf a sw:Race ;
    rdfs:label "Dwarf" .

sw:Elf a sw:Race ;
    rdfs:label "Elf" .

sw:FighterClass a sw:PlayerClass ;
    rdfs:label "Fighter" .

sw:Goblin_Chamber1 a sw:Monster ;
    rdfs:label "Goblin (Chamber)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing). Ability: Nimble Escape." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Chamber2 a sw:Monster ;
    rdfs:label "Goblin (Chamber)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing). Ability: Nimble Escape." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Chamber3 a sw:Monster ;
    rdfs:label "Goblin (Chamber)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing). Ability: Nimble Escape." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Guard a sw:Monster ;
    rdfs:label "Goblin (Bodyguard)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing) or Shortbow. Ability: Nimble Escape." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Sentry1 a sw:Monster ;
    rdfs:label "Goblin (Sentry 1)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing, range 80/320 ft). Ability: Nimble Escape (can Disengage or Hide as a bonus action)." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Goblin_Sentry2 a sw:Monster ;
    rdfs:label "Goblin (Sentry 2)" ;
    sw:abilityText "Attacks: Scimitar (+4 to hit, 1d6+2 slashing); Shortbow (+4 to hit, 1d6+2 piercing, range 80/320 ft). Ability: Nimble Escape (can Disengage or Hide as a bonus action)." ;
    sw:armorClass 15 ;
    sw:attackBonus 4 ;
    sw:hp 7 ;
    sw:xpValue 50 .

sw:Gold_12 a sw:Item ;
    rdfs:label "12 gp (scattered around the warren)" ;
    sw:goldAmount 12.0 ;
    sw:quantity 1 .

sw:Gold_200 a sw:Item ;
    rdfs:label "200 gp (stolen chest contents)" ;
    sw:goldAmount 200.0 ;
    sw:quantity 1 .

sw:Gold_3 a sw:Item ;
    rdfs:label "3 gp (found at trail post)" ;
    sw:goldAmount 3.0 ;
    sw:quantity 1 .

sw:Grix a sw:Monster ;
    rdfs:label "Grix (Goblin Boss)" ;
    sw:abilityText "Morningstar attack (+4 to hit, 2d6+2 piercing). Abilities: Redirect Attack (when hit, can redirect attack to a nearby goblin); Multiattack (2 attacks per turn)." ;
    sw:armorClass 17 ;
    sw:attackBonus 4 ;
    sw:carries sw:ChestKey,
        sw:HeirloomDagger ;
    sw:hp 21 ;
    sw:xpValue 200 .

sw:HealingPotion_S2 a sw:Potion ;
    rdfs:label "Healing Potion (tucked in sack near post)" ;
    sw:damage "Restores 2d4+2 HP when consumed (action to drink)" ;
    sw:quantity 1 .

sw:HealingPotion_S3 a sw:Potion ;
    rdfs:label "Healing Potion (in chest)" ;
    sw:damage "Restores 2d4+2 HP when consumed (action to drink)" ;
    sw:quantity 1 .

sw:HeirloomDagger a sw:Weapon ;
    rdfs:label "Heirloom Dagger (Thorn family)" ;
    sw:damage "1d4+1 piercing" ;
    sw:quantity 1 ;
    rdfs:comment "Properties: Finesse, Light, Thrown (range 20/60). Finely-crafted dagger with a silver pommel engraved with the Thorn family crest." .

sw:Human a sw:Race ;
    rdfs:label "Human" .

sw:Location_GoblinWarren a sw:Location ;
    rdfs:label "Ashenvale Burrows (Goblin Warren)" .

sw:Location_HillsideTrail a sw:Location ;
    rdfs:label "Hillside Trail (north of Millhaven)" .

sw:RogueClass a sw:PlayerClass ;
    rdfs:label "Rogue" .

sw:Scene1_Millhaven a sw:Scene ;
    rdfs:label "Scene 1: The Village of Millhaven" ;
    sw:hasLocation sw:Location_Millhaven ;
    sw:hasNPC sw:AldricThorn,
        sw:ElderMira ;
    sw:leadsTo sw:Scene2_HillsideTrail ;
    sw:objectiveText "Learn about the quest and agree to help." ;
    sw:sceneDescription "A small farming village at dusk. Aldric Thorn sits outside the inn, head bandaged and distressed; Elder Mira stands nearby. Players can ask questions to learn direction (north), approximate goblin numbers (4–5), and time of attack (dusk, ~2 hours ago)." .

sw:Scene4_ReturnToMillhaven a sw:Scene ;
    rdfs:label "Scene 4: Return to Millhaven" ;
    sw:hasLocation sw:Location_Millhaven ;
    sw:hasNPC sw:AldricThorn,
        sw:ElderMira ;
    sw:objectiveText "Deliver the chest and dagger to Aldric and Elder Mira; collect the village reward." ;
    sw:sceneDescription "Dawn in Millhaven. Aldric is overjoyed; Elder Mira pays the reward. Additional small roleplay/cleanup scene." .

sw:Scene_DeadEnd_Wilderness a sw:Scene ;
    rdfs:label "Back Crack / Wilderness (dead end)" ;
    sw:sceneDescription "A narrow crack and scramble leading outside; used as an escape route by Grix (dead end for players)." .

sw:TatteredMap a sw:Item ;
    rdfs:label "Tattered Map" ;
    sw:quantity 1 ;
    rdfs:comment "A worn map of the local area (flavor item)." .

sw:WizardClass a sw:PlayerClass ;
    rdfs:label "Wizard" .

sw:AldricThorn a sw:Npc ;
    rdfs:label "Aldric Thorn" ;
    sw:hasRole "Merchant; Quest Giver" ;
    rdfs:comment "Survived the ambush. Owner of the stolen gold chest and the family heirloom dagger (the dagger is especially important to him)." .

sw:ElderMira a sw:Npc ;
    rdfs:label "Elder Mira" ;
    sw:hasRole "Village Elder; Quest Authority" ;
    rdfs:comment "Offers a 50 gp reward for recovery of the stolen goods." .

sw:Location_Millhaven a sw:Location ;
    rdfs:label "Millhaven" .

sw:Scene2_HillsideTrail a sw:Scene ;
    rdfs:label "Scene 2: The Hillside Trail" ;
    sw:dc 13 ;
    sw:hasItem sw:Gold_3,
        sw:HealingPotion_S2 ;
    sw:hasLocation sw:Location_HillsideTrail ;
    sw:hasMonster sw:Goblin_Sentry1,
        sw:Goblin_Sentry2 ;
    sw:leadsTo sw:Scene3_GoblinWarren ;
    sw:objectiveText "Reach the cave. Optional: defeat or sneak past the 2 goblin sentries." ;
    sw:sceneDescription "A rocky trail under a half-moon. Goblin tracks in mud; cave entrance marked by a crude post with a skull." .

sw:Scene3_GoblinWarren a sw:Scene ;
    rdfs:label "Scene 3: The Goblin Warren" ;
    sw:dc 12,
        14 ;
    sw:hasItem sw:Chest_GoldChest,
        sw:Gold_12,
        sw:TatteredMap ;
    sw:hasLocation sw:Location_GoblinWarren ;
    sw:hasMonster sw:Goblin_Chamber1,
        sw:Goblin_Chamber2,
        sw:Goblin_Chamber3,
        sw:Goblin_Guard,
        sw:Grix ;
    sw:leadsTo sw:Scene_DeadEnd_Wilderness ;
    sw:objectiveText "Defeat the goblins, retrieve the chest key from Grix, and open the locked chest." ;
    sw:sceneDescription "Torch-lit cave chamber with bedrolls, gnawed bones, scattered stolen goods, and a locked wooden chest against the far wall. A bolted door leads to Grix's chamber." .

