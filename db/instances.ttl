@prefix ns1: <http://example.org/semantic-web#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/semantic-web/instance/bfo> a ns1:FoundationalOntology ;
    rdfs:label "BFO" ;
    ns1:description "Basic Formal Ontology, a domain-neutral upper-level ontology used as a structural foundation for interoperability across sub-ontologies." ;
    ns1:name "BFO" .

<http://example.org/semantic-web/instance/dbpedia> a ns1:KnowledgeGraph ;
    rdfs:label "DBpedia" ;
    ns1:description "The structured RDF counterpart of Wikipedia and a central hub in the Linked Open Data movement." ;
    ns1:name "DBpedia" ;
    ns1:queriesWith <http://example.org/semantic-web/instance/sparql> ;
    ns1:serializedAs <http://example.org/semantic-web/instance/json-ld>,
        <http://example.org/semantic-web/instance/rdf-xml>,
        <http://example.org/semantic-web/instance/turtle> .

<http://example.org/semantic-web/instance/dublin-core> a ns1:Vocabulary ;
    rdfs:label "Dublin Core" ;
    ns1:description "A standard vocabulary for describing digital and physical resources." ;
    ns1:name "Dublin Core" .

<http://example.org/semantic-web/instance/enterprise-knowledge-graph> a ns1:KnowledgeGraph ;
    rdfs:label "Enterprise Knowledge Graph" ;
    ns1:description "An internal enterprise knowledge graph built using semantic web standards to integrate heterogeneous enterprise data." ;
    ns1:name "Enterprise Knowledge Graph" ;
    ns1:queriesWith <http://example.org/semantic-web/instance/sparql> ;
    ns1:usedFor "Integrating data from CRM systems, ERP software, and supply chain logs without catastrophic database migrations." .

<http://example.org/semantic-web/instance/foaf> a ns1:FoundationalOntology ;
    rdfs:label "FOAF" ;
    ns1:description "Friend of a Friend, used for describing people, their attributes, and their social networks." ;
    ns1:name "FOAF" .

<http://example.org/semantic-web/instance/gene-ontology> a ns1:FoundationalOntology ;
    rdfs:label "Gene Ontology" ;
    ns1:description "A large domain ontology standardizing the representation of gene and protein functions across biology." ;
    ns1:name "Gene Ontology" .

<http://example.org/semantic-web/instance/hermit> a ns1:Reasoner ;
    rdfs:label "HermiT" ;
    ns1:enablesTask <http://example.org/semantic-web/instance/classification>,
        <http://example.org/semantic-web/instance/consistency-checking> ;
    ns1:name "HermiT" .

<http://example.org/semantic-web/instance/linked-open-data> a ns1:Concept ;
    rdfs:label "Linked Open Data" ;
    ns1:description "A global movement to publish structured data so that it can be interlinked." ;
    ns1:name "Linked Open Data" ;
    ns1:usedFor "Publishing and interlinking open structured datasets." .

<http://example.org/semantic-web/instance/openllet> a ns1:Reasoner ;
    rdfs:label "Openllet" ;
    ns1:enablesTask <http://example.org/semantic-web/instance/classification>,
        <http://example.org/semantic-web/instance/consistency-checking> ;
    ns1:name "Openllet" .

<http://example.org/semantic-web/instance/owl-same-as> a ns1:ObjectPropertyConcept ;
    rdfs:label "owl:sameAs" ;
    ns1:description "An explicit predicate used to map different identifiers for the same real-world entity together." ;
    ns1:name "owl:sameAs" .

<http://example.org/semantic-web/instance/pellet> a ns1:Reasoner ;
    rdfs:label "Pellet" ;
    ns1:enablesTask <http://example.org/semantic-web/instance/classification>,
        <http://example.org/semantic-web/instance/consistency-checking> ;
    ns1:name "Pellet" .

<http://example.org/semantic-web/instance/schema-org> a ns1:Vocabulary ;
    rdfs:label "Schema.org" ;
    ns1:definesConcept <http://example.org/semantic-web/instance/knowledge-graph-concept> ;
    ns1:description "A collaborative initiative whose lightweight semantic vocabulary is embedded into HTML using JSON-LD or Microdata." ;
    ns1:name "Schema.org" ;
    ns1:publishedBy <http://example.org/semantic-web/instance/bing>,
        <http://example.org/semantic-web/instance/google>,
        <http://example.org/semantic-web/instance/yahoo>,
        <http://example.org/semantic-web/instance/yandex> ;
    ns1:serializedAs <http://example.org/semantic-web/instance/json-ld>,
        <http://example.org/semantic-web/instance/microdata> ;
    ns1:usedFor "Search engine optimization and feeding data directly into search engine knowledge graphs." .

<http://example.org/semantic-web/instance/semantic-web> a ns1:SemanticWeb ;
    rdfs:label "Semantic Web" ;
    ns1:description "An evolutionary extension of the World Wide Web that transforms the web into a universal medium for data, information, and knowledge exchange by embedding explicit, machine-understandable semantics into web resources." ;
    ns1:name "Semantic Web" ;
    ns1:supportsPrinciple <http://example.org/semantic-web/instance/non-unique-name-assumption>,
        <http://example.org/semantic-web/instance/open-world-assumption> ;
    ns1:usedFor "Universal data, information, and knowledge exchange on the web." .

<http://example.org/semantic-web/instance/semantic-web-layer-cake> a ns1:WebArchitecture ;
    rdfs:label "Semantic Web Layer Cake" ;
    ns1:description "A hierarchical stack of technologies in which each layer builds upon the capabilities of the layer below it." ;
    ns1:hasLayer <http://example.org/semantic-web/instance/data-model-layer>,
        <http://example.org/semantic-web/instance/identifier-layer>,
        <http://example.org/semantic-web/instance/ontology-layer>,
        <http://example.org/semantic-web/instance/proof-layer>,
        <http://example.org/semantic-web/instance/query-layer>,
        <http://example.org/semantic-web/instance/rules-layer>,
        <http://example.org/semantic-web/instance/syntax-layer>,
        <http://example.org/semantic-web/instance/trust-layer> ;
    ns1:name "Semantic Web Layer Cake" .

<http://example.org/semantic-web/instance/thomas-gruber> a ns1:Organization ;
    rdfs:label "Thomas R. Gruber" ;
    ns1:description "Quoted in the source for the definition of ontology." ;
    ns1:name "Thomas R. Gruber" .

<http://example.org/semantic-web/instance/tim-berners-lee> a ns1:Organization ;
    rdfs:label "Tim Berners-Lee" ;
    ns1:description "Identified in the source as championing the Semantic Web." ;
    ns1:name "Tim Berners-Lee" .

<http://example.org/semantic-web/instance/triplestore/allegrograph> a ns1:Triplestore ;
    rdfs:label "AllegroGraph" ;
    ns1:featureText "Document-Graph database with advanced temporal"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/document-graph-database-with-advanced-temporal> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial> ;
    ns1:licenseText "Commercial"^^xsd:string ;
    ns1:maintainedBy <http://example.org/semantic-web/instance/organization/franz-inc> ;
    ns1:name "AllegroGraph"^^xsd:string ;
    ns1:offersInterface <http://example.org/semantic-web/instance/interface/sparql-1-1-python-java-lisp> ;
    ns1:primaryInterfaceText "SPARQL 1.1 / Python / Java / Lisp"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/amazon-neptune> a ns1:Triplestore ;
    rdfs:label "Amazon Neptune" ;
    ns1:featureText "Fully managed cloud database"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/fully-managed-cloud-database> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial-managed-service> ;
    ns1:licenseText "Commercial (Managed Service)"^^xsd:string ;
    ns1:maintainedBy <http://example.org/semantic-web/instance/organization/amazon-web-services-aws> ;
    ns1:name "Amazon Neptune"^^xsd:string ;
    ns1:offersInterface <http://example.org/semantic-web/instance/interface/sparql-apache-tinkerpop-gremlin-opencypher> ;
    ns1:primaryInterfaceText "SPARQL / Apache TinkerPop Gremlin / openCypher"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/anzograph> a ns1:Triplestore ;
    rdfs:label "AnzoGraph" ;
    ns1:featureText "Massively Parallel Processing (MPP) native graph database designed for distributed analytics."^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/massively-parallel-processing-mpp-native-graph-database-designed-for-distributed-analytics> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial> ;
    ns1:licenseText "Commercial"^^xsd:string ;
    ns1:maintainedBy <http://example.org/semantic-web/instance/organization/cambridge-semantics> ;
    ns1:name "AnzoGraph"^^xsd:string ;
    ns1:offersInterface <http://example.org/semantic-web/instance/interface/sparql-1-1-cypher-c-api> ;
    ns1:primaryInterfaceText "SPARQL 1.1 / Cypher / C++ API"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/apache-jena-tdb> a ns1:Triplestore ;
    rdfs:label "Apache Jena TDB" ;
    ns1:featureText "Component of the Apache Jena framework; a native"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/component-of-the-apache-jena-framework-a-native> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/open-source-apache-2-0> ;
    ns1:licenseText "Open Source (Apache 2.0)"^^xsd:string ;
    ns1:maintainedBy <http://example.org/semantic-web/instance/organization/apache-software-foundation> ;
    ns1:name "Apache Jena TDB"^^xsd:string ;
    ns1:offersInterface <http://example.org/semantic-web/instance/interface/sparql-1-1-native-jena-api> ;
    ns1:primaryInterfaceText "SPARQL 1.1 / Native Jena API"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/blazegraph> a ns1:Triplestore ;
    rdfs:label "Blazegraph" ;
    ns1:featureText "High-performance graph database (historically powered Wikidata Query Service)."^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/high-performance-graph-database-historically-powered-wikidata-query-service> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/open-source-gplv3-commercial> ;
    ns1:licenseText "Open Source (GPLv3) / Commercial"^^xsd:string ;
    ns1:maintainedBy <http://example.org/semantic-web/instance/organization/systap-acquired-by-amazon> ;
    ns1:name "Blazegraph"^^xsd:string ;
    ns1:offersInterface <http://example.org/semantic-web/instance/interface/sparql-1-1-blueprint-rdf4j> ;
    ns1:primaryInterfaceText "SPARQL 1.1 / Blueprint / RDF4J"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/graphdb> a ns1:Triplestore ;
    rdfs:label "GraphDB" ;
    ns1:featureText "Advanced RDF/OWL reasoning"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/advanced-rdf-owl-reasoning> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial-free-edition> ;
    ns1:licenseText "Commercial / Free Edition"^^xsd:string ;
    ns1:maintainedBy <http://example.org/semantic-web/instance/organization/ontotext> ;
    ns1:name "GraphDB"^^xsd:string ;
    ns1:offersInterface <http://example.org/semantic-web/instance/interface/sparql-1-1-rdf4j-graphdb-workbench> ;
    ns1:primaryInterfaceText "SPARQL 1.1 / RDF4J / GraphDB Workbench"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/marklogic> a ns1:Triplestore ;
    rdfs:label "MarkLogic" ;
    ns1:featureText "Multi-model NoSQL database integrating XML"^^xsd:string ;
    ns1:hasFeature <http://example.org/semantic-web/instance/feature/multi-model-nosql-database-integrating-xml> ;
    ns1:hasLicenseModel <http://example.org/semantic-web/instance/license-model/commercial> ;
    ns1:licenseText "Commercial"^^xsd:string ;
