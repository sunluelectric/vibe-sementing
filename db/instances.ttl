ns1:identifier-character-set-layer a ns1:IdentifierLayer ;
    rdfs:label "Identifiers and Character Sets Layer" ;
    ns1:isLayerOfArchitecture ns1:semantic-web-layer-cake ;
    ns1:name "Identifiers and Character Sets (URI/IRI, Unicode)" ;
    ns1:precedesLayer ns1:syntax-serialization-layer ;
    ns1:usesTechnology ns1:iri,
        ns1:uri .

ns1:ontology-components-topic a ns1:ConceptualTopic ;
    rdfs:label "Core Components of an Ontology" ;
    ns1:name "Core Components of an Ontology" .

ns1:owl a ns1:Language,
        ns1:OntologyLanguage,
        ns1:Standard ;
    rdfs:label "OWL" ;
    ns1:description "An ontology language standardized by the W3C that extends RDF Schema with advanced structural modeling based on Description Logics." ;
    ns1:hasLogicalProfile ns1:owl-2-el,
        ns1:owl-2-ql,
        ns1:owl-2-rl ;
    ns1:name "Web Ontology Language" ;
    ns1:publishedBy ns1:w3c .

ns1:proof-trust-layer-instance a ns1:ProofTrustLayer ;
    rdfs:label "Proof and Trust Layer" ;
    ns1:dependsOnLayer ns1:rules-layer-instance ;
    ns1:description "The upper Semantic Web layer concerned with proof, provenance, trust, and reliability assessment." ;
    ns1:isLayerOfArchitecture ns1:semantic-web-layer-cake ;
    ns1:name "Proof and Trust" .

ns1:classification-task a ns1:ClassificationTask ;
    rdfs:label "Classification" ;
    ns1:description "The task of computing implied class membership or taxonomy structure from logical definitions." ;
    ns1:name "Classification" .

ns1:consistency-checking-task a ns1:ConsistencyCheckingTask ;
    rdfs:label "Consistency Checking" ;
    ns1:description "The task of analyzing an ontology to find logical contradictions or incompatible assertions." ;
    ns1:name "Consistency Checking" .

ns1:data-model-layer-instance a ns1:DataModelLayer ;
    rdfs:label "Data Model Layer" ;
    ns1:dependsOnLayer ns1:syntax-serialization-layer ;
    ns1:isLayerOfArchitecture ns1:semantic-web-layer-cake ;
    ns1:name "Data Model (RDF and RDFS)" ;
    ns1:precedesLayer ns1:ontology-layer-instance ;
    ns1:usesTechnology ns1:rdf,
        ns1:rdfs .

ns1:iri a ns1:IdentifierScheme ;
    rdfs:label "IRI" ;
    ns1:description "An extension of URIs that allows non-ASCII characters." ;
    ns1:name "IRI" .

ns1:ontology-layer-instance a ns1:OntologyLayer ;
    rdfs:label "Ontology Layer" ;
    ns1:dependsOnLayer ns1:data-model-layer-instance ;
    ns1:isLayerOfArchitecture ns1:semantic-web-layer-cake ;
    ns1:name "Ontology (OWL and SKOS)" ;
    ns1:precedesLayer ns1:query-layer-instance ;
    ns1:usesTechnology ns1:owl,
        ns1:skos .

ns1:query-layer-instance a ns1:QueryLayer ;
    rdfs:label "Query Layer" ;
    ns1:dependsOnLayer ns1:ontology-layer-instance ;
    ns1:isLayerOfArchitecture ns1:semantic-web-layer-cake ;
    ns1:name "Query (SPARQL)" ;
    ns1:precedesLayer ns1:rules-layer-instance ;
    ns1:usesTechnology ns1:sparql .

ns1:rdf a ns1:DataModel,
        ns1:Standard ;
    rdfs:label "RDF" ;
    ns1:description "The fundamental Semantic Web data model that represents data as directed labeled graphs expressed as triples." ;
    ns1:name "Resource Description Framework" ;
    ns1:publishedBy ns1:w3c .

ns1:reasoner-capability a ns1:ReasoningCapability ;
    rdfs:label "Semantic reasoning" ;
    ns1:description "The ability to deduce new information and detect logical consequences from ontology axioms and graph assertions." ;
    ns1:name "Semantic reasoning" .

ns1:rules-layer-instance a ns1:RulesLayer ;
    rdfs:label "Rules Layer" ;
    ns1:dependsOnLayer ns1:query-layer-instance ;
    ns1:isLayerOfArchitecture ns1:semantic-web-layer-cake ;
    ns1:name "Rules and Logic" ;
    ns1:precedesLayer ns1:proof-trust-layer-instance ;
    ns1:usesTechnology ns1:rif,
        ns1:swrl .

ns1:syntax-serialization-layer a ns1:SyntaxLayer ;
    rdfs:label "Syntax and Serialization Layer" ;
    ns1:dependsOnLayer ns1:identifier-character-set-layer ;
    ns1:isLayerOfArchitecture ns1:semantic-web-layer-cake ;
    ns1:name "Syntax and Serialization" ;
    ns1:precedesLayer ns1:data-model-layer-instance ;
    ns1:usesTechnology ns1:json-ld,
        ns1:rdf-xml,
        ns1:turtle .

ns1:w3c a ns1:Organization,
        ns1:StandardsBody ;
    rdfs:label "World Wide Web Consortium" ;
    ns1:name "World Wide Web Consortium" .

<http://example.org/semantic-web/instance/license-model/commercial> a ns1:LicenseModel ;
    rdfs:label "Commercial" .

ns1:semantic-web-layer-cake a ns1:KnowledgeArtifact ;
    rdfs:label "Semantic Web Layer Cake" ;
    ns1:description "A hierarchical stack of Semantic Web technologies in which each layer builds upon the capabilities of the layer below it." ;
    ns1:hasLayer ns1:data-model-layer-instance,
        ns1:identifier-character-set-layer,
        ns1:ontology-layer-instance,
        ns1:proof-trust-layer-instance,
        ns1:query-layer-instance,
        ns1:rules-layer-instance,
        ns1:syntax-serialization-layer ;
    ns1:name "Semantic Web Layer Cake" .

