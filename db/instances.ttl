    rdfs:label "SPARQL 1.1 / RDF4J / GraphDB Workbench" .

<http://example.org/semantic-web/instance/api-interface/sparql-1-1-rest-java-node-js> a ns1:APIInterface ;
    rdfs:label "SPARQL 1.1 / REST / Java / Node.js" .

<http://example.org/semantic-web/instance/api-interface/sparql-1-1-sql-property-graph> a ns1:APIInterface ;
    rdfs:label "SPARQL 1.1 / SQL / Property Graph" .

<http://example.org/semantic-web/instance/api-interface/sparql-apache-tinkerpop-gremlin-opencypher> a ns1:APIInterface ;
    rdfs:label "SPARQL / Apache TinkerPop Gremlin / openCypher" .

<http://example.org/semantic-web/instance/api-interface/sparql-sql-odbc-jdbc> a ns1:APIInterface ;
    rdfs:label "SPARQL / SQL / ODBC / JDBC" .

<http://example.org/semantic-web/instance/feature/advanced-rdf-owl-reasoning> a ns1:Feature ;
    rdfs:label "Advanced RDF/OWL reasoning" .

<http://example.org/semantic-web/instance/feature/component-of-the-apache-jena-framework-a-native> a ns1:Feature ;
    rdfs:label "Component of the Apache Jena framework; a native" .

<http://example.org/semantic-web/instance/feature/document-graph-database-with-advanced-temporal> a ns1:Feature ;
    rdfs:label "Document-Graph database with advanced temporal" .

<http://example.org/semantic-web/instance/feature/enterprise-knowledge-graph-platform-with-virtual-graphs-data-virtualization-and-logic-reasoning> a ns1:Feature ;
    rdfs:label "Enterprise knowledge graph platform with virtual graphs (data virtualization) and logic reasoning." .

<http://example.org/semantic-web/instance/feature/enterprise-rdf-semantic-graph-support-built-natively-into-oracle-database> a ns1:Feature ;
    rdfs:label "Enterprise RDF semantic graph support built natively into Oracle Database." .

<http://example.org/semantic-web/instance/feature/fully-managed-cloud-database> a ns1:Feature ;
    rdfs:label "Fully managed cloud database" .

<http://example.org/semantic-web/instance/feature/high-performance-graph-database-historically-powered-wikidata-query-service> a ns1:Feature ;
    rdfs:label "High-performance graph database (historically powered Wikidata Query Service)." .

<http://example.org/semantic-web/instance/feature/hybrid-relational-rdf-engine> a ns1:Feature ;
    rdfs:label "Hybrid relational/RDF engine" .

<http://example.org/semantic-web/instance/feature/java-framework-for-processing-rdf-data-that-includes-an-in-memory-and-disk-based-triplestore> a ns1:Feature ;
    rdfs:label "Java framework for processing RDF data that includes an in-memory and disk-based triplestore." .

