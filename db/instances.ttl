    rdfs:label "Cambridge Semantics" .

<http://example.org/semantic-web/instance/organization/eclipse-foundation> a ns1:Organization ;
    rdfs:label "Eclipse Foundation" .

<http://example.org/semantic-web/instance/organization/franz-inc> a ns1:Organization ;
    rdfs:label "Franz Inc." .

