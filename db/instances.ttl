    rdfs:label "IRI" ;
    ns1:description "Internationalized Resource Identifier, an extension of URI that allows non-ASCII characters." ;
    ns1:name "IRI" ;
    ns1:usedFor "Assigning global, unique identifiers to entities to prevent naming collisions across disparate databases." .

