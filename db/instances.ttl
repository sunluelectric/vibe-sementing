    ns1:offersInterface <http://example.org/semantic-web/instance/interface/sparql-sql-odbc-jdbc> ;
    ns1:primaryInterfaceText "SPARQL / SQL / ODBC / JDBC"^^xsd:string .

<http://example.org/semantic-web/instance/wikidata> a ns1:KnowledgeGraph ;
    rdfs:label "Wikidata" ;
    ns1:description "A central hub connecting many open datasets in the Web of Data." ;
    ns1:name "Wikidata" ;
    ns1:queriesWith <http://example.org/semantic-web/instance/sparql> ;
    ns1:serializedAs <http://example.org/semantic-web/instance/json-ld> .

<http://example.org/semantic-web/instance/axiom-primitive> a ns1:Axiom ;
    rdfs:label "Axiom" ;
    ns1:description "An explicit logical assertion that constrains the model and supports reasoning." ;
    ns1:name "Axiom" .

<http://example.org/semantic-web/instance/bing> a ns1:Organization ;
    rdfs:label "Bing" ;
    ns1:name "Bing" .

<http://example.org/semantic-web/instance/cardinality-constraint-axiom> a ns1:CardinalityConstraint ;
    rdfs:label "Cardinality Constraint" ;
    ns1:description "A restriction that limits how many relationships an entity can have." ;
    ns1:name "Cardinality Constraint" .

<http://example.org/semantic-web/instance/class-restriction-axiom> a ns1:ClassRestriction ;
    rdfs:label "Class Restriction" ;
    ns1:description "A class-level restriction expressed with logical quantifiers over properties." ;
    ns1:name "Class Restriction" .

<http://example.org/semantic-web/instance/constraint-axiom> a ns1:Constraint ;
    rdfs:label "Constraint" ;
    ns1:description "A logical constraint used to define domain boundaries and rules." ;
    ns1:name "Constraint" .

<http://example.org/semantic-web/instance/data-model-layer> a ns1:DataModelLayer ;
    rdfs:label "Data Model Layer" ;
    ns1:layerUsesTechnology <http://example.org/semantic-web/instance/rdf>,
        <http://example.org/semantic-web/instance/rdfs> ;
    ns1:name "Data Model Layer" .

<http://example.org/semantic-web/instance/datatype-property-primitive> a ns1:DatatypePropertyConcept ;
    rdfs:label "Datatype Property" ;
    ns1:description "A property that links a class or individual to a primitive data value such as a string, integer, or boolean." ;
    ns1:name "Datatype Property" .

<http://example.org/semantic-web/instance/disjointness-axiom> a ns1:DisjointnessAxiom ;
    rdfs:label "Disjointness Axiom" ;
    ns1:description "An axiom declaring that classes do not overlap." ;
    ns1:name "Disjointness Axiom" .

