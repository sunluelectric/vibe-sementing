<http://example.org/agent/franz-inc> a ns1:Agent ;
    rdfs:label "Franz Inc." .

<http://example.org/agent/ontotext> a ns1:Agent ;
    rdfs:label "Ontotext" .

<http://example.org/agent/openlink-software> a ns1:Agent ;
    rdfs:label "OpenLink Software" .

<http://example.org/agent/oracle> a ns1:Agent ;
