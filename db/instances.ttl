<http://example.org/semantic-web/instance/non-unique-name-assumption> a ns1:NonUniqueNameAssumption ;
    rdfs:label "Non-Unique Name Assumption" ;
    ns1:description "Two different URIs can refer to the same real-world entity." ;
    ns1:name "Non-Unique Name Assumption" ;
    ns1:usedFor "Identity reconciliation across decentralized data silos." .

<http://example.org/semantic-web/instance/object-property-primitive> a ns1:ObjectPropertyConcept ;
    rdfs:label "Object Property" ;
    ns1:description "A binary relation that connects one resource to another." ;
    ns1:name "Object Property" .

<http://example.org/semantic-web/instance/ontology-class-primitive> a ns1:OntologyClass ;
    rdfs:label "Class" ;
    ns1:description "An abstract concept or category within a domain, typically organized into taxonomies or hierarchies." ;
    ns1:name "Class" .

<http://example.org/semantic-web/instance/ontology-individual-primitive> a ns1:OntologyIndividual ;
    rdfs:label "Individual" ;
    ns1:description "A concrete real-world object or data point that belongs to a class." ;
    ns1:name "Individual" .

<http://example.org/semantic-web/instance/ontology-layer> a ns1:OntologyLayer ;
    rdfs:label "Ontology Layer" ;
    ns1:layerUsesTechnology <http://example.org/semantic-web/instance/owl>,
        <http://example.org/semantic-web/instance/skos> ;
    ns1:name "Ontology Layer" .

<http://example.org/semantic-web/instance/open-world-assumption> a ns1:OpenWorldAssumption ;
    rdfs:label "Open World Assumption" ;
    ns1:description "In the Semantic Web, missing information is treated as unknown rather than false." ;
    ns1:name "Open World Assumption" .

<http://example.org/semantic-web/instance/organization/amazon-web-services-aws> a ns1:Organization ;
    rdfs:label "Amazon Web Services (AWS)" .

<http://example.org/semantic-web/instance/organization/apache-software-foundation> a ns1:Organization ;
    rdfs:label "Apache Software Foundation" .

<http://example.org/semantic-web/instance/organization/cambridge-semantics> a ns1:Organization ;
    rdfs:label "Cambridge Semantics" .

<http://example.org/semantic-web/instance/organization/eclipse-foundation> a ns1:Organization ;
    rdfs:label "Eclipse Foundation" .

<http://example.org/semantic-web/instance/organization/franz-inc> a ns1:Organization ;
    rdfs:label "Franz Inc." .

<http://example.org/semantic-web/instance/organization/ontotext> a ns1:Organization ;
    rdfs:label "Ontotext" .

<http://example.org/semantic-web/instance/organization/openlink-software> a ns1:Organization ;
    rdfs:label "OpenLink Software" .

<http://example.org/semantic-web/instance/organization/oracle> a ns1:Organization ;
    rdfs:label "Oracle" .

<http://example.org/semantic-web/instance/organization/progress-software> a ns1:Organization ;
    rdfs:label "Progress Software" .

<http://example.org/semantic-web/instance/organization/stardog-union> a ns1:Organization ;
    rdfs:label "Stardog Union" .

<http://example.org/semantic-web/instance/organization/systap-acquired-by-amazon> a ns1:Organization ;
    rdfs:label "Systap (acquired by Amazon)" .

<http://example.org/semantic-web/instance/owl> a ns1:OntologyLanguage ;
    rdfs:label "OWL" ;
    ns1:description "Web Ontology Language, an ontology language standardized by the W3C and based on Description Logics." ;
    ns1:enablesTask <http://example.org/semantic-web/instance/classification>,
        <http://example.org/semantic-web/instance/consistency-checking> ;
    ns1:extendsTechnology <http://example.org/semantic-web/instance/rdfs> ;
    ns1:hasProfile <http://example.org/semantic-web/instance/owl-2-el>,
        <http://example.org/semantic-web/instance/owl-2-ql>,
        <http://example.org/semantic-web/instance/owl-2-rl> ;
    ns1:name "OWL" ;
    ns1:publishedBy <http://example.org/semantic-web/instance/w3c> .

<http://example.org/semantic-web/instance/owl-2-el> a ns1:OntologyProfile ;
    rdfs:label "OWL 2 EL" ;
    ns1:description "A profile tailored for domains with massive numbers of classes and complex subclass hierarchies but relatively simple property relationships." ;
    ns1:name "OWL 2 EL" ;
    ns1:usedFor "Biomedical ontologies such as SNOMED CT." .

<http://example.org/semantic-web/instance/owl-2-ql> a ns1:OntologyProfile ;
    rdfs:label "OWL 2 QL" ;
    ns1:description "A profile designed to work smoothly with standard relational databases by allowing semantic queries to be translated into optimized SQL." ;
    ns1:name "OWL 2 QL" ;
    ns1:usedFor "Enterprise data virtualization and data integration." .

<http://example.org/semantic-web/instance/owl-2-rl> a ns1:OntologyProfile ;
    rdfs:label "OWL 2 RL" ;
    ns1:description "A profile optimized for applications requiring heavy relational reasoning while preserving scalability through rule-engine-friendly mappings." ;
    ns1:name "OWL 2 RL" ;
    ns1:usedFor "Financial fraud detection and compliance tracking systems." .

<http://example.org/semantic-web/instance/proof-layer> a ns1:ProofLayer ;
    rdfs:label "Proof Layer" ;
    ns1:name "Proof Layer" .

<http://example.org/semantic-web/instance/property-characteristic-axiom> a ns1:PropertyCharacteristic ;
    rdfs:label "Property Characteristic" ;
    ns1:description "A property-level logical feature such as transitive, symmetric, functional, or inverse." ;
    ns1:name "Property Characteristic" .

<http://example.org/semantic-web/instance/query-layer> a ns1:QueryLayer ;
    rdfs:label "Query Layer" ;
    ns1:layerUsesTechnology <http://example.org/semantic-web/instance/sparql> ;
    ns1:name "Query Layer" .

<http://example.org/semantic-web/instance/rif> a ns1:RuleLanguage ;
    rdfs:label "RIF" ;
    ns1:description "A rule language used in the upper logic layer of the Semantic Web." ;
    ns1:name "RIF" .

<http://example.org/semantic-web/instance/rules-layer> a ns1:RulesLayer ;
    rdfs:label "Rules Layer" ;
    ns1:layerUsesTechnology <http://example.org/semantic-web/instance/rif>,
        <http://example.org/semantic-web/instance/swrl> ;
    ns1:name "Rules Layer" .

<http://example.org/semantic-web/instance/skos> a ns1:OntologyLanguage ;
    rdfs:label "SKOS" ;
    ns1:description "Simple Knowledge Organization System, used to represent basic thesauri, taxonomies, and classification schemes that do not require full Description Logics." ;
    ns1:name "SKOS" ;
    ns1:publishedBy <http://example.org/semantic-web/instance/w3c> .

<http://example.org/semantic-web/instance/swrl> a ns1:RuleLanguage ;
    rdfs:label "SWRL" ;
    ns1:description "A rule language that combines ontologies with Horn-clause logic rules for advanced reasoning." ;
    ns1:name "SWRL" .

<http://example.org/semantic-web/instance/syntax-layer> a ns1:SyntaxLayer ;
    rdfs:label "Syntax and Serialization Layer" ;
    ns1:layerUsesTechnology <http://example.org/semantic-web/instance/json-ld>,
        <http://example.org/semantic-web/instance/rdf-xml>,
        <http://example.org/semantic-web/instance/turtle> ;
    ns1:name "Syntax and Serialization Layer" .

<http://example.org/semantic-web/instance/trust-layer> a ns1:TrustLayer ;
    rdfs:label "Trust Layer" ;
    ns1:name "Trust Layer" ;
    ns1:usedFor "Cryptographic verification and provenance tracking to determine the reliability of semantic data." .

<http://example.org/semantic-web/instance/unicode> a ns1:CharacterSetStandard ;
    rdfs:label "Unicode" ;
    ns1:description "Universal character encoding support for semantic web data." ;
    ns1:name "Unicode" .

<http://example.org/semantic-web/instance/uri> a ns1:IdentifierScheme ;
    rdfs:label "URI" ;
    ns1:description "Uniform Resource Identifier technology used to identify resources." ;
    ns1:name "URI" .

<http://example.org/semantic-web/instance/yahoo> a ns1:Organization ;
    rdfs:label "Yahoo!" ;
    ns1:name "Yahoo!" .

<http://example.org/semantic-web/instance/yandex> a ns1:Organization ;
    rdfs:label "Yandex" ;
    ns1:name "Yandex" .

<http://example.org/semantic-web/instance/ontology-as-concept> a ns1:Ontology ;
    rdfs:label "Ontology" ;
    ns1:contrastsWith <http://example.org/semantic-web/instance/knowledge-graph-concept>,
        <http://example.org/semantic-web/instance/taxonomy-concept> ;
    ns1:description "A formal, explicit specification of a shared conceptualization." ;
    ns1:hasAxiom <http://example.org/semantic-web/instance/cardinality-constraint-axiom>,
        <http://example.org/semantic-web/instance/class-restriction-axiom>,
        <http://example.org/semantic-web/instance/constraint-axiom>,
        <http://example.org/semantic-web/instance/disjointness-axiom>,
        <http://example.org/semantic-web/instance/property-characteristic-axiom> ;
    ns1:hasPrimitive <http://example.org/semantic-web/instance/axiom-primitive>,
        <http://example.org/semantic-web/instance/datatype-property-primitive>,
        <http://example.org/semantic-web/instance/object-property-primitive>,
        <http://example.org/semantic-web/instance/ontology-class-primitive>,
        <http://example.org/semantic-web/instance/ontology-individual-primitive> ;
    ns1:name "Ontology" .

<http://example.org/semantic-web/instance/rdf> a ns1:DataModelTechnology ;
    rdfs:label "RDF" ;
    ns1:description "Resource Description Framework, the fundamental semantic web data model representing data as a directed labeled graph of triples." ;
    ns1:name "RDF" ;
    ns1:serializedAs <http://example.org/semantic-web/instance/json-ld>,
        <http://example.org/semantic-web/instance/rdf-xml>,
        <http://example.org/semantic-web/instance/turtle> .

<http://example.org/semantic-web/instance/rdfs> a ns1:DataModelTechnology ;
    rdfs:label "RDFS" ;
    ns1:description "RDF Schema, a foundational vocabulary for basic hierarchies, classes, domains, and ranges." ;
    ns1:extendsTechnology <http://example.org/semantic-web/instance/rdf> ;
    ns1:name "RDFS" ;
    ns1:serializedAs <http://example.org/semantic-web/instance/json-ld>,
        <http://example.org/semantic-web/instance/rdf-xml>,
        <http://example.org/semantic-web/instance/turtle> .

<http://example.org/semantic-web/instance/taxonomy-concept> a ns1:Taxonomy ;
    rdfs:label "Taxonomy" ;
    ns1:contrastsWith <http://example.org/semantic-web/instance/knowledge-graph-concept>,
        <http://example.org/semantic-web/instance/ontology-as-concept> ;
    ns1:description "A narrow hierarchical classification scheme focused on tree-like parental structures and lacking advanced properties or logic." ;
    ns1:name "Taxonomy" .

<http://example.org/semantic-web/instance/knowledge-graph-concept> a ns1:KnowledgeGraph ;
    rdfs:label "Knowledge Graph" ;
    ns1:contrastsWith <http://example.org/semantic-web/instance/ontology-as-concept>,
        <http://example.org/semantic-web/instance/taxonomy-concept> ;
    ns1:description "A network of real-world entities connected by typed relationships that represents actual data instance networks." ;
    ns1:name "Knowledge Graph" ;
    ns1:queriesWith <http://example.org/semantic-web/instance/sparql> ;
    ns1:serializedAs <http://example.org/semantic-web/instance/json-ld>,
        <http://example.org/semantic-web/instance/rdf-xml>,
        <http://example.org/semantic-web/instance/turtle> .

<http://example.org/semantic-web/instance/w3c> a ns1:Organization ;
    rdfs:label "World Wide Web Consortium" ;
    ns1:name "World Wide Web Consortium" .

<http://example.org/semantic-web/instance/classification> a ns1:ClassificationTask ;
    rdfs:label "Classification" ;
    ns1:description "Automatic computation of the logical class hierarchy and inferred class membership." ;
    ns1:name "Classification" .

<http://example.org/semantic-web/instance/consistency-checking> a ns1:ConsistencyCheckingTask ;
    rdfs:label "Consistency Checking" ;
    ns1:description "Analysis of an ontology to find logical contradictions." ;
    ns1:name "Consistency Checking" .

<http://example.org/semantic-web/instance/license-model/commercial> a ns1:LicenseModel ;
    rdfs:label "Commercial" .

<http://example.org/semantic-web/instance/rdf-xml> a ns1:SerializationFormat ;
    rdfs:label "RDF/XML" ;
    ns1:description "The historical XML-based RDF serialization format." ;
    ns1:name "RDF/XML" .

<http://example.org/semantic-web/instance/sparql> a ns1:QueryLanguage ;
    rdfs:label "SPARQL" ;
    ns1:description "SPARQL Protocol and RDF Query Language, the SQL equivalent for the Semantic Web." ;
    ns1:name "SPARQL" ;
    ns1:publishedBy <http://example.org/semantic-web/instance/w3c> ;
    ns1:usedFor "Executing graph-pattern matching against RDF graphs, including across federated endpoints." .

<http://example.org/semantic-web/instance/turtle> a ns1:SerializationFormat ;
    rdfs:label "Turtle" ;
    ns1:description "A compact, human-readable RDF serialization format." ;
    ns1:name "Turtle" .

<http://example.org/semantic-web/instance/json-ld> a ns1:SerializationFormat ;
    rdfs:label "JSON-LD" ;
    ns1:description "JSON for Linking Data, a format that injects semantic data into standard JSON structures." ;
    ns1:name "JSON-LD" .

