@prefix ns1: <http://example.org/semantic-web#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/semantic-web/instance/bfo> a ns1:FoundationalOntology ;
    rdfs:label "BFO" ;
    ns1:description "A domain-neutral upper-level ontology used as a structural foundation for interoperability across sub-ontologies." ;
    ns1:name "Basic Formal Ontology" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/bing> a ns1:Organization ;
    rdfs:label "Bing" ;
    ns1:name "Bing" ;
    ns1:officialName "Bing" .

<http://example.org/semantic-web/instance/classification-reasoning> a ns1:ClassificationReasoning ;
    rdfs:label "Classification" ;
    ns1:description "A reasoning process that computes logical implications of class definitions and derives correct hierarchy placement." ;
    ns1:name "Classification" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/closed-world-assumption> a ns1:ClosedWorldAssumption ;
    rdfs:label "Closed World Assumption" ;
    ns1:description "The principle that information not present is generally treated as false in traditional database settings." ;
    ns1:name "Closed World Assumption" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/consistency-checking> a ns1:ConsistencyChecking ;
    rdfs:label "Consistency Checking" ;
    ns1:description "A reasoning process that detects logical contradictions in an ontology or its data." ;
    ns1:name "Consistency Checking" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/data-integration-use-case> a ns1:DataIntegrationUseCase ;
    rdfs:label "Data Integration" ;
    ns1:description "A use case involving integration of heterogeneous data using semantic technologies." ;
    ns1:name "Data Integration" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/data-virtualization-use-case> a ns1:DataVirtualizationUseCase ;
    rdfs:label "Data Virtualization" ;
    ns1:description "A use case involving semantic access to distributed data without full physical consolidation." ;
    ns1:name "Data Virtualization" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/dbpedia> a ns1:Dataset ;
    rdfs:label "DBpedia" ;
    ns1:description "The structured RDF counterpart of Wikipedia and a central hub in Linked Open Data." ;
    ns1:name "DBpedia" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/dublin-core> a ns1:Vocabulary ;
    rdfs:label "Dublin Core" ;
    ns1:description "A standard vocabulary for describing digital and physical resources." ;
    ns1:name "Dublin Core" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/enterprise-knowledge-graph> a ns1:EnterpriseKnowledgeGraph ;
    rdfs:label "Enterprise Knowledge Graph" ;
    ns1:description "An enterprise application area that uses semantic web standards to integrate internal data sources into knowledge graphs." ;
    ns1:name "Enterprise Knowledge Graph" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/foaf> a ns1:FoundationalOntology ;
    rdfs:label "FOAF" ;
    ns1:description "A foundational ontology used for describing people, their attributes, and their social networks." ;
    ns1:name "Friend of a Friend" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/gene-ontology> a ns1:Ontology ;
    rdfs:label "Gene Ontology" ;
    ns1:description "A large domain ontology standardizing the representation of gene and protein functions across biology." ;
    ns1:name "Gene Ontology" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/google> a ns1:Organization ;
    rdfs:label "Google" ;
    ns1:name "Google" ;
    ns1:officialName "Google" .

<http://example.org/semantic-web/instance/hermit> a ns1:Reasoner ;
    rdfs:label "HermiT" ;
    ns1:description "A reasoner named in the source as an example of software used to perform semantic reasoning." ;
    ns1:name "HermiT" .

<http://example.org/semantic-web/instance/iri> a ns1:IRI ;
    rdfs:label "IRI" ;
    ns1:description "An extension of URI that allows non-ASCII characters and provides global identification for entities." ;
    ns1:name "Internationalized Resource Identifier" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/identifier-layer> .

<http://example.org/semantic-web/instance/json-ld> a ns1:JSONLDFormat ;
    rdfs:label "JSON-LD" ;
    ns1:description "A JSON-based format for linked data widely used in web development." ;
    ns1:name "JSON-LD" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/syntax-layer> .

<http://example.org/semantic-web/instance/knowledge-graph> a ns1:KnowledgeGraph ;
    rdfs:label "Knowledge Graph" ;
    ns1:description "A network of real-world entities connected by relationships that represents actual data instance networks." ;
    ns1:name "Knowledge Graph" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/linked-open-data> a ns1:LinkedOpenData ;
    rdfs:label "Linked Open Data" ;
    ns1:description "A movement to publish structured data so that it can be interlinked across the web." ;
    ns1:name "Linked Open Data" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/microdata> a ns1:MicrodataTechnology ;
    rdfs:label "Microdata" ;
    ns1:description "A lightweight mechanism for embedding structured data into HTML pages." ;
    ns1:name "Microdata" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/non-unique-name-assumption> a ns1:NonUniqueNameAssumption ;
    rdfs:label "Non-Unique Name Assumption" ;
    ns1:description "The principle that two different URIs may refer to the same real-world entity." ;
    ns1:name "Non-Unique Name Assumption" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/ontology-conceptual-artifact> a ns1:Ontology ;
    rdfs:label "Ontology" ;
    ns1:description "A formal, explicit specification of a shared conceptualization that provides the conceptual schema and rules behind a knowledge graph." ;
    ns1:hasComponent <http://example.org/semantic-web/instance/attribute-concept>,
        <http://example.org/semantic-web/instance/axiom-concept>,
        <http://example.org/semantic-web/instance/class-concept>,
        <http://example.org/semantic-web/instance/individual-concept>,
        <http://example.org/semantic-web/instance/relationship-concept> ;
    ns1:name "Ontology" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/open-world-assumption> a ns1:OpenWorldAssumption ;
    rdfs:label "Open World Assumption" ;
    ns1:description "The principle that missing information should be treated as unknown rather than false." ;
    ns1:name "Open World Assumption" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/openllet> a ns1:Reasoner ;
    rdfs:label "Openllet" ;
    ns1:description "A reasoner named in the source as an example of software used to perform semantic reasoning." ;
    ns1:name "Openllet" .

<http://example.org/semantic-web/instance/owl> a ns1:OWLTechnology ;
    rdfs:label "OWL" ;
    ns1:description "An ontology language for advanced semantic modeling based on description logics." ;
    ns1:name "Web Ontology Language" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/ontology-layer> .

<http://example.org/semantic-web/instance/owl-2-el> a ns1:OWL2ELProfile ;
    rdfs:label "OWL 2 EL" ;
    ns1:description "An OWL 2 profile tailored for massive numbers of classes and complex subclass hierarchies with relatively simple property relationships." ;
    ns1:name "OWL 2 EL" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/owl-2-ql> a ns1:OWL2QLProfile ;
    rdfs:label "OWL 2 QL" ;
    ns1:description "An OWL 2 profile designed to work smoothly with standard relational databases and support translation of semantic queries into SQL." ;
    ns1:name "OWL 2 QL" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/owl-2-rl> a ns1:OWL2RLProfile ;
    rdfs:label "OWL 2 RL" ;
    ns1:description "An OWL 2 profile optimized for scalable rule-oriented reasoning using rule engines." ;
    ns1:name "OWL 2 RL" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/pellet> a ns1:Reasoner ;
    rdfs:label "Pellet" ;
    ns1:description "A reasoner named in the source as an example of software used to perform semantic reasoning." ;
    ns1:name "Pellet" .

<http://example.org/semantic-web/instance/rdf> a ns1:RDFTechnology ;
    rdfs:label "RDF" ;
    ns1:description "The fundamental semantic web data model representing information as directed labeled graphs composed of triples." ;
    ns1:name "Resource Description Framework" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/data-model-layer> .

<http://example.org/semantic-web/instance/rdf-xml> a ns1:RDFXMLFormat ;
    rdfs:label "RDF/XML" ;
    ns1:description "A historical XML-based RDF serialization format." ;
    ns1:name "RDF/XML" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/syntax-layer> .

<http://example.org/semantic-web/instance/rdfs> a ns1:RDFSchemaTechnology ;
    rdfs:label "RDF Schema" ;
    ns1:description "A foundational vocabulary for classes, subclass hierarchies, domains, and ranges." ;
    ns1:name "RDF Schema" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/data-model-layer> .

<http://example.org/semantic-web/instance/schema-org> a ns1:Vocabulary ;
    rdfs:label "Schema.org" ;
    ns1:description "A collaborative semantic vocabulary initiative used heavily on the web for structured data and search engine optimization." ;
    ns1:name "Schema.org" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/search-engine-knowledge-graph> a ns1:SearchEngineKnowledgeGraph ;
    rdfs:label "Search Engine Knowledge Graph" ;
    ns1:description "A knowledge-graph application area supporting search engine understanding and presentation of structured knowledge." ;
    ns1:name "Search Engine Knowledge Graph" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/skos> a ns1:SKOSTechnology ;
    rdfs:label "SKOS" ;
    ns1:description "A vocabulary for representing thesauri, taxonomies, and classification schemes that do not require full description logics." ;
    ns1:name "Simple Knowledge Organization System" ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/ontology-layer> .

<http://example.org/semantic-web/instance/sparql> a ns1:SPARQLTechnology ;
    rdfs:label "SPARQL" ;
    ns1:description "The query language used for graph-pattern matching against RDF graphs." ;
    ns1:name "SPARQL Protocol and RDF Query Language" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/query-layer> .

<http://example.org/semantic-web/instance/taxonomy> a ns1:Taxonomy ;
    rdfs:label "Taxonomy" ;
    ns1:description "A narrow hierarchical classification scheme focused on tree-like parental structures." ;
    ns1:name "Taxonomy" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/thomas-gruber> a ns1:Entity ;
    rdfs:label "Thomas R. Gruber" ;
    ns1:description "Computer scientist quoted in the source for the definition of an ontology as a formal, explicit specification of a shared conceptualization." ;
    ns1:name "Thomas R. Gruber" .

<http://example.org/semantic-web/instance/tim-berners-lee> a ns1:Entity ;
    rdfs:label "Tim Berners-Lee" ;
    ns1:description "Named in the source as a champion of the Semantic Web vision." ;
    ns1:name "Tim Berners-Lee" .

<http://example.org/semantic-web/instance/triplestore/allegrograph> a ns1:Triplestore ;
    rdfs:label "AllegroGraph" ;
    ns1:description "Commercial"^^xsd:string,
        "Document-Graph database with advanced temporal"^^xsd:string,
        "Franz Inc."^^xsd:string,
        "SPARQL 1.1 / Python / Java / Lisp"^^xsd:string ;
    ns1:name "AllegroGraph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/amazon-neptune> a ns1:Triplestore ;
    rdfs:label "Amazon Neptune" ;
    ns1:description "Amazon Web Services (AWS)"^^xsd:string,
        "Commercial (Managed Service)"^^xsd:string,
        "Fully managed cloud database"^^xsd:string,
        "SPARQL / Apache TinkerPop Gremlin / openCypher"^^xsd:string ;
    ns1:name "Amazon Neptune"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/anzograph> a ns1:Triplestore ;
    rdfs:label "AnzoGraph" ;
    ns1:description "Cambridge Semantics"^^xsd:string,
        "Commercial"^^xsd:string,
        "Massively Parallel Processing (MPP) native graph database designed for distributed analytics."^^xsd:string,
        "SPARQL 1.1 / Cypher / C++ API"^^xsd:string ;
    ns1:name "AnzoGraph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/apache-jena-tdb> a ns1:Triplestore ;
    rdfs:label "Apache Jena TDB" ;
    ns1:description "Apache Software Foundation"^^xsd:string,
        "Component of the Apache Jena framework; a native"^^xsd:string,
        "Open Source (Apache 2.0)"^^xsd:string,
        "SPARQL 1.1 / Native Jena API"^^xsd:string ;
    ns1:name "Apache Jena TDB"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/blazegraph> a ns1:Triplestore ;
    rdfs:label "Blazegraph" ;
    ns1:description "High-performance graph database (historically powered Wikidata Query Service)."^^xsd:string,
        "Open Source (GPLv3) / Commercial"^^xsd:string,
        "SPARQL 1.1 / Blueprint / RDF4J"^^xsd:string,
        "Systap (acquired by Amazon)"^^xsd:string ;
    ns1:name "Blazegraph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/graphdb> a ns1:Triplestore ;
    rdfs:label "GraphDB" ;
    ns1:description "Advanced RDF/OWL reasoning"^^xsd:string,
        "Commercial / Free Edition"^^xsd:string,
        "Ontotext"^^xsd:string,
        "SPARQL 1.1 / RDF4J / GraphDB Workbench"^^xsd:string ;
    ns1:name "GraphDB"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/marklogic> a ns1:Triplestore ;
    rdfs:label "MarkLogic" ;
    ns1:description "Commercial"^^xsd:string,
        "Multi-model NoSQL database integrating XML"^^xsd:string,
        "Progress Software"^^xsd:string,
        "SPARQL 1.1 / REST / Java / Node.js"^^xsd:string ;
    ns1:name "MarkLogic"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/oracle-spatial-and-graph> a ns1:Triplestore ;
    rdfs:label "Oracle Spatial and Graph" ;
    ns1:description "Commercial"^^xsd:string,
        "Enterprise RDF semantic graph support built natively into Oracle Database."^^xsd:string,
        "Oracle"^^xsd:string,
        "SPARQL 1.1 / SQL / Property Graph"^^xsd:string ;
    ns1:name "Oracle Spatial and Graph"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/rdf4j-formerly-sesame> a ns1:Triplestore ;
    rdfs:label "RDF4J (formerly Sesame)" ;
    ns1:description "Eclipse Foundation"^^xsd:string,
        "Java framework for processing RDF data that includes an in-memory and disk-based triplestore."^^xsd:string,
        "Open Source (EDL)"^^xsd:string,
        "SPARQL 1.1 / RDF4J API"^^xsd:string ;
    ns1:name "RDF4J (formerly Sesame)"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/stardog> a ns1:Triplestore ;
    rdfs:label "Stardog" ;
    ns1:description "Commercial"^^xsd:string,
        "Enterprise knowledge graph platform with virtual graphs (data virtualization) and logic reasoning."^^xsd:string,
        "SPARQL 1.1 / GraphQL / Java API"^^xsd:string,
        "Stardog Union"^^xsd:string ;
    ns1:name "Stardog"^^xsd:string .

<http://example.org/semantic-web/instance/triplestore/virtuoso> a ns1:Triplestore ;
    rdfs:label "Virtuoso" ;
    ns1:description "Hybrid relational/RDF engine"^^xsd:string,
        "Open Source (GPLv2) / Commercial"^^xsd:string,
        "OpenLink Software"^^xsd:string,
        "SPARQL / SQL / ODBC / JDBC"^^xsd:string ;
    ns1:name "Virtuoso"^^xsd:string .

<http://example.org/semantic-web/instance/turtle> a ns1:TurtleFormat ;
    rdfs:label "Turtle" ;
    ns1:description "A compact, human-readable RDF serialization format." ;
    ns1:name "Turtle" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/syntax-layer> .

<http://example.org/semantic-web/instance/unicode> a ns1:CharacterEncoding ;
    rdfs:label "Unicode" ;
    ns1:description "A universal character encoding system supporting semantic web identifiers and content." ;
    ns1:name "Unicode" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/uri> a ns1:URI ;
    rdfs:label "URI" ;
    ns1:description "An identifier used to identify resources on the web." ;
    ns1:name "Uniform Resource Identifier" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> ;
    ns1:supportsLayer <http://example.org/semantic-web/instance/identifier-layer> .

<http://example.org/semantic-web/instance/w3c> a ns1:Organization ;
    rdfs:label "World Wide Web Consortium" ;
    ns1:description "The standards organization that initiated and standardized key Semantic Web technologies." ;
    ns1:homepage "https://www.w3.org/"^^xsd:anyURI ;
    ns1:name "World Wide Web Consortium" ;
    ns1:officialName "World Wide Web Consortium" .

<http://example.org/semantic-web/instance/wikidata> a ns1:Dataset ;
    rdfs:label "Wikidata" ;
    ns1:description "A central open knowledge base that connects many other open datasets." ;
    ns1:name "Wikidata" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/yahoo> a ns1:Organization ;
    rdfs:label "Yahoo!" ;
    ns1:name "Yahoo!" ;
    ns1:officialName "Yahoo!" .

<http://example.org/semantic-web/instance/yandex> a ns1:Organization ;
    rdfs:label "Yandex" ;
    ns1:name "Yandex" ;
    ns1:officialName "Yandex" .

<http://example.org/semantic-web/instance/attribute-concept> a ns1:AttributeConcept ;
    rdfs:label "Attributes" ;
    ns1:description "Datatype properties that describe characteristics or values associated with a class or individual." ;
    ns1:name "Attributes" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/axiom-concept> a ns1:AxiomConcept ;
    rdfs:label "Axioms" ;
    ns1:description "Logical assertions, constraints, and rules that are always true within an ontology and support reasoning." ;
    ns1:name "Axioms" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/class-concept> a ns1:ClassConcept ;
    rdfs:label "Class" ;
    ns1:description "Abstract concepts or categories within a domain, typically organized into taxonomies or hierarchies." ;
    ns1:name "Classes" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/individual-concept> a ns1:IndividualConcept ;
    rdfs:label "Individuals" ;
    ns1:description "Concrete real-world instances that belong to classes in an ontology." ;
    ns1:name "Individuals" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/proof-layer> a ns1:ProofLayer ;
    rdfs:label "Proof layer" ;
    ns1:description "Layer concerning proof and justification of inferred knowledge." ;
    ns1:name "Proof" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-paradigm> .

<http://example.org/semantic-web/instance/relationship-concept> a ns1:RelationshipConcept ;
    rdfs:label "Relationships" ;
    ns1:description "Object properties that define how classes and individuals relate to one another." ;
    ns1:name "Relationships" ;
    ns1:partOf <http://example.org/semantic-web/instance/ontology-md> .

<http://example.org/semantic-web/instance/rules-layer> a ns1:RulesLayer ;
    rdfs:label "Rules layer" ;
    ns1:description "Layer covering logic rule technologies used with ontologies for advanced reasoning." ;
    ns1:name "Rules" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-paradigm> .

<http://example.org/semantic-web/instance/trust-layer> a ns1:TrustLayer ;
    rdfs:label "Trust layer" ;
    ns1:description "Layer concerning provenance, reliability, and trustworthiness of semantic data." ;
    ns1:name "Trust" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-paradigm> .

<http://example.org/semantic-web/instance/web-of-data> a ns1:WebOfData ;
    rdfs:label "Web of Data" ;
    ns1:broaderThan <http://example.org/semantic-web/instance/web-of-documents> ;
    ns1:description "The machine-understandable, data-centric web based on typed relationships and explicit semantics." ;
    ns1:name "Web of Data" .

<http://example.org/semantic-web/instance/query-layer> a ns1:QueryLayer ;
    rdfs:label "Query layer" ;
    ns1:description "Layer covering SPARQL for graph-pattern matching and RDF querying." ;
    ns1:name "Query" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-paradigm> .

<http://example.org/semantic-web/instance/web-of-documents> a ns1:WebOfDocuments ;
    rdfs:label "Web of Documents" ;
    ns1:description "The traditional web centered on unstructured and semi-structured documents for human consumption." ;
    ns1:name "Web of Documents" .

<http://example.org/semantic-web/instance/data-model-layer> a ns1:DataModelLayer ;
    rdfs:label "Data Model layer" ;
    ns1:description "Layer covering RDF and RDF Schema as the foundational graph data model and schema vocabulary." ;
    ns1:name "Data Model" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-paradigm> .

<http://example.org/semantic-web/instance/identifier-layer> a ns1:IdentifierLayer ;
    rdfs:label "Identifiers and Character Sets layer" ;
    ns1:description "Layer covering URI, IRI, and Unicode for global identification and character encoding." ;
    ns1:name "Identifiers and Character Sets" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-paradigm> .

<http://example.org/semantic-web/instance/ontology-layer> a ns1:OntologyLayer ;
    rdfs:label "Ontology layer" ;
    ns1:description "Layer covering ontology technologies such as OWL and SKOS for advanced semantic modeling." ;
    ns1:name "Ontology" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-paradigm> .

<http://example.org/semantic-web/instance/syntax-layer> a ns1:SyntaxLayer ;
    rdfs:label "Syntax and Serialization layer" ;
    ns1:description "Layer covering text syntaxes used to serialize semantic graphs, including Turtle, JSON-LD, and RDF/XML." ;
    ns1:name "Syntax and Serialization" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-paradigm> .

<http://example.org/semantic-web/instance/semantic-web-paradigm> a ns1:SemanticWeb ;
    rdfs:label "Semantic Web" ;
    ns1:description "An evolutionary extension of the World Wide Web that embeds explicit, machine-understandable semantics into web resources to support data, information, and knowledge exchange." ;
    ns1:hasComponent <http://example.org/semantic-web/instance/web-of-data>,
        <http://example.org/semantic-web/instance/web-of-documents> ;
    ns1:hasLayer <http://example.org/semantic-web/instance/data-model-layer>,
        <http://example.org/semantic-web/instance/identifier-layer>,
        <http://example.org/semantic-web/instance/ontology-layer>,
        <http://example.org/semantic-web/instance/proof-layer>,
        <http://example.org/semantic-web/instance/query-layer>,
        <http://example.org/semantic-web/instance/rules-layer>,
        <http://example.org/semantic-web/instance/syntax-layer>,
        <http://example.org/semantic-web/instance/trust-layer> ;
    ns1:name "Semantic Web" ;
    ns1:partOf <http://example.org/semantic-web/instance/semantic-web-md> .

<http://example.org/semantic-web/instance/ontology-md> a ns1:Document ;
    rdfs:label "ontology.md" ;
    ns1:description "An explanatory document introducing ontologies in information science, including ontology definition, core components, taxonomy vs. knowledge graph vs. ontology, OWL profiles, semantic reasoning, and foundational ontologies." ;
    ns1:title "Comprehensive Introduction to Ontologies in Information Science" .

<http://example.org/semantic-web/instance/semantic-web-md> a ns1:Document ;
    rdfs:label "semantic web.md" ;
    ns1:description "An explanatory document describing the Semantic Web, its architectural layers, logical principles, and modern implementations." ;
    ns1:title "The Semantic Web: Architecture, Logic, and Engineering" .

